---
import '~/components/Hero.css'
import Button from '~/components/Button.astro'
import FormattedDate from '~/components/FormattedDate.astro'
import Tag from '~/components/Tag.astro'

interface CallToAction {
    label: string;
    href: string;
}

interface LatestPost {
    title: string;
    slug: string;
    date: string;
    tags: string[];
    coverImage?: string;
    extract?: string;
}

interface Props {
    title: string;
    subtitle: string;
    role: string;
    aiTagline?: string;
    callToActions: CallToAction[];
    latestPost?: LatestPost;
    lang?: string;
}

const { title, subtitle, role, aiTagline, callToActions, latestPost, lang = "it" } = Astro.props;
const blogPrefix = lang === "it" ? "/blog" : "/en/blog";
const latestLabel = lang === "it" ? "Ultimo articolo" : "Latest post";
---

<section class="Hero">
  <div class="container">
    <video class="video" autoplay muted loop playsinline>
      <source src="/videos/CARAMELLA_TRAILER.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="overlay">
    {latestPost && (
      <a class="hero-latest-post" href={`${blogPrefix}/${latestPost.slug}/`}>
        {latestPost.coverImage && (
          <img class="hlp-cover" src={latestPost.coverImage} alt="" loading="eager" />
        )}
        <span class="hlp-label">{latestLabel}</span>
        <span class="hlp-title">{latestPost.title}</span>
        {latestPost.extract && (
          <span class="hlp-extract">{latestPost.extract.length > 100 ? latestPost.extract.substring(0, 97) + "..." : latestPost.extract}</span>
        )}
        <span class="hlp-meta">
          <FormattedDate date={new Date(latestPost.date)} />
          {latestPost.tags.slice(0, 2).map((tag) => (
            <Tag tag={tag} lang={lang} asSpan={true} />
          ))}
        </span>
      </a>
    )}
    <div class="content">
      <h1 class="cursor-blink">{title}</h1>
      <p class="hero-subtitle">
        <span class="prompt">&gt;</span> {role}
      </p>
      <p class="hero-subtitle">{subtitle}</p>
      {aiTagline && (
        <p class="hero-ai-tagline">// {aiTagline}</p>
      )}
      <div class="call-to-actions">
        {callToActions.map((cta) => <Button label={cta.label} href={cta.href} />)}
      </div>
    </div>
    {latestPost && (
      <a class="hero-mobile-post" href={`${blogPrefix}/${latestPost.slug}/`}>
        <span class="hmp-label">{latestLabel}</span>
        <span class="hmp-title">{latestPost.title}</span>
      </a>
    )}
    <button class="floating-btn">
      <span class="arrow">&#8595;</span>
    </button>
  </div>
</section>

<script>
  const button = document.querySelector('button.floating-btn');
  button?.addEventListener('click', () => {
    const targetSection = document.getElementById('last-watched');
    if (targetSection) {
      targetSection.scrollIntoView({ behavior: 'smooth' });
    }
  });
</script>
