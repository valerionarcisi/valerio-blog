---

<div class="nfr-game" data-lang={lang}>
  <div class="nfr-main">
    <div class="nfr-stage" id="nfr-stage">
      <canvas id="nfr-canvas" width="640" height="360" aria-label="Non Fa Ridere mini-game"></canvas>

      <div class="nfr-hud">
        <span class="nfr-hud-item"><b id="nfr-score">0</b> {t.score}</span>
        <span class="nfr-hud-item nfr-hud-level" id="nfr-level-label"></span>
        <span class="nfr-hud-item">{t.lives} <b id="nfr-lives">3</b></span>
      </div>

      <div class="nfr-sysbtns">
        <button class="nfr-sysbtn" id="nfr-mute" aria-label="audio">♪</button>
        <button class="nfr-sysbtn" id="nfr-fs" aria-label="fullscreen">⛶</button>
      </div>

      <div class="nfr-overlay" id="nfr-overlay-start">
        <p class="nfr-title">NON FA RIDERE</p>
        <p class="nfr-cta">{t.tapToStart}</p>
        <p class="nfr-help">{t.move}</p>
      </div>

      <div class="nfr-overlay nfr-hidden" id="nfr-overlay-level">
        <p class="nfr-level-clear" id="nfr-level-clear-text"></p>
        <p class="nfr-level-name" id="nfr-level-next-name"></p>
        <button class="nfr-restart" id="nfr-next-level-btn">{t.nextLevel}</button>
      </div>

      <div class="nfr-overlay nfr-hidden" id="nfr-overlay-end">
        <p class="nfr-title">{t.gameOver}</p>
        <p class="nfr-final"><span id="nfr-final-score">0</span> {t.score}</p>
        <form class="nfr-submit" id="nfr-submit-form">
          <input
            type="text"
            id="nfr-name"
            maxlength="24"
            placeholder={t.namePlaceholder}
            autocomplete="off"
          />
          <button type="submit" id="nfr-submit-btn">{t.submit}</button>
        </form>
        <p class="nfr-submitted nfr-hidden" id="nfr-submitted">{t.submitted}</p>
        <button class="nfr-restart" id="nfr-restart">{t.again}</button>
      </div>

      <div class="nfr-touch" id="nfr-touch">
        <div class="nfr-touch-group">
          <button class="nfr-tbtn" id="nfr-t-left" aria-label="left">◀</button>
          <button class="nfr-tbtn" id="nfr-t-right" aria-label="right">▶</button>
        </div>
        <div class="nfr-touch-group">
          <button class="nfr-tbtn" id="nfr-t-jump">{t.jump}</button>
          <button class="nfr-tbtn nfr-tbtn-acc" id="nfr-t-throw">{t.throw}</button>
        </div>
      </div>
    </div>

    <div class="nfr-howto">
      <h3 class="nfr-howto-title">{t.howTitle}</h3>
      <dl class="nfr-howto-list">
        <dt>{t.howKeys}</dt><dd>{t.howKeysVal}</dd>
        <dt>{t.howTouch}</dt><dd>{t.howTouchVal}</dd>
        <dt>{t.howGoal}</dt><dd>{t.howGoalVal}</dd>
        <dt>{t.howLevels}</dt><dd>{t.howLevelsVal}</dd>
      </dl>
    </div>
  </div>

  <aside class="nfr-board">
    <h3 class="nfr-board-title">{t.leaderboard}</h3>
    <ol class="nfr-board-list" id="nfr-board-list">
      <li class="nfr-board-loading">{t.loading}</li>
    </ol>
  </aside>
</div>

