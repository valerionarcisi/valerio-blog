  // ── Musica punk: WebAudio procedurale, chitarra + batteria ──────
  const music = {
    ac: null, master: null, distortion: null,
    timer: null, nextTime: 0, step: 0,
    muted: localStorage.getItem("nfr-muted") === "1",
    bpm: 172,
    // L1 sala: garage A-D-G-D · L2 bar: groove dondolante E-G-A · L3 cucina:
    // teso E-A-B · L4 palco: massima velocità, giro di potenza.
