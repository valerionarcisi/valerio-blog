  function spriteSize(def) {
    return { w: def.rows[0].length * SCALE, h: def.rows.length * SCALE };
  }

  function drawSprite(def, sx, sy, flip, alpha) {
    ctx.globalAlpha = alpha ?? 1;
    const cols = def.rows[0].length;
    for (let r = 0; r < def.rows.length; r++) {
      const row = def.rows[r];
      for (let c = 0; c < cols; c++) {
        const ch = row[flip ? cols - 1 - c : c];
        if (ch === ".") continue;
        const color = def.colors[ch];
        if (!color) continue;
        ctx.fillStyle = color;
        ctx.fillRect(Math.round(sx + c * SCALE), Math.round(sy + r * SCALE), SCALE, SCALE);
      }
    }
    ctx.globalAlpha = 1;
  }

  // ── Dialetto autentico dalla sceneggiatura ──────────────────────
  const LINES = {
