      1: [110, 110, 146.83, 146.83, 196, 196, 146.83, 146.83],
      2: [82.4, 98, 82.4, 110, 98, 110, 130.81, 110],
      3: [82.4, 82.4, 110, 110, 123.47, 123.47, 110, 110],
      4: [82.4, 110, 82.4, 110, 123.47, 164.81, 123.47, 110],
    },
    bpms: { 1: 172, 2: 178, 3: 196, 4: 212 },
  };

  function audioInit() {
    if (music.ac) return;
    const AC = window.AudioContext || window.webkitAudioContext;
    if (!AC) return;
    music.ac = new AC();
    music.master = music.ac.createGain();
    music.master.gain.value = music.muted ? 0 : 0.16;
    music.master.connect(music.ac.destination);
    const curve = new Float32Array(256);
    for (let i = 0; i < 256; i++) curve[i] = Math.tanh((i / 128 - 1) * 8);
    music.distortion = music.ac.createWaveShaper();
    music.distortion.curve = curve;
    const lp = music.ac.createBiquadFilter();
    lp.type = "lowpass";
    lp.frequency.value = 2400;
    music.distortion.connect(lp);
    lp.connect(music.master);
  }

  function chug(time, rootHz) {
    const ac = music.ac;
    const g = ac.createGain();
    g.gain.setValueAtTime(0.0001, time);
    g.gain.linearRampToValueAtTime(0.55, time + 0.005);
    g.gain.exponentialRampToValueAtTime(0.0001, time + 0.13);
    g.connect(music.distortion);
    for (const mult of [1, 1.5, 2]) {
      const o = ac.createOscillator();
      o.type = "sawtooth";
      o.frequency.value = rootHz * mult;
      o.detune.value = (Math.random() - 0.5) * 18;
      o.connect(g);
      o.start(time);
      o.stop(time + 0.16);
    }
  }

  function snare(time) {
    const ac = music.ac;
    const len = 0.12;
    const buf = ac.createBuffer(1, ac.sampleRate * len, ac.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
    const src = ac.createBufferSource();
    src.buffer = buf;
    const bp = ac.createBiquadFilter();
    bp.type = "bandpass";
    bp.frequency.value = 1800;
    bp.Q.value = 0.8;
    const g = ac.createGain();
    g.gain.setValueAtTime(0.5, time);
    g.gain.exponentialRampToValueAtTime(0.001, time + len);
    src.connect(bp);
    bp.connect(g);
    g.connect(music.master);
    src.start(time);
  }

  function kick(time) {
    const ac = music.ac;
    const o = ac.createOscillator();
    o.type = "sine";
    o.frequency.setValueAtTime(120, time);
    o.frequency.exponentialRampToValueAtTime(42, time + 0.12);
    const g = ac.createGain();
    g.gain.setValueAtTime(0.7, time);
    g.gain.exponentialRampToValueAtTime(0.001, time + 0.14);
    o.connect(g);
    g.connect(music.master);
    o.start(time);
    o.stop(time + 0.15);
  }

  function musicStart() {
    audioInit();
    if (!music.ac) return;
    music.ac.resume();
    if (music.timer) clearInterval(music.timer);
    const bpm = music.bpms[state.level] || 172;
    const stepDur = 60 / bpm / 2;
    music.nextTime = music.ac.currentTime + 0.05;
    music.step = 0;
    music.timer = setInterval(() => {
      const riff = music.riffs[state.level] || music.riffs[1];
      while (music.nextTime < music.ac.currentTime + 0.12) {
        const s = music.step % 8;
        chug(music.nextTime, riff[s]);
        if (s === 0 || s === 4) kick(music.nextTime);
        if (s === 2 || s === 6) snare(music.nextTime);
        music.step += 1;
        music.nextTime += stepDur;
      }
    }, 30);
  }

  function musicStop() {
    if (music.timer) { clearInterval(music.timer); music.timer = null; }
  }

  function syncMuteBtn() {
    el.mute.textContent = music.muted ? "✕" : "♪";
    el.mute.classList.toggle("nfr-sysbtn-off", music.muted);
  }
  el.mute.addEventListener("click", () => {
    music.muted = !music.muted;
    localStorage.setItem("nfr-muted", music.muted ? "1" : "0");
    if (music.master) music.master.gain.value = music.muted ? 0 : 0.16;
    syncMuteBtn();
  });
  syncMuteBtn();

  // Fullscreen cross-platform. iOS Safari blocca requestFullscreen sugli
  // elementi non-video, quindi usiamo un fallback CSS (position: fixed).
  const isTouch = window.matchMedia("(pointer: coarse)").matches;

  function nativeFsAvailable() {
    return !!(el.stage.requestFullscreen || el.stage.webkitRequestFullscreen);
  }
  function enterGameView() {
    if (nativeFsAvailable()) {
      const req = el.stage.requestFullscreen || el.stage.webkitRequestFullscreen;
      const p = req.call(el.stage);
      if (p && p.catch) p.catch(() => el.stage.classList.add("nfr-fs-fallback"));
    } else {
      el.stage.classList.add("nfr-fs-fallback");
    }
  }
  function exitGameView() {
    if (document.fullscreenElement || document.webkitFullscreenElement) {
      (document.exitFullscreen || document.webkitExitFullscreen).call(document);
    }
    el.stage.classList.remove("nfr-fs-fallback");
  }

  el.fs.addEventListener("click", () => {
    const inFs = document.fullscreenElement || document.webkitFullscreenElement || el.stage.classList.contains("nfr-fs-fallback");
    if (inFs) exitGameView();
    else enterGameView();
  });

  // ── Game flow ──────────────────────────────────────────────────
  function levelNames() {
    return [level1Name, level2Name, level3Name, level4Name];
  }

  function syncHud() {
    el.score.textContent = String(state.score);
    el.lives.textContent = String(state.lives);
    let progress = "";
    if (state.level === 1 || state.level === 2) {
      const left = Math.max(0, LEVEL_KILLS_TO_CLEAR[state.level] - state.killCount);
      progress = left > 0 ? ` · ${left}` : " · →";
    } else if (state.level === 3) {
      if (!state.teaDefeated) progress = state.bossAlive ? " · TEA" : ` · ${Math.max(0, TEA_BOSS_AT - state.killCount)}`;
      else progress = ` · ${Math.max(0, LEVEL_KILLS_TO_CLEAR[3] - state.killCount)}`;
    } else {
      progress = " · GIULIO";
    }
    // Su mobile l'etichetta è corta (il nome livello toglierebbe spazio al
    // contatore); su desktop mostra anche il nome della scena.
    el.levelLabel.textContent = isTouch
      ? `${levelLabel} ${state.level}${progress}`
      : `${levelLabel} ${state.level} — ${levelNames()[state.level - 1]}${progress}`;
  }

  function resetLevel(lvl) {
    state.level = lvl;
    state.tick = 0;
    state.camX = 0;
    state.killCount = 0;
    state.bossAlive = false;
    state.teaDefeated = false;
    state.giulioDefeated = false;
    state.levelTransition = false;
    state.pizzas = [];
    state.enemies = [];
    state.popups = [];
    state.particles = [];
    state.combo = 0;
    state.comboT = 0;
    state.shake = 0;
    state.spawnTimer = 0;
    state.player = { x: 80, y: groundY(80), vy: 0, dir: 1, onGround: true, hurtT: 0 };
    musicStart();
    syncHud();
    // Livello 4 (palco): niente attesa, Giulio entra subito.
    if (lvl === 4) spawnEnemy();
  }

  function reset() {
    state.score = 0;
    state.lives = 3;
    resetLevel(1);
  }

  function start() {
    reset();
    state.running = true;
    el.overlayStart.classList.add("nfr-hidden");
    el.overlayEnd.classList.add("nfr-hidden");
    el.overlayLevel.classList.add("nfr-hidden");
    // Su mobile il gioco va a tutto schermo per essere giocabile.
    if (isTouch) enterGameView();
  }

  function showLevelTransition(nextLvl) {
    state.running = false;
    state.levelTransition = true;
    musicStop();
    el.levelClearText.textContent = levelClearMsg;
    el.levelNextName.textContent = levelNames()[nextLvl - 1];
    el.overlayLevel.classList.remove("nfr-hidden");
  }

  function say(e, text) {
    e.bubble = text;
    e.bubbleT = 130;
  }

  function spawnEnemy() {
    let type;
    const lv = state.level;

    if (lv === 4) {
      // Palco: solo Giulio, una volta.
      if (state.giulioDefeated) return;
      if (!state.bossAlive) {
        type = "giulio";
        state.bossAlive = true;
      } else return;
    } else if (lv === 3) {
      // Cucina: cuochi, poi Tea mini-boss.
      if (state.killCount >= TEA_BOSS_AT && !state.teaDefeated && !state.bossAlive) {
        type = "teaBoss";
        state.bossAlive = true;
      } else if (state.teaDefeated) {
        const r = Math.random();
        type = r < 0.6 ? "cuoco" : "rider";
      } else {
        const r = Math.random();
        if (r < 0.5) type = "cuoco";
        else if (r < 0.75) type = "rider";
        else type = "vecchia";
      }
    } else if (lv === 2) {
      // Bar: Michele il comico, qualche vecchia e rider, e ogni tanto il nonno.
      const r = Math.random();
      if (r < 0.10) type = "nonno";
      else if (r < 0.50) type = "michele";
      else if (r < 0.72) type = "rider";
      else type = "vecchia";
    } else {
      // Sala
      const r = Math.random();
      if (r < 0.08) type = "nonno";
      else if (r < 0.16) type = "tea";
      else if (r < 0.40) type = "rider";
      else if (r < 0.62) type = "comico";
      else type = "vecchia";
    }

    const def = ENEMIES[type];
    const sprite = SPRITES[type === "teaBoss" ? "tea" : type];
    const size = spriteSize(sprite);
    // la maggior parte arriva dal fronte (destra, dove avanzi): meno colpi a sorpresa da dietro
    const fromLeft = Math.random() < 0.28;
    let x = fromLeft ? state.camX - size.w - 30 : state.camX + W + 30;
    x = Math.max(-size.w - 40, Math.min(WORLD_W + 40, x));
    if (def.boss) {
      // Giulio entra dal bordo destro dell'arena (palco a schermo fisso)
      x = state.level === 4 ? W - size.w - 16 : Math.min(WORLD_W - size.w - 20, state.camX + W + 30);
    }

    const lines = type === "teaBoss" ? LINES.teaBoss : (LINES[type] || LINES.cuoco);
    const e = {
      type, def, sprite, w: size.w, h: size.h,
      x,
      y: def.ghost ? FLOOR - size.h - 60 : groundY(x) - size.h,
      vx: (x < state.player.x ? 1 : -1) * def.speed,
      vy: 0,
      hp: def.hp,
      seed: Math.random() * Math.PI * 2,
      bubble: null, bubbleT: 0,
    };
    say(e, lines[Math.floor(Math.random() * lines.length)]);
    state.enemies.push(e);
  }

  function throwPizza() {
    if (!state.running) return;
    if (state.pizzas.length >= MAX_PIZZAS) return;
    state.pizzas.push({
      x: state.player.x + pSize.w / 2 + state.player.dir * 14,
      y: state.player.y - pSize.h + 16,
      vx: state.player.dir * 6.4,
      vy: -1.2, r: 7,
    });
  }

  function loseLife() {
    state.lives -= 1;
    state.player.hurtT = 70;
    state.combo = 0;
    state.comboT = 0;
    state.shake = Math.max(state.shake, 9);
    const p = state.player;
    addPopup(p.x - state.camX + pSize.w / 2, p.y - pSize.h, "Ahia!", C.accent);
    syncHud();
    if (state.lives <= 0) gameOver();
  }

  function gameOver() {
    state.running = false;
    musicStop();
    if (state.score > state.best) {
      state.best = state.score;
      localStorage.setItem("nfr-best", String(state.best));
    }
    el.finalScore.textContent = String(state.score);
    el.submitted.classList.add("nfr-hidden");
    el.submitForm.classList.remove("nfr-hidden");
    el.submitBtn.disabled = false;
    el.submitBtn.textContent = submitMsg;
    el.overlayEnd.classList.remove("nfr-hidden");
    // Fine partita su mobile: si esce dal fullscreen, tornando alla pagina.
    if (isTouch) exitGameView();
  }

  // ── Effetti (juice) ────────────────────────────────────────────
  function addPopup(x, y, text, color) {
    state.popups.push({ x, y, text, color: color || C.accent, t: 0, life: 48 });
  }
  function addSplat(x, y, color) {
    for (let i = 0; i < 8; i++) {
      const a = Math.random() * Math.PI * 2;
      const sp = 1 + Math.random() * 3;
      state.particles.push({
        x, y,
        vx: Math.cos(a) * sp,
        vy: Math.sin(a) * sp - 1.5,
        t: 0, life: 24 + (Math.random() * 12 | 0),
        color: color || C.cheese,
        s: 2 + (Math.random() * 2 | 0),
      });
    }
  }

  function killEnemy(e) {
    e.dead = true;
    if (!e.def.friend) {
      // combo: uccisioni ravvicinate valgono di più
      if (state.comboT > 0) state.combo += 1; else state.combo = 1;
      state.comboT = 90;
      const mult = state.combo >= 3 ? 1 + (state.combo - 2) * 0.25 : 1;
      const gained = Math.round(e.def.points * mult);
      state.score += gained;

      const cx = e.x - state.camX + e.w / 2;
      const cy = e.y - 6;
      addPopup(cx, cy, "+" + gained, e.def.boss ? C.accent : C.ink);
      addSplat(e.x - state.camX + e.w / 2, e.y + e.h / 2, e.def.boss ? C.accent : C.cheese);
      if (state.combo >= 3) addPopup(cx, cy - 16, "COMBO ×" + state.combo, C.accent);
      if (e.def.boss) state.shake = Math.max(state.shake, 6);

      if (e.def.boss) {
        state.bossAlive = false;
        if (e.def.teaBoss) state.teaDefeated = true;
        else state.giulioDefeated = true;
      } else {
        state.killCount += 1;
      }
    }
    checkLevelProgress();
  }

  function checkLevelProgress() {
    const lv = state.level;
    if (lv === 1 && state.killCount >= LEVEL_KILLS_TO_CLEAR[1]) {
      showLevelTransition(2);
    } else if (lv === 2 && state.killCount >= LEVEL_KILLS_TO_CLEAR[2]) {
      showLevelTransition(3);
    } else if (lv === 3 && state.teaDefeated && state.killCount >= LEVEL_KILLS_TO_CLEAR[3]) {
      showLevelTransition(4);
    } else if (lv === 4 && state.giulioDefeated) {
      setTimeout(gameOver, 1000);
    }
  }

  // ── Update ─────────────────────────────────────────────────────
  function update() {
    state.tick += 1;
    const p = state.player;

    // Il palco (L4) è un'arena a schermo fisso: niente scroll, Filippo si
    // muove dentro lo schermo e il microfono resta al suo posto.
    const arena = state.level === 4;
    const maxX = (arena ? W : WORLD_W) - pSize.w;

    let vx = 0;
    if (state.keys.left) { vx = -RUN_V; p.dir = -1; }
    if (state.keys.right) { vx = RUN_V; p.dir = 1; }
    p.x = Math.max(0, Math.min(maxX, p.x + vx));

    p.vy += GRAVITY;
    p.y += p.vy;
    const gy = groundY(p.x + pSize.w / 2);
    if (p.y >= gy) { p.y = gy; p.vy = 0; p.onGround = true; }
    else p.onGround = false;
    if (p.hurtT > 0) p.hurtT -= 1;

    state.camX = arena ? 0 : Math.max(0, Math.min(WORLD_W - W, p.x + pSize.w / 2 - W / 2));

    state.spawnTimer += 1;
    // L4 (palco): nessun nuovo spawn, c'è solo Giulio. Cucina/bar più fitti.
    const baseCadence = state.level === 4 ? 99999 : state.level === 3 ? 70 : state.level === 2 ? 84 : 100;
    const cadence = Math.max(38, baseCadence - Math.floor(state.score / 30));
    if (state.spawnTimer >= cadence) {
      state.spawnTimer = 0;
      spawnEnemy();
    }

    for (const z of state.pizzas) {
      z.x += z.vx;
      z.vy += 0.3;
      z.y += z.vy;
      const zgy = groundY(z.x) + 8;
      if (z.y > zgy) { z.y = zgy; z.vy = -4.2; }
      if (z.x < -20 || z.x > WORLD_W + 20) z.dead = true;
    }
    state.pizzas = state.pizzas.filter((z) => !z.dead);

    const ramp = 1 + state.score / 4000;
    for (const e of state.enemies) {
      e.x += e.vx * ramp;
      // Michele si dondola da comico mentre cammina verso di te
      if (e.def.wobble) e.x += Math.sin((state.tick + e.seed * 30) / 11) * 1.3;
      if (e.def.ghost) {
        // vola basso abbastanza da poterlo colpire con pizza o salto
        e.y = FLOOR - e.h - 22 + Math.sin((state.tick + e.seed * 40) / 30) * 16;
      } else if (e.def.hops) {
        e.vy += GRAVITY;
        e.y += e.vy;
        const egy = groundY(e.x + e.w / 2) - e.h;
        if (e.y >= egy) { e.y = egy; e.vy = Math.random() < 0.5 ? -5.5 : 0; }
      } else {
        e.y = groundY(e.x + e.w / 2) - e.h;
      }
      if (e.bubbleT > 0) e.bubbleT -= 1;
      if ((e.vx < 0 && e.x < -e.w - 60) || (e.vx > 0 && e.x > WORLD_W + 60)) e.dead = true;

      if (e.def.boss && !e.def.teaBoss) {
        // Giulio insegue Filippo per tutto il palco; più veloce quando è ferito
        const enraged = e.hp <= e.def.hp * 0.4;
        const chase = (enraged ? 1.7 : 1) * e.def.speed;
        const dir = (p.x + pSize.w / 2) > (e.x + e.w / 2) ? 1 : -1;
        // scatto improvviso ogni tanto (più frequente da arrabbiato)
        e.dashT = (e.dashT || 0) - 1;
        if (e.dashT <= 0 && state.tick % (enraged ? 95 : 150) === 0) {
          e.dashT = 26;
          say(e, LINES.giulio[Math.floor(Math.random() * LINES.giulio.length)]);
        }
        const dashing = e.dashT > 0;
        e.vx = dir * chase * (dashing ? 3.2 : 1);
        e.x = Math.max(20, Math.min(W - e.w - 20, e.x));
      }
      if (e.def.teaBoss) {
        // Tea difende il bancone della cucina
        if (e.x < COUNTER_X - 80) e.vx = Math.abs(e.vx);
        if (e.x > COUNTER_X + COUNTER_W - e.w + 30) e.vx = -Math.abs(e.vx);
        if (state.tick % 180 === 0) say(e, LINES.teaBoss[Math.floor(Math.random() * LINES.teaBoss.length)]);
      }
    }

    // Pizza ↔ nemico
    for (const z of state.pizzas) {
      for (const e of state.enemies) {
        if (e.dead) continue;
        if (z.x + z.r > e.x && z.x - z.r < e.x + e.w && z.y + z.r > e.y && z.y - z.r < e.y + e.h) {
          z.dead = true;
          addSplat(z.x - state.camX, z.y, C.cheese);
          if (e.def.friend) {
            e.dead = true;
            say(e, LINES.teaHit);
            state.score = Math.max(0, state.score - 30);
            loseLife();
          } else {
            e.hp -= 1;
            if (e.hp <= 0) killEnemy(e);
            else state.shake = Math.max(state.shake, 3); // colpito ma vivo (boss)
          }
          break;
        }
      }
    }
    state.pizzas = state.pizzas.filter((z) => !z.dead);

    // Player ↔ nemico: stomp o danno contatto
    const px1 = p.x + 6, px2 = p.x + pSize.w - 6;
    const pTop = p.y - pSize.h, pBot = p.y;
    for (const e of state.enemies) {
      if (e.dead) continue;
      const overlapX = px2 > e.x + 4 && px1 < e.x + e.w - 4;
      if (!overlapX) continue;
      const stomping = p.vy > 1 && pBot > e.y && pBot < e.y + e.h * 0.6;
      if (stomping) {
        p.vy = JUMP_V * 0.75;
        if (e.def.friend) continue;
        if (e.def.boss) { e.hp -= 1; if (e.hp <= 0) killEnemy(e); }
        else killEnemy(e);
      } else if (pBot > e.y + 4 && pTop < e.y + e.h - 4) {
        // il nonno (ghost) attraversa senza fare danno; lo si batte solo a pizza/salto
        if (e.def.friend || e.def.ghost) continue;
        if (p.hurtT === 0) {
          if (!e.def.boss) e.dead = true;
          loseLife();
        }
      }
    }
    state.enemies = state.enemies.filter((e) => !e.dead);

    // ── Effetti ──
    if (state.comboT > 0) { state.comboT -= 1; if (state.comboT === 0) state.combo = 0; }
    if (state.shake > 0) state.shake *= 0.85;
    if (state.shake < 0.4) state.shake = 0;
    for (const pp of state.popups) { pp.t += 1; pp.y -= 0.7; }
    state.popups = state.popups.filter((pp) => pp.t < pp.life);
    for (const pt of state.particles) {
      pt.t += 1; pt.vy += 0.35; pt.x += pt.vx; pt.y += pt.vy;
    }
    state.particles = state.particles.filter((pt) => pt.t < pt.life);

    syncHud();
  }

  // ── Render backgrounds ─────────────────────────────────────────
  function drawTable(wx) {
    const x = wx - state.camX;
    ctx.fillStyle = "#fbf7ee";
    ctx.beginPath();
    ctx.moveTo(x, FLOOR - 34); ctx.lineTo(x + 64, FLOOR - 34);
    ctx.lineTo(x + 58, FLOOR - 12); ctx.lineTo(x + 6, FLOOR - 12);
    ctx.closePath(); ctx.fill();
    ctx.strokeStyle = "#d8cebd"; ctx.stroke();
    ctx.fillStyle = C.woodDark;
    ctx.fillRect(x + 12, FLOOR - 12, 4, 12);
    ctx.fillRect(x + 48, FLOOR - 12, 4, 12);
    ctx.fillStyle = "#3f6e3a";
    ctx.fillRect(x + 28, FLOOR - 46, 5, 12);
  }

  function drawBgSala() {
    const cam = state.camX;
    ctx.fillStyle = C.wall;
    ctx.fillRect(0, 0, W, FLOOR);

    // forno a legna
    const ox = 26 - cam;
    if (ox > -120 && ox < W) {
      ctx.fillStyle = "#b8743a";
      ctx.fillRect(ox, FLOOR - 82, 96, 82);
      ctx.fillStyle = C.ink;
      ctx.beginPath(); ctx.arc(ox + 48, FLOOR - 32, 25, Math.PI, 0); ctx.fill();
      ctx.fillStyle = C.accent;
      ctx.beginPath(); ctx.arc(ox + 48, FLOOR - 32, 17, Math.PI, 0); ctx.fill();
      ctx.fillStyle = "#f0a030";
      const f = Math.sin(state.tick / 5) * 3;
      ctx.fillRect(ox + 42, FLOOR - 38 + f, 5, 6);
      ctx.fillRect(ox + 50, FLOOR - 41 - f, 4, 8);
    }
    drawTable(200); drawTable(420);

    const lx = 600 - cam;
    if (lx > -60 && lx < W) {
      ctx.fillStyle = "#fbf7ee";
      ctx.fillRect(lx, 80, 44, 60);
      ctx.strokeStyle = C.ink; ctx.strokeRect(lx, 80, 44, 60);
      ctx.fillStyle = "#e8c9a0"; ctx.fillRect(lx + 12, 90, 20, 20);
      ctx.fillStyle = C.ink;
      ctx.font = '6px "JetBrains Mono", monospace';
      ctx.fillText("OPEN", lx + 11, 122);
      ctx.fillText("GREZZO", lx + 7, 130);
      ctx.fillStyle = C.accent; ctx.fillText("21:30", lx + 11, 137);
    }
    const dx = 700 - cam;
    if (dx > -40 && dx < W) {
      ctx.fillStyle = C.wallDark;
      ctx.fillRect(dx, FLOOR - 110, 8, 110);
      ctx.font = '8px "JetBrains Mono", monospace';
      ctx.fillStyle = C.accent;
      ctx.fillText("PALCO →", dx - 26, FLOOR - 116);
    }

    // palco
    const sx = STAGE_X - cam;
    if (sx < W && sx + STAGE_W > 0) {
      ctx.fillStyle = "#e9dfc8";
      ctx.fillRect(sx + 60, 26, STAGE_W - 120, 38);
      ctx.strokeStyle = C.ink; ctx.lineWidth = 1;
      ctx.strokeRect(sx + 60, 26, STAGE_W - 120, 38);
      ctx.fillStyle = C.ink;
      ctx.font = '14px "JetBrains Mono", monospace'; ctx.textAlign = "center";
      ctx.fillText("OPEN GREZZO", sx + STAGE_W / 2, 45);
      ctx.font = '8px "JetBrains Mono", monospace';
      ctx.fillText("un open mic provinciale", sx + STAGE_W / 2, 57);
      ctx.textAlign = "left";
      ctx.globalAlpha = 0.12 + Math.sin(state.tick / 40) * 0.03;
      ctx.fillStyle = "#f0d98a";
      ctx.beginPath(); ctx.moveTo(sx + 90, 0); ctx.lineTo(sx + 150, FLOOR - STAGE_H); ctx.lineTo(sx + 230, FLOOR - STAGE_H); ctx.closePath(); ctx.fill();
      ctx.beginPath(); ctx.moveTo(sx + STAGE_W - 90, 0); ctx.lineTo(sx + STAGE_W - 230, FLOOR - STAGE_H); ctx.lineTo(sx + STAGE_W - 150, FLOOR - STAGE_H); ctx.closePath(); ctx.fill();
      ctx.globalAlpha = 1;
      ctx.fillStyle = C.wood; ctx.fillRect(sx, FLOOR - STAGE_H, STAGE_W, 6);
      ctx.fillStyle = C.woodDark; ctx.fillRect(sx, FLOOR - STAGE_H + 6, STAGE_W, STAGE_H - 6);
      ctx.fillStyle = "#00000022";
      for (let i = 0; i < STAGE_W; i += 26) ctx.fillRect(sx + i, FLOOR - STAGE_H + 6, 2, STAGE_H - 6);
      const mx = sx + STAGE_W / 2;
      ctx.fillStyle = C.ink; ctx.fillRect(mx, FLOOR - STAGE_H - 52, 2, 52);
      ctx.beginPath(); ctx.arc(mx + 1, FLOOR - STAGE_H - 54, 4, 0, Math.PI * 2); ctx.fill();
      ctx.fillRect(sx + 24, FLOOR - STAGE_H - 26, 30, 26);
    }
  }

  function drawBgCucina() {
    const cam = state.camX;
    ctx.fillStyle = C.wallKitchen;
    ctx.fillRect(0, 0, W, FLOOR);

    // piastrelle a griglia
    ctx.strokeStyle = C.tileDark;
    ctx.lineWidth = 0.5;
    for (let tx = -((cam | 0) % 24); tx < W; tx += 24) {
      ctx.beginPath(); ctx.moveTo(tx, 0); ctx.lineTo(tx, FLOOR); ctx.stroke();
    }
    for (let ty = 0; ty < FLOOR; ty += 24) {
      ctx.beginPath(); ctx.moveTo(0, ty); ctx.lineTo(W, ty); ctx.stroke();
    }

    // cappa + cappe aspirazione
    ctx.fillStyle = C.steelDark;
    ctx.fillRect(-((cam | 0) % 380) + 100, 0, 220, 38);
    ctx.fillRect(-((cam | 0) % 380) + 500, 0, 220, 38);
    ctx.fillStyle = C.steel;
    ctx.fillRect(-((cam | 0) % 380) + 104, 4, 212, 30);
    ctx.fillRect(-((cam | 0) % 380) + 504, 4, 212, 30);

    // bancone-fornelli (il piano su cui si cammina)
    const cx = COUNTER_X - cam;
    if (cx < W && cx + COUNTER_W > 0) {
      // fronte del bancone
      ctx.fillStyle = C.steelDark;
      ctx.fillRect(cx, FLOOR - COUNTER_H, COUNTER_W, COUNTER_H);
      ctx.fillStyle = C.steel;
      ctx.fillRect(cx, FLOOR - COUNTER_H, COUNTER_W, 4);
      // fornelli sopra il bancone
      for (let fi = 0; fi < 6; fi++) {
        const fx = cx + 40 + fi * 90;
        const fy = FLOOR - COUNTER_H - 10;
        ctx.fillStyle = "#555";
        ctx.beginPath(); ctx.arc(fx, fy, 14, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = fi === 2 || fi === 4 ? "#c0392b" : "#333";
        ctx.beginPath(); ctx.arc(fx, fy, 9, 0, Math.PI * 2); ctx.fill();
        if (fi === 2 || fi === 4) {
          ctx.fillStyle = "#f0a030";
          const ff = Math.sin(state.tick / 4 + fi) * 2;
          ctx.fillRect(fx - 3, fy - 8 + ff, 2, 5);
          ctx.fillRect(fx + 1, fy - 9 - ff, 2, 6);
        }
      }
      // pentole
      ctx.fillStyle = C.steelDark;
      ctx.fillRect(cx + 155, FLOOR - COUNTER_H - 28, 38, 20);
      ctx.fillRect(cx + 355, FLOOR - COUNTER_H - 28, 38, 20);
    }

    // cartelli appesi
    const s1x = 80 - cam;
    if (s1x > -60 && s1x < W) {
      ctx.fillStyle = "#fbf7ee"; ctx.fillRect(s1x, 60, 54, 32);
      ctx.strokeStyle = C.accent; ctx.lineWidth = 1; ctx.strokeRect(s1x, 60, 54, 32);
      ctx.fillStyle = C.accent;
      ctx.font = '7px "JetBrains Mono", monospace';
      ctx.fillText("CUCINA", s1x + 4, 77);
      ctx.fillText("RISERVATA", s1x + 2, 86);
    }
    const s2x = 400 - cam;
    if (s2x > -60 && s2x < W) {
      ctx.fillStyle = "#fbf7ee"; ctx.fillRect(s2x, 60, 54, 32);
      ctx.strokeStyle = C.ink; ctx.lineWidth = 1; ctx.strokeRect(s2x, 60, 54, 32);
      ctx.fillStyle = C.ink;
      ctx.font = '6px "JetBrains Mono", monospace';
      ctx.fillText("ORDINI", s2x + 8, 77);
      ctx.fillText(String(Math.floor(state.tick / 60) % 20 + 10), s2x + 18, 86);
    }
  }

  function drawBgPalco() {
    // Sfondo scuro, luci di scena
    ctx.fillStyle = C.bgStage;
    ctx.fillRect(0, 0, W, FLOOR);

    // tenda di fondo
    ctx.fillStyle = "#2a1e14";
    ctx.fillRect(0, 0, W, FLOOR);
    for (let i = 0; i < W; i += 28) {
      ctx.fillStyle = i % 56 === 0 ? "#241a10" : "#2e2218";
      ctx.fillRect(i, 0, 28, FLOOR);
    }

    // striscione OPEN GREZZO
    ctx.fillStyle = "#e9dfc8";
    ctx.fillRect(80, 22, W - 160, 44);
    ctx.strokeStyle = C.accent; ctx.lineWidth = 2; ctx.strokeRect(80, 22, W - 160, 44);
    ctx.fillStyle = C.ink;
    ctx.font = 'bold 18px "JetBrains Mono", monospace'; ctx.textAlign = "center";
    ctx.fillText("OPEN GREZZO", W / 2, 46);
    ctx.font = '9px "JetBrains Mono", monospace'; ctx.fillStyle = C.accent;
    ctx.fillText("● LIVE TONIGHT ●", W / 2, 60);
    ctx.textAlign = "left";

    // Occhi di bue pulsanti
    const a1 = 0.18 + Math.sin(state.tick / 30) * 0.07;
    const a2 = 0.18 + Math.sin(state.tick / 30 + Math.PI) * 0.07;
    ctx.globalAlpha = a1;
    ctx.fillStyle = "#f0d98a";
    ctx.beginPath(); ctx.moveTo(60, 0); ctx.lineTo(0, FLOOR - STAGE_H); ctx.lineTo(220, FLOOR - STAGE_H); ctx.closePath(); ctx.fill();
    ctx.globalAlpha = a2;
    ctx.beginPath(); ctx.moveTo(W - 60, 0); ctx.lineTo(W - 220, FLOOR - STAGE_H); ctx.lineTo(W, FLOOR - STAGE_H); ctx.closePath(); ctx.fill();
    ctx.globalAlpha = 1;

    // Pedana legno
    ctx.fillStyle = C.wood; ctx.fillRect(0, FLOOR - STAGE_H, W, 6);
    ctx.fillStyle = C.woodDark; ctx.fillRect(0, FLOOR - STAGE_H + 6, W, STAGE_H - 6);
    ctx.fillStyle = "#00000030";
    for (let i = 0; i < W; i += 26) ctx.fillRect(i, FLOOR - STAGE_H + 6, 2, STAGE_H - 6);

    // Asta microfono centro palco
    ctx.fillStyle = "#e8c9a0";
    ctx.fillRect(W / 2 - 1, FLOOR - STAGE_H - 60, 2, 60);
    ctx.beginPath(); ctx.arc(W / 2, FLOOR - STAGE_H - 62, 5, 0, Math.PI * 2); ctx.fill();

    // Amplificatori ai lati
    ctx.fillStyle = "#1a1410";
    ctx.fillRect(20, FLOOR - STAGE_H - 42, 44, 42);
    ctx.fillRect(W - 64, FLOOR - STAGE_H - 42, 44, 42);
    ctx.fillStyle = "#333";
    ctx.fillRect(26, FLOOR - STAGE_H - 36, 32, 22);
    ctx.fillRect(W - 58, FLOOR - STAGE_H - 36, 32, 22);
    // speaker cone
    ctx.fillStyle = "#555";
    ctx.beginPath(); ctx.arc(42, FLOOR - STAGE_H - 25, 9, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(W - 42, FLOOR - STAGE_H - 25, 9, 0, Math.PI * 2); ctx.fill();
  }

  function drawBgBar() {
    const cam = state.camX;
    // parete calda da bar
    ctx.fillStyle = "#3a2c20";
    ctx.fillRect(0, 0, W, FLOOR);

    // mensole con bottiglie lungo tutta la parete (parallasse leggera)
    const shelfY = [70, 116];
    for (const sy of shelfY) {
      ctx.fillStyle = "#2a1d14";
      ctx.fillRect(0, sy + 26, W, 4);
      const off = (cam * 0.6) % 22;
      for (let i = -22; i < W + 22; i += 22) {
        const bx = i - off;
        const hue = (Math.floor((i + sy) / 22) % 4);
        ctx.fillStyle = ["#5e7d4a", "#7a3a2a", "#c9b06a", "#3a5a72"][hue];
        ctx.fillRect(bx + 6, sy + 6, 7, 20);
        ctx.fillStyle = "#1f1610";
        ctx.fillRect(bx + 8, sy, 3, 7);
      }
    }

    // lavagna dei liquori (come "PECORINO AMARO" del set)
    const lbx = 150 - cam;
    if (lbx > -180 && lbx < W) {
      ctx.fillStyle = "#1a1410";
      ctx.fillRect(lbx, 150, 180, 56);
      ctx.strokeStyle = "#5e4a32"; ctx.lineWidth = 2; ctx.strokeRect(lbx, 150, 180, 56);
      ctx.fillStyle = "#d8c8a8";
      ctx.font = '9px "JetBrains Mono", monospace';
      ctx.fillText("PECORINO  AMARO", lbx + 14, 168);
      ctx.fillText("NOCINO   GRAPPA", lbx + 14, 182);
      ctx.fillStyle = C.accent;
      ctx.fillText("· OPEN GREZZO ·", lbx + 20, 198);
    }

    // bancone del bar (decorativo, non calpestabile: il pavimento è piatto)
    const barX = 560 - cam;
    if (barX < W && barX + 360 > 0) {
      ctx.fillStyle = "#5a3a22";
      ctx.fillRect(barX, FLOOR - 30, 360, 30);
      ctx.fillStyle = "#6e4828";
      ctx.fillRect(barX, FLOOR - 34, 360, 5);
      // bicchieri sul bancone
      for (let i = 0; i < 5; i++) {
        ctx.fillStyle = "rgba(240,217,138,0.55)";
        ctx.fillRect(barX + 30 + i * 70, FLOOR - 44, 8, 10);
      }
    }

    // lampade a sospensione calde
    for (let i = 0; i < 4; i++) {
      const lx = (i * 200 - (cam * 0.8) % 200) % (W + 200);
      ctx.fillStyle = "#2a1d14";
      ctx.fillRect(lx + 40, 0, 2, 26);
      ctx.fillStyle = "#caa15a";
      ctx.beginPath(); ctx.ellipse(lx + 41, 30, 22, 9, 0, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = "rgba(240,200,120,0.18)";
      ctx.beginPath(); ctx.arc(lx + 41, 36, 30, 0, Math.PI * 2); ctx.fill();
    }
  }

  function drawBackground() {
    if (state.level === 1) drawBgSala();
    else if (state.level === 2) drawBgBar();
    else if (state.level === 3) drawBgCucina();
    else drawBgPalco();

    // pavimento per livello
    const floorColor = state.level === 3 ? C.floorKitchen
      : state.level === 4 ? C.floorStage
      : state.level === 2 ? "#7a5230"
      : C.floor;
    ctx.fillStyle = floorColor;
    ctx.fillRect(0, FLOOR, W, H - FLOOR);
    if (state.level !== 4) {
      ctx.fillStyle = state.level === 3 ? "#6a5048" : state.level === 2 ? "#5e3e22" : C.floorDark;
      const cam = state.camX;
      for (let i = -((cam | 0) % 32); i < W; i += 32) ctx.fillRect(i, FLOOR, 1, H - FLOOR);
    }
    ctx.fillRect(0, FLOOR, W, 2);

    // grana punk
    ctx.fillStyle = "rgba(34,26,18,0.045)";
    for (let i = 0; i < 50; i++) ctx.fillRect((Math.random() * W) | 0, (Math.random() * H) | 0, 2, 2);
    ctx.fillStyle = "rgba(34,26,18,0.035)";
    for (let y = 0; y < H; y += 4) ctx.fillRect(0, y, W, 1);
  }

  function drawPizzaShot(z) {
    const x = z.x - state.camX;
    if (x < -20 || x > W + 20) return;
    ctx.beginPath();
    ctx.fillStyle = C.cheese;
    ctx.arc(x, z.y, z.r, 0, Math.PI * 2); ctx.fill();
    ctx.lineWidth = 2; ctx.strokeStyle = C.crust; ctx.stroke();
    ctx.fillStyle = C.accent;
    ctx.fillRect(x - 3, z.y - 2, 2, 2); ctx.fillRect(x + 1, z.y + 1, 2, 2);
  }

  function drawBubble(e) {
    if (!e.bubble || e.bubbleT <= 0) return;
    const ex = e.x - state.camX;
    ctx.font = '9px "JetBrains Mono", monospace';
    const tw = ctx.measureText(e.bubble).width;
    const bx = Math.max(4, Math.min(W - tw - 14, ex + e.w / 2 - tw / 2 - 5));
    const by = e.y - 22;
    ctx.fillStyle = "#fbf7ee"; ctx.strokeStyle = C.ink; ctx.lineWidth = 1;
    ctx.fillRect(bx, by, tw + 10, 15); ctx.strokeRect(bx, by, tw + 10, 15);
    ctx.fillStyle = C.ink; ctx.fillText(e.bubble, bx + 5, by + 11);
  }

  function drawEnemy(e) {
    const ex = e.x - state.camX;
    if (ex < -e.w - 20 || ex > W + 20) return;
    const blink = e.def.ghost && Math.floor(state.tick / 16) % 3 === 0;
    let alpha = e.def.ghost ? 0.75 : 1;
    if (blink) alpha = 0.3;
    drawSprite(e.sprite, ex, e.y, e.vx > 0, alpha);
    // Giulio: testa = volto reale trattato sopra il corpo pixel
    const isGiulio = e.def.boss && !e.def.teaBoss;
    if (isGiulio && giulioFaceReady) {
      const fw = e.w * 1.15;
      const fx = ex + e.w / 2 - fw / 2;
      const fy = e.y - fw * 0.46; // testa in cima al corpo pixel
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(giulioFace, fx, fy, fw, fw);
      ctx.imageSmoothingEnabled = false;
    }
    if (e.def.boss) {
      const ratio = Math.max(0, e.hp / e.def.hp);
      const bw = Math.max(e.w, 60);
      const bx = ex + e.w / 2 - bw / 2;
      const by = e.y - 18;
      // nome del boss
      ctx.font = 'bold 8px "JetBrains Mono", monospace';
      ctx.textAlign = "center";
      ctx.fillStyle = "#fbf7ee";
      ctx.fillText(e.def.teaBoss ? "TEA" : "GIULIO", ex + e.w / 2, by - 2);
      ctx.textAlign = "left";
      // barra vita
      ctx.fillStyle = "#00000044"; ctx.fillRect(bx, by, bw, 4);
      ctx.fillStyle = e.def.teaBoss ? "#5e8d7a" : (ratio < 0.4 ? "#d23a1a" : C.accent);
      ctx.fillRect(bx, by, bw * ratio, 4);
      ctx.strokeStyle = "#00000055"; ctx.lineWidth = 1; ctx.strokeRect(bx, by, bw, 4);
    }
    drawBubble(e);
  }

  function drawParticles() {
    for (const pt of state.particles) {
      ctx.globalAlpha = Math.max(0, 1 - pt.t / pt.life);
      ctx.fillStyle = pt.color;
      ctx.fillRect(pt.x | 0, pt.y | 0, pt.s, pt.s);
    }
    ctx.globalAlpha = 1;
  }

  function drawPopups() {
    ctx.textAlign = "center";
    for (const pp of state.popups) {
      ctx.globalAlpha = Math.max(0, 1 - pp.t / pp.life);
      ctx.font = 'bold 12px "JetBrains Mono", monospace';
      ctx.fillStyle = "#fbf7ee";
      ctx.fillText(pp.text, pp.x + 1, pp.y + 1);
      ctx.fillStyle = pp.color;
      ctx.fillText(pp.text, pp.x, pp.y);
    }
    ctx.globalAlpha = 1;
    ctx.textAlign = "left";
  }

  function drawComboBadge() {
    if (state.combo < 2) return;
    ctx.save();
    ctx.textAlign = "center";
    const pulse = 1 + Math.sin(state.tick / 4) * 0.06;
    ctx.font = `bold ${Math.round(16 * pulse)}px "JetBrains Mono", monospace`;
    ctx.fillStyle = C.accent;
    ctx.globalAlpha = Math.min(1, state.comboT / 30);
    ctx.fillText("COMBO ×" + state.combo, W / 2, 28);
    ctx.restore();
    ctx.textAlign = "left";
  }

  function render() {
    ctx.save();
    if (state.shake > 0) {
      ctx.translate((Math.random() - 0.5) * state.shake, (Math.random() - 0.5) * state.shake);
    }
    drawBackground();
    const p = state.player;
    for (const e of state.enemies) drawEnemy(e);
    for (const z of state.pizzas) drawPizzaShot(z);
    const flash = p.hurtT > 0 && Math.floor(state.tick / 4) % 2 === 0;
    if (!flash) {
      const px = p.x - state.camX;
      drawSprite(SPRITES.filippo, px, p.y - pSize.h, p.dir < 0, 1);
      // testa = volto reale trattato di Filippo, in cima al corpo pixel
      if (filippoFaceReady) {
        const fw = pSize.w * 1.05;
        ctx.drawImage(filippoFace, px + pSize.w / 2 - fw / 2, p.y - pSize.h - fw * 0.46, fw, fw);
      }
    }
    drawParticles();
    drawPopups();
    ctx.restore();
    drawComboBadge();
  }

  function loop() {
    if (state.running) { update(); render(); }
    else if (!state.levelTransition) render();
    requestAnimationFrame(loop);
  }

  // ── Leaderboard ────────────────────────────────────────────────
  async function loadBoard() {
    try {
      const res = await fetch("/api/non-fa-ridere/scores");
      const data = await res.json();
      renderBoard(data.scores || []);
    } catch { el.boardList.innerHTML = `<li class="nfr-board-loading">—</li>`; }
  }

  function escapeHtml(s) {
    const d = document.createElement("div"); d.textContent = s; return d.innerHTML;
  }

  function renderBoard(scores) {
    if (!scores.length) {
      el.boardList.innerHTML = `<li class="nfr-board-empty">${escapeHtml(emptyMsg)}</li>`;
      return;
    }
    el.boardList.innerHTML = scores.map((s, i) =>
      `<li><span class="nfr-rank">${i + 1}</span><span class="nfr-name">${escapeHtml(s.name)}</span><span class="nfr-pts">${s.score}</span></li>`
    ).join("");
  }

  async function submitScore(name) {
    el.submitBtn.disabled = true;
    el.submitBtn.textContent = submittingMsg;
    try {
      const res = await fetch("/api/non-fa-ridere/scores", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, score: state.score }),
      });
      const data = await res.json();
      renderBoard(data.scores || []);
      el.submitForm.classList.add("nfr-hidden");
      el.submitted.classList.remove("nfr-hidden");
    } catch {
      el.submitBtn.disabled = false;
      el.submitBtn.textContent = submitMsg;
    }
  }

  // ── Input ──────────────────────────────────────────────────────
  function jump() { if (state.player.onGround) state.player.vy = JUMP_V; }

  function maybeStart() {
    if (!state.running && el.overlayEnd.classList.contains("nfr-hidden") && el.overlayLevel.classList.contains("nfr-hidden")) {
      start(); return true;
    }
    return false;
  }

  window.addEventListener("keydown", (ev) => {
    if (ev.target === el.nameInput) return;
    if (ev.key === "ArrowLeft") { state.keys.left = true; ev.preventDefault(); }
    if (ev.key === "ArrowRight") { state.keys.right = true; ev.preventDefault(); }
    if (ev.key === "ArrowUp" || ev.key === "w") { ev.preventDefault(); if (!maybeStart()) jump(); }
    if (ev.key === " " || ev.code === "Space") { ev.preventDefault(); if (!maybeStart()) throwPizza(); }
  });
  window.addEventListener("keyup", (ev) => {
    if (ev.key === "ArrowLeft") state.keys.left = false;
    if (ev.key === "ArrowRight") state.keys.right = false;
  });

  function handleStartTap(ev) {
    if (maybeStart()) ev.preventDefault();
  }
  canvas.addEventListener("pointerdown", handleStartTap);
  // L'overlay di start copre il canvas (z-index 2): su mobile il tap arriva
  // qui, quindi deve avviare il gioco direttamente.
  el.overlayStart.addEventListener("pointerdown", handleStartTap);

  function bindHold(id, down, up) {
    const btn = document.getElementById(id);
    btn.addEventListener("pointerdown", (ev) => {
      ev.preventDefault();
      // tieni l'evento agganciato al bottone anche se il dito scivola fuori
      if (btn.setPointerCapture) {
        try { btn.setPointerCapture(ev.pointerId); } catch (_) {}
      }
      maybeStart();
      down();
    });
    btn.addEventListener("pointerup", () => up && up());
    btn.addEventListener("pointercancel", () => up && up());
  }
  bindHold("nfr-t-left", () => (state.keys.left = true), () => (state.keys.left = false));
  bindHold("nfr-t-right", () => (state.keys.right = true), () => (state.keys.right = false));
  bindHold("nfr-t-jump", jump);
  bindHold("nfr-t-throw", throwPizza);

  el.nextLevelBtn.addEventListener("click", () => {
    const nextLvl = state.level + 1;
    el.overlayLevel.classList.add("nfr-hidden");
    resetLevel(nextLvl);
    state.running = true;
  });

  el.submitForm.addEventListener("submit", (ev) => { ev.preventDefault(); submitScore(el.nameInput.value); });
  el.restart.addEventListener("click", start);

  loadBoard();
  requestAnimationFrame(loop);
  render();
</script>

<style>
  .nfr-game {
    display: block;
    margin: 2rem 0;
  }
  .nfr-main {
    width: 100%;
  }

  .nfr-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 640 / 360;
    border: 1px solid var(--foglio-rule-strong);
    border-radius: var(--foglio-radius-md);
    overflow: hidden;
    box-shadow: var(--foglio-shadow);
    background: #221a12;
  }
  .nfr-stage:fullscreen,
  .nfr-stage:-webkit-full-screen {
    border: none;
    border-radius: 0;
    aspect-ratio: auto;
  }

  /* Fallback fullscreen per iOS (requestFullscreen bloccato): lo stage
     copre l'intero viewport. */
  .nfr-stage.nfr-fs-fallback {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    max-height: none;
    aspect-ratio: auto;
    border: none;
    border-radius: 0;
    z-index: 9999;
  }

  /* In fullscreen su mobile (portrait): il canvas 16:9 sta tutto in vista,
     centrato verticalmente, così Filippo e il pavimento sono sempre
     visibili e l'azione resta al centro dello schermo. */
  .nfr-stage:fullscreen #nfr-canvas,
  .nfr-stage:-webkit-full-screen #nfr-canvas,
  .nfr-stage.nfr-fs-fallback #nfr-canvas {
    object-fit: contain;
    object-position: center center;
  }

  #nfr-canvas {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    touch-action: none;
    image-rendering: pixelated;
  }

  .nfr-hud {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0.8rem;
    font-family: var(--foglio-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #5e4d3a;
    pointer-events: none;
  }
  .nfr-hud b { color: var(--foglio-accent); }
  .nfr-hud-level {
    font-size: 0.65rem;
    opacity: 0.8;
  }

  .nfr-sysbtns {
    position: absolute;
    top: 1.9rem;
    right: 0.6rem;
    display: flex;
    gap: 0.4rem;
  }
  .nfr-sysbtn {
    width: 34px; height: 34px;
    font-family: var(--foglio-mono);
    font-size: 0.9rem;
    border: 1px solid rgba(34, 26, 18, 0.3);
    border-radius: var(--foglio-radius-sm);
    background: rgba(251, 247, 238, 0.7);
    color: #221a12;
    cursor: pointer;
  }
  .nfr-sysbtn-off { opacity: 0.5; text-decoration: line-through; }

  .nfr-overlay {
