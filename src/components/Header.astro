---
import { Image } from "astro:assets";
import HeaderLink from "~/components/HeaderLink.astro";
import "~/components/Header.css";

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en');
const otherLang = isEn ? 'IT' : 'EN';

// Bidirectional map for routes whose IT and EN slugs differ.
// New entries are auto-mirrored: writing the IT→EN entry is enough.
const baseRouteMap: Record<string, string> = {
  '/contatti': '/en/contact',
  '/blog/dalla-meditazione-alla-programmazione-funzionale': '/en/blog/from-meditation-to-functional-programming',
  '/tag/meditazione': '/en/tag/meditation',
  '/tag/programmazione-funzionale': '/en/tag/functional-programming',
};

const routeMap: Record<string, string> = { ...baseRouteMap };
for (const [from, to] of Object.entries(baseRouteMap)) {
  routeMap[to] = from;
}

function getLangSwitchHref(path: string): string {
  const normalized = path.replace(/\/$/, '') || '/';
  if (routeMap[normalized]) return routeMap[normalized] + '/';
  // Prefix match for paginated routes (e.g. /tag/meditazione/2)
  for (const key of Object.keys(routeMap)) {
    if (normalized.startsWith(key + '/')) {
      const suffix = normalized.slice(key.length);
      return routeMap[key] + suffix + '/';
    }
  }
  if (isEn) return (normalized.replace(/^\/en/, '') || '/');
  return `/en${normalized}`;
}

const langSwitchHref = getLangSwitchHref(currentPath);
---

<header class="Header">
  <div class="logo-container">
    <HeaderLink href="/" class="logo">
      <Image src="/img/me.jpg" alt="Logo Valerio Narcisi" width={32} height={32} loading="eager" />
      <div>Valerio Narcisi</div>
    </HeaderLink>
  </div>
  <div class="header-controls">
    <div class="menu-toggle">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
  <nav>
    <HeaderLink href={isEn ? "/en" : "/"}>Home</HeaderLink>
    <HeaderLink href={isEn ? "/en/blog" : "/blog"}>Blog</HeaderLink>
    <HeaderLink href={isEn ? "/en/films" : "/films"}>{isEn ? "Films" : "Film"}</HeaderLink>
    <HeaderLink href={isEn ? "/en/who-i-am" : "/who-i-am"}>{isEn ? "Who I Am" : "Chi Sono"}</HeaderLink>
    <HeaderLink href={isEn ? "/en/contact" : "/contatti"}>{isEn ? "Contact" : "Contatti"}</HeaderLink>
    <a href={langSwitchHref} class="lang-switch">{otherLang}</a>
  </nav>
</header>

<script>
  const menuToggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector("nav");
  const heroPill = document.querySelector(".hero-mobile-pill");

  function openMenu() {
    menuToggle?.classList.add("active");
    nav?.classList.add("active");
    heroPill?.classList.add("hidden");
  }

  function closeMenu() {
    menuToggle?.classList.remove("active");
    nav?.classList.remove("active");
    heroPill?.classList.remove("hidden");
  }

  menuToggle?.addEventListener("click", () => {
    nav?.classList.contains("active") ? closeMenu() : openMenu();
  });

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  document.addEventListener("click", (e) => {
    if (
      nav?.classList.contains("active") &&
      !nav.contains(e.target as Node) &&
      !menuToggle?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menuToggle?.classList.remove("active");
      nav?.classList.remove("active");
    });
  });
</script>
