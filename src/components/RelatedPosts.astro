---
import { getCollection } from "astro:content";
import { getSlugFromId, getLangFromId } from "~/i18n/utils";

interface Props {
  currentSlug: string;
  currentTags: string[];
  maxPosts?: number;
  lang?: string;
}

const { currentSlug, currentTags, maxPosts = 6, lang = "it" } = Astro.props;

const isEn = lang === "en";

function formatDate(d: string) {
  return new Date(d).toLocaleDateString(isEn ? "en-GB" : "it-IT", { day: "numeric", month: "short", year: "numeric" });
}

function calculateSimilarity(postTags: string[], currentTags: string[]): number {
  const commonTags = postTags.filter(tag => currentTags.includes(tag));
  return commonTags.length;
}

const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter(post => getLangFromId(post.id) === lang)
  .filter(post => getSlugFromId(post.id) !== currentSlug)
  .map(post => ({
    ...post.data,
    slug: getSlugFromId(post.id),
    coverImage: post.data.coverImage,
    similarity: calculateSimilarity(post.data.tags || [], currentTags),
  }))
  .filter(post => post.similarity > 0)
  .sort((a, b) => {
    if (b.similarity !== a.similarity) return b.similarity - a.similarity;
    return new Date(b.date).getTime() - new Date(a.date).getTime();
  })
  .slice(0, maxPosts);
---

{relatedPosts.length > 0 && (
  <section class="rp-section">
    <h2 class="rp-title">{isEn ? "Related articles." : "Articoli correlati."}</h2>
    <div class="rp-grid">
      {relatedPosts.map((post) => (
        <a href={isEn ? `/en/blog/${post.slug}/` : `/blog/${post.slug}/`} class="rp-card">
          {post.coverImage && (
            <div class="rp-card-img" style={`background-image: url('${post.coverImage}')`} />
          )}
          {!post.coverImage && <div class="rp-card-img rp-card-img--empty" />}
          <div class="rp-card-body">
            <div class="rp-card-meta">
              <span class="rp-card-date">{formatDate(post.date)}</span>
              {post.tags?.[0] && <span class="rp-card-tag">{post.tags[0]}</span>}
            </div>
            <h3 class="rp-card-title">{post.title}</h3>
            {post.extract && <p class="rp-card-extract">{post.extract}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .rp-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 3rem 6rem;
    border-top: 1px solid var(--foglio-rule);
  }
  .rp-title {
    font-family: var(--foglio-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.5rem;
    color: var(--foglio-ink);
    margin: 0 0 2.5rem;
  }
  .rp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .rp-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--foglio-rule);
    border-radius: var(--foglio-radius-md);
    overflow: hidden;
    background: var(--foglio-paper);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .rp-card:hover {
    box-shadow: var(--foglio-shadow);
    transform: translateY(-2px);
  }
  .rp-card-img {
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--foglio-paper-2);
  }
  .rp-card-img--empty {
    background: var(--foglio-paper-2);
  }
  .rp-card-body {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .rp-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--foglio-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--foglio-ink-mute);
  }
  .rp-card-tag {
    color: var(--foglio-accent);
  }
  .rp-card-title {
    font-family: var(--foglio-serif);
    font-weight: 500;
    font-size: 1.1rem;
    line-height: 1.3;
    color: var(--foglio-ink);
    margin: 0;
  }
  .rp-card:hover .rp-card-title {
    color: var(--foglio-accent);
  }
  .rp-card-extract {
    font-family: var(--foglio-serif);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--foglio-ink-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .rp-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .rp-section { padding: 3rem 1.4rem 4rem; }
    .rp-grid { grid-template-columns: 1fr; }
  }
</style>
