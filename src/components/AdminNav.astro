---
import "./AdminNav.css";

interface Props {
  currentPage: "analytics" | "comments" | "meal-plan" | "grocery" | "body-comp" | "meditation";
  token: string;
}

const { currentPage, token } = Astro.props;

const links = [
  { id: "analytics" as const, label: "Analytics", href: `/admin/analytics?token=${token}` },
  { id: "comments" as const, label: "Comments", href: `/admin/comments?token=${token}` },
  { id: "meal-plan" as const, label: "Meal Plan", href: `/admin/meal-plan?token=${token}` },
  { id: "grocery" as const, label: "Spesa", href: `/admin/grocery?token=${token}` },
  { id: "body-comp" as const, label: "Body Comp", href: `/admin/body-comp?token=${token}` },
  { id: "meditation" as const, label: "Medita", href: `/admin/meditation?token=${token}` },
] as const;
---

<nav class="admin-nav">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={["admin-nav-link", { active: currentPage === link.id }]}
    >
      {link.label}
    </a>
  ))}
</nav>
