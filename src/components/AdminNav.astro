---
import "./AdminNav.css";

interface Props {
  currentPage: "analytics" | "comments" | "meal-plan" | "grocery" | "body-comp" | "meditation" | "recipes" | "training" | "workout";
  token: string;
}

const { currentPage, token } = Astro.props;

const topLinks = [
  { id: "analytics" as const, label: "Analytics", short: "Stats", href: `/admin/analytics?token=${token}` },
  { id: "comments" as const, label: "Comments", short: "Msg", href: `/admin/comments?token=${token}` },
];

const dietaLinks = [
  { id: "meal-plan" as const, label: "Meal Plan", short: "Menu", href: `/admin/meal-plan?token=${token}` },
  { id: "body-comp" as const, label: "Body Comp", short: "Body", href: `/admin/body-comp?token=${token}` },
  { id: "grocery" as const, label: "Spesa", short: "Spesa", href: `/admin/grocery?token=${token}` },
  { id: "recipes" as const, label: "Ricette", short: "Chef", href: `/admin/recipes?token=${token}` },
];

const bottomLinks = [
  { id: "meditation" as const, label: "Medita", short: "Zen", href: `/admin/meditation?token=${token}` },
  { id: "training" as const, label: "Training", short: "Run", href: `/admin/training?token=${token}` },
  { id: "workout" as const, label: "Workout Casa", short: "Casa", href: `/admin/workout?token=${token}` },
];

const allLinks = [...topLinks, ...dietaLinks, ...bottomLinks];
---

<!-- Hamburger button (mobile only) -->
<button class="admin-hamburger" id="admin-hamburger" aria-label="Menu">
  <span></span>
  <span></span>
  <span></span>
</button>

<!-- Backdrop -->
<div class="admin-backdrop" id="admin-backdrop"></div>

<aside class="admin-sidebar" id="admin-sidebar">
  <div class="sidebar-section">
    {topLinks.map((link) => (
      <a
        href={link.href}
        class:list={["sidebar-link", { active: currentPage === link.id }]}
      >
        <span class="sidebar-label-full">{link.label}</span>
        <span class="sidebar-label-short">{link.short}</span>
      </a>
    ))}
  </div>

  <div class="sidebar-section">
    <div class="sidebar-group-title">Dieta</div>
    {dietaLinks.map((link) => (
      <a
        href={link.href}
        class:list={["sidebar-link", "sidebar-link-sub", { active: currentPage === link.id }]}
      >
        <span class="sidebar-label-full">{link.label}</span>
        <span class="sidebar-label-short">{link.short}</span>
      </a>
    ))}
  </div>

  <div class="sidebar-section">
    {bottomLinks.map((link) => (
      <a
        href={link.href}
        class:list={["sidebar-link", { active: currentPage === link.id }]}
      >
        <span class="sidebar-label-full">{link.label}</span>
        <span class="sidebar-label-short">{link.short}</span>
      </a>
    ))}
  </div>
</aside>

<script>
  const btn = document.getElementById('admin-hamburger');
  const sidebar = document.getElementById('admin-sidebar');
  const backdrop = document.getElementById('admin-backdrop');

  function openMenu() {
    sidebar?.classList.add('open');
    btn?.classList.add('open');
    backdrop?.classList.add('visible');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    sidebar?.classList.remove('open');
    btn?.classList.remove('open');
    backdrop?.classList.remove('visible');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    sidebar?.classList.contains('open') ? closeMenu() : openMenu();
  });
  backdrop?.addEventListener('click', closeMenu);

  // Close on link tap (mobile navigation)
  sidebar?.querySelectorAll('.sidebar-link').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 768) closeMenu();
    });
  });
</script>
