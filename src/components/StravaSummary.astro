---
import "~/components/StravaSummary.css";
import {
  formatDistance,
  formatDuration,
  formatPaceFromSecondsPerKm,
} from "~/services/strava";
import type { PeriodStats } from "~/services/strava";

interface Props {
  stats: PeriodStats;
  weekLabel?: string;
  monthLabel?: string;
}

const {
  stats,
  weekLabel = "7d",
  monthLabel = "30d",
} = Astro.props;

const fmt = (s: typeof stats.weekly) => ({
  distance: formatDistance(s.totalDistance),
  duration: formatDuration(s.totalMovingTime),
  pace: formatPaceFromSecondsPerKm(s.averagePace),
  elevation: s.totalElevation > 0 ? `↑${Math.round(s.totalElevation)}m` : "",
  count: s.totalActivities,
});

const w = fmt(stats.weekly);
const m = fmt(stats.monthly);
---

<div class="StravaSummary">
  <div class="summary-row">
    <span class="summary-badge">{weekLabel}</span>
    <span class="summary-km">{w.distance}</span>
    <span class="summary-sep">·</span>
    <span class="summary-meta">{w.count} att.</span>
    {w.pace && (
      <>
        <span class="summary-sep">·</span>
        <span class="summary-pace">{w.pace}</span>
      </>
    )}
    {w.elevation && (
      <>
        <span class="summary-sep">·</span>
        <span class="summary-meta">{w.elevation}</span>
      </>
    )}
  </div>
  <div class="summary-row">
    <span class="summary-badge">{monthLabel}</span>
    <span class="summary-km">{m.distance}</span>
    <span class="summary-sep">·</span>
    <span class="summary-meta">{m.count} att.</span>
    {m.pace && (
      <>
        <span class="summary-sep">·</span>
        <span class="summary-pace">{m.pace}</span>
      </>
    )}
    {m.elevation && (
      <>
        <span class="summary-sep">·</span>
        <span class="summary-meta">{m.elevation}</span>
      </>
    )}
  </div>
</div>
