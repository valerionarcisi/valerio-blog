---
import { Icon } from "astro-icon/components";
import "./Comments.css";

interface Props {
  pageId: string;
  lang: "it" | "en";
}

const { pageId, lang } = Astro.props;

const HEART_OUTLINE_SVG =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" width="14" height="14" aria-hidden="true"><path d="M21 8.25c0-2.485-2.099-4.5-4.687-4.5c-1.936 0-3.598 1.126-4.313 2.733c-.715-1.607-2.377-2.733-4.312-2.733C5.098 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12"/></svg>';
const HEART_SOLID_SVG =
  '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="m11.645 20.91l-.007-.003l-.022-.012l-.082-.045q-.108-.06-.301-.173a25.2 25.2 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25C2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052A5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25c0 3.925-2.438 7.111-4.739 9.256a25 25 0 0 1-4.244 3.17a15 15 0 0 1-.383.219l-.022.012l-.007.004l-.003.001a.75.75 0 0 1-.704 0z"/></svg>';

const labels = {
  it: {
    title: "Commenti",
    name: "Nome",
    email: "Email",
    text: "Commento",
    submit: "Invia commento",
    submitReply: "Invia risposta",
    cancel: "Annulla",
    reply: "Rispondi",
    like: "Mi piace",
    success: "Commento inviato! Sarà visibile dopo la moderazione.",
    error: "Errore nell'invio del commento. Riprova.",
    loading: "Caricamento commenti...",
    empty: "Nessun commento ancora. Sii il primo!",
    on: "il",
  },
  en: {
    title: "Comments",
    name: "Name",
    email: "Email",
    text: "Comment",
    submit: "Submit comment",
    submitReply: "Submit reply",
    cancel: "Cancel",
    reply: "Reply",
    like: "Like",
    success: "Comment submitted! It will be visible after moderation.",
    error: "Error submitting comment. Please try again.",
    loading: "Loading comments...",
    empty: "No comments yet. Be the first!",
    on: "on",
  },
};

const t = labels[lang];
---

<section class="Comments" data-page-id={pageId} data-lang={lang}>
  <h2>{t.title}</h2>

  <div class="Comments-list" aria-live="polite">
    <p class="Comments-loading">{t.loading}</p>
  </div>

  <form class="Comments-form Comments-form--root">
    <p class="Comments-author-indicator" hidden></p>
    <div class="Comments-field Comments-field--public">
      <label for="comment-name">{t.name} *</label>
      <input type="text" id="comment-name" name="name" maxlength="100" />
    </div>
    <div class="Comments-field Comments-field--public">
      <label for="comment-email">{t.email} *</label>
      <input type="email" id="comment-email" name="email" maxlength="254" />
    </div>
    <div class="Comments-hp Comments-field--public" aria-hidden="true">
      <label for="comment-website">Website</label>
      <input type="text" id="comment-website" name="website" tabindex="-1" autocomplete="off" />
    </div>
    <div class="Comments-field">
      <label for="comment-text">{t.text} *</label>
      <textarea id="comment-text" name="text" required maxlength="5000" rows="4"></textarea>
    </div>
    <button type="submit" class="Button">{t.submit}</button>
    <p class="Comments-message" role="status"></p>
  </form>
</section>

<script is:inline define:vars={{ initialPageId: pageId, initialLang: lang, HEART_OUTLINE_SVG, HEART_SOLID_SVG }}>
  (function () {
    var section = document.querySelector(".Comments");
    if (!section) return;

    var pageId = initialPageId;
    var lang = initialLang;
    var listEl = section.querySelector(".Comments-list");
    var rootForm = section.querySelector(".Comments-form--root");
    var rootMessage = rootForm.querySelector(".Comments-message");

    var labels = {
      it: {
        empty: "Nessun commento ancora. Sii il primo!",
        on: "il",
        success: "Commento inviato! Sarà visibile dopo la moderazione.",
        error: "Errore nell'invio del commento. Riprova.",
        reply: "Rispondi",
        cancel: "Annulla",
        like: "Mi piace",
        submitReply: "Invia risposta",
        name: "Nome",
        email: "Email",
        text: "Commento",
      },
      en: {
        empty: "No comments yet. Be the first!",
        on: "on",
        success: "Comment submitted! It will be visible after moderation.",
        error: "Error submitting comment. Please try again.",
        reply: "Reply",
        cancel: "Cancel",
        like: "Like",
        submitReply: "Submit reply",
        name: "Name",
        email: "Email",
        text: "Comment",
      },
    };
    var t = labels[lang] || labels.en;
    var MAX_DEPTH = 4;
    var authorToken = null;
    try { authorToken = localStorage.getItem("vbAdminToken"); } catch (e) {}
    var isAuthor = !!authorToken;
    var AUTHOR_LABEL_IT = "Stai rispondendo come Valerio · Author";
    var AUTHOR_LABEL_EN = "Posting as Valerio · Author";

    function applyAuthorMode(form) {
      if (!isAuthor) return;
      var indicator = form.querySelector(".Comments-author-indicator");
      if (indicator) {
        indicator.hidden = false;
        indicator.textContent = lang === "it" ? AUTHOR_LABEL_IT : AUTHOR_LABEL_EN;
      }
      form.querySelectorAll(".Comments-field--public").forEach(function (el) {
        el.style.display = "none";
        el.querySelectorAll("input").forEach(function (i) { i.required = false; });
      });
    }

    function escapeHtml(str) {
      var div = document.createElement("div");
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    function buildTree(rows) {
      var byId = {};
      var roots = [];
      rows.forEach(function (r) {
        r.children = [];
        byId[r.id] = r;
      });
      rows.forEach(function (r) {
        if (r.parent_id != null && byId[r.parent_id]) {
          byId[r.parent_id].children.push(r);
        } else {
          roots.push(r);
        }
      });
      return roots;
    }

    function renderComment(c, depth) {
      var d = new Date(c.created_at).toLocaleDateString(
        lang === "it" ? "it-IT" : "en-US"
      );
      var liked = c.liked_by_me ? "is-active" : "";
      var pressed = c.liked_by_me ? "true" : "false";
      var visualDepth = depth > MAX_DEPTH ? MAX_DEPTH : depth;
      var authorBadge = c.is_author
        ? ' <span class="Comments-author-badge">Author</span>'
        : "";
      var html =
        '<div class="Comments-item" data-id="' +
        c.id +
        '" data-depth="' +
        visualDepth +
        '">' +
        '<div class="Comments-meta"><strong>' +
        escapeHtml(c.name) +
        "</strong>" +
        authorBadge +
        " " +
        '<span class="Comments-date">' +
        t.on +
        " " +
        d +
        "</span></div>" +
        '<p class="Comments-text">' +
        escapeHtml(c.text) +
        "</p>" +
        '<div class="Comments-actions">' +
        '<button type="button" class="Comments-like ' +
        liked +
        '" aria-pressed="' +
        pressed +
        '" data-id="' +
        c.id +
        '">' +
        '<span class="Comments-like-icon" aria-hidden="true">' +
        (c.liked_by_me ? HEART_SOLID_SVG : HEART_OUTLINE_SVG) +
        '</span> ' +
        '<span class="Comments-like-count">' +
        Number(c.likes_count || 0) +
        "</span>" +
        "</button>" +
        '<button type="button" class="Comments-reply-btn" data-id="' +
        c.id +
        '">' +
        t.reply +
        "</button>" +
        "</div>" +
        '<div class="Comments-reply-slot"></div>';
      if (c.children && c.children.length) {
        html += '<div class="Comments-children">';
        c.children.forEach(function (child) {
          html += renderComment(child, depth + 1);
        });
        html += "</div>";
      }
      html += "</div>";
      return html;
    }

    function loadComments() {
      fetch("/api/comments?pageId=" + encodeURIComponent(pageId))
        .then(function (r) {
          return r.json();
        })
        .then(function (rows) {
          if (!rows.length) {
            listEl.innerHTML =
              '<p class="Comments-empty">' + t.empty + "</p>";
            return;
          }
          var tree = buildTree(rows);
          listEl.innerHTML = tree
            .map(function (c) {
              return renderComment(c, 0);
            })
            .join("");
          attachHandlers();
        })
        .catch(function () {
          listEl.innerHTML =
            '<p class="Comments-empty">' + t.empty + "</p>";
        });
    }

    function attachHandlers() {
      listEl.querySelectorAll(".Comments-like").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var id = Number(btn.dataset.id);
          btn.disabled = true;
          fetch("/api/comments/like", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ commentId: id }),
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (data) {
              if (typeof data.count === "number") {
                btn.querySelector(".Comments-like-count").textContent =
                  data.count;
                btn.classList.toggle("is-active", !!data.liked);
                btn.setAttribute("aria-pressed", data.liked ? "true" : "false");
                var iconWrap = btn.querySelector(".Comments-like-icon");
                if (iconWrap)
                  iconWrap.innerHTML = data.liked
                    ? HEART_SOLID_SVG
                    : HEART_OUTLINE_SVG;
              }
            })
            .catch(function () {})
            .then(function () {
              btn.disabled = false;
            });
        });
      });

      listEl.querySelectorAll(".Comments-reply-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var id = Number(btn.dataset.id);
          var item = btn.closest(".Comments-item");
          var slot = item.querySelector(":scope > .Comments-reply-slot");
          if (slot.querySelector("form")) {
            slot.innerHTML = "";
            return;
          }
          slot.innerHTML = buildReplyForm(id);
          var form = slot.querySelector("form");
          applyAuthorMode(form);
          form.addEventListener("submit", function (e) {
            handleSubmit(e, form, id);
          });
          form.querySelector(".Comments-cancel").addEventListener("click", function () {
            slot.innerHTML = "";
          });
        });
      });
    }

    function buildReplyForm(parentId) {
      return (
        '<form class="Comments-form Comments-form--reply" data-parent="' +
        parentId +
        '">' +
        '<p class="Comments-author-indicator" hidden></p>' +
        '<div class="Comments-field Comments-field--public"><label>' +
        t.name +
        ' *</label><input type="text" name="name" maxlength="100" /></div>' +
        '<div class="Comments-field Comments-field--public"><label>' +
        t.email +
        ' *</label><input type="email" name="email" maxlength="254" /></div>' +
        '<div class="Comments-hp Comments-field--public" aria-hidden="true"><label>Website</label><input type="text" name="website" tabindex="-1" autocomplete="off" /></div>' +
        '<div class="Comments-field"><label>' +
        t.text +
        ' *</label><textarea name="text" required maxlength="5000" rows="3"></textarea></div>' +
        '<div class="Comments-form-actions">' +
        '<button type="submit" class="Button">' +
        t.submitReply +
        "</button>" +
        '<button type="button" class="Comments-cancel">' +
        t.cancel +
        "</button>" +
        "</div>" +
        '<p class="Comments-message" role="status"></p>' +
        "</form>"
      );
    }

    function handleSubmit(e, form, parentId) {
      e.preventDefault();
      var messageEl = form.querySelector(".Comments-message");
      var textEl = form.querySelector('[name="text"]');
      var data = {
        pageId: pageId,
        lang: lang,
        text: textEl ? textEl.value : "",
      };
      if (!isAuthor) {
        data.name = form.querySelector('[name="name"]').value;
        data.email = form.querySelector('[name="email"]').value;
        data.website = form.querySelector('[name="website"]').value;
      }
      if (parentId != null) data.parentId = parentId;
      messageEl.textContent = "";
      messageEl.className = "Comments-message";

      var headers = { "Content-Type": "application/json" };
      if (isAuthor) headers["Authorization"] = "Bearer " + authorToken;

      fetch("/api/comments", {
        method: "POST",
        headers: headers,
        body: JSON.stringify(data),
      })
        .then(function (r) {
          if (!r.ok) throw new Error();
          if (isAuthor) {
            form.reset();
            var slot = form.parentElement && form.parentElement.classList.contains("Comments-reply-slot")
              ? form.parentElement
              : null;
            if (slot) slot.innerHTML = "";
            loadComments();
          } else {
            messageEl.textContent = t.success;
            messageEl.classList.add("Comments-message--success");
            form.reset();
          }
        })
        .catch(function () {
          messageEl.textContent = t.error;
          messageEl.classList.add("Comments-message--error");
        });
    }

    applyAuthorMode(rootForm);
    rootForm.addEventListener("submit", function (e) {
      handleSubmit(e, rootForm, null);
    });

    loadComments();
  })();
</script>
