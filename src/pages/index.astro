---
import BaseHead from "~/components/BaseHead.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import StructuredData from "~/components/StructuredData.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "~/consts";
import Hero from "~/components/Hero.astro";
import Title from "~/components/Title.astro";
import Card from "~/components/Card.astro";
import { getLetterboxdRss, parseXmlContent } from "~/services/letterboxd";
import { getMovieById } from "~/services/tmdb";
import Reel from "~/components/Reel.astro";
import "./index.css";
import { fetchRecentTracks } from "~/services/audioscrobbler";
import { fetchRecentActivities, fetchActivityStats } from "~/services/strava";
import ActivityCard from "~/components/ActivityCard.astro";
import StravaSummary from "~/components/StravaSummary.astro";
import { getCollection } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";

const lastWatchedMovies = async () => {
  const xml = await getLetterboxdRss();
  const parsedXml = (await parseXmlContent(await xml.text())) as any;

  const moviePromises = parsedXml.rss.channel[0].item
    .filter((item: any) => item?.["tmdb:movieId"]?.[0])
    .map(async (item: any) => {
      try {
        const movie = await getMovieById(item["tmdb:movieId"][0]);
        return { ...movie, ...item };
      } catch (error) {
        console.error(
          `Failed to fetch movie with ID ${item["tmdb:movieId"][0]}`,
          error
        );
        return null;
      }
    });

  const watchedMovies = await Promise.all(moviePromises);
  return watchedMovies.filter(Boolean);
};

const allEntries = await getCollection("blog");
const posts = allEntries
  .filter((e) => getLangFromId(e.id) === "it")
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6)
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));

const [lastWatched, lastSongs, lastActivities, activityStats] = await Promise.all([
  lastWatchedMovies(),
  fetchRecentTracks(),
  fetchRecentActivities(5).catch(() => []),
  fetchActivityStats().catch(() => null),
]);
---

<!doctype html>
<html lang="it">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <StructuredData
      type="website"
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      url={Astro.url.href}
      image="/img/avatar.png"
    />
  </head>
  <body>
    <Header />
    <Hero
      title="Ciao, sono Valerio"
      role="developer.filmmaker"
      subtitle="I solve problems. I tell stories."
      aiTagline="AI-assisted, human-driven"
      callToActions={[
        {
          label: "Connettiti con me",
          href: "http://linkedin.com/in/cv-valerio-narcisi",
        },
        {
          label: "Guarda il Trailer di Caramella",
          href: "https://www.youtube.com/watch?v=UnQ8NSXYXao",
        },
      ]}
    />
    <main>
      <section id="last-watched">
        <Title title="Ultimi film visti" />
        <div class="ReelContainer" id="movies-reel">
          {
            lastWatched.map((movie: any) => (
              <Reel
                type="movie"
                vote_average={movie.vote_average}
                vote_count={movie.vote_count}
                url={`https://image.tmdb.org/t/p/w185/${movie.poster_path}`}
                href={movie.link[0]}
                title={movie["letterboxd:filmTitle"][0]}
                watchedDate={movie["letterboxd:watchedDate"][0]}
              />
            ))
          }
        </div>
      </section>
      <section>
        <Title title="Ultimi brani ascoltati" />
        <div class="ReelContainer" id="songs-reel">
          {
            lastSongs.map((song) => (
              <Reel
                type="song"
                artist={song.artist["#text"]}
                album={song.album["#text"]}
                url={song.image[3]["#text"]}
                href={song.url}
                title={song.name}
                watchedDate={
                  song?.date
                    ? song.date["#text"]
                    : new Date().toLocaleDateString("it-IT", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })
                }
              />
            ))
          }
        </div>
      </section>
      <section id="strava-section" style={lastActivities.length === 0 ? "display:none" : ""}>
        <Title title="Ultime attività sportive" />
        <div id="strava-summary">
          {activityStats && (
            <StravaSummary stats={activityStats} />
          )}
        </div>
        <div class="ReelContainer" id="strava-reel">
          {lastActivities.map((activity) => (
            <ActivityCard activity={activity} />
          ))}
        </div>
      </section>
      <section>
        <Title title="Ultimi articoli" />
        <div class="cards-grid">
          {
            posts?.map((post) => (
              <Card
                date={post.date}
                title={post.title}
                extract={post.extract}
                slug={post.slug}
                coverImage={post.coverImage}
                tags={post.tags}
                lang="it"
              />
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var REFRESH_MS = 15 * 60 * 1000;
        var MOVIE_PLACEHOLDER = "https://placeholder.pics/svg/178x278/1a1b26/8a8a8e/No%20Poster";
        var SONG_PLACEHOLDER = "https://placeholder.pics/svg/185x185/1a1b26/8a8a8e/No%20Cover";

        function fmtDate(dateStr) {
          if (!dateStr) return "";
          var d = new Date(dateStr);
          return d.toLocaleDateString("en-us", { month: "short", day: "numeric" });
        }

        function renderMovie(m) {
          var img = m.posterPath
            ? "https://image.tmdb.org/t/p/w185" + m.posterPath
            : MOVIE_PLACEHOLDER;
          var vote = m.voteAverage
            ? '<span class="vote">' + m.voteAverage.toFixed(1) + "</span>"
            : "";
          return '<div class="Reel movie">'
            + '<a href="' + m.link + '" target="_blank" rel="noopener noreferrer">'
            + '<div class="thumbnail"><img src="' + img + '" alt="' + m.title + '" loading="lazy" />' + vote + "</div>"
            + "</a>"
            + '<div class="info"><h3 class="reel-title">' + m.title + "</h3>"
            + '<p class="reel-date">' + fmtDate(m.watchedDate) + "</p></div></div>";
        }

        function renderSong(s) {
          var img = s.image || SONG_PLACEHOLDER;
          var date = s.date ? fmtDate(s.date) : fmtDate(new Date().toISOString());
          return '<div class="Reel song">'
            + '<a href="' + s.url + '" target="_blank" rel="noopener noreferrer">'
            + '<div class="thumbnail"><img src="' + img + '" alt="' + s.name + '" loading="lazy" /></div>'
            + "</a>"
            + '<div class="info"><h3 class="reel-title">' + s.name + "</h3>"
            + '<p class="reel-artist">' + s.artist + "</p>"
            + '<p class="reel-album">' + s.album + "</p>"
            + '<p class="reel-date">' + date + "</p></div></div>";
        }

        function renderActivity(a) {
          var stats = "";
          if (a.hasDistance) stats += '<span class="stat">' + a.formattedDistance + "</span>";
          stats += '<span class="stat">' + a.formattedDuration + "</span>";
          if (a.formattedPace) stats += '<span class="stat pace">' + a.formattedPace + "</span>";
          if (a.formattedElevation) stats += '<span class="stat">' + a.formattedElevation + "</span>";
          return '<a class="ActivityCard" href="' + a.url + '" target="_blank" rel="noopener noreferrer">'
            + '<div class="activity-type">'
            + '<span class="activity-dot" style="background:' + a.color + '"></span>'
            + '<span class="activity-label">' + a.label + "</span></div>"
            + '<h3 class="activity-name">' + a.name + "</h3>"
            + '<div class="activity-stats">' + stats + "</div>"
            + '<span class="activity-date">' + a.formattedDate + "</span></a>";
        }

        function renderSummaryRow(s, badge) {
          var html = '<div class="summary-row">'
            + '<span class="summary-badge">' + badge + "</span>"
            + '<span class="summary-km">' + s.distance + "</span>"
            + '<span class="summary-sep">·</span>'
            + '<span class="summary-meta">' + s.count + " att.</span>";
          if (s.pace) html += '<span class="summary-sep">·</span><span class="summary-pace">' + s.pace + "</span>";
          if (s.elevation) html += '<span class="summary-sep">·</span><span class="summary-meta">' + s.elevation + "</span>";
          html += "</div>";
          return html;
        }

        function refresh() {
          fetch("/api/letterboxd")
            .then(function (r) { return r.json(); })
            .then(function (movies) {
              var el = document.getElementById("movies-reel");
              if (el && Array.isArray(movies)) el.innerHTML = movies.map(renderMovie).join("");
            })
            .catch(function () {});

          fetch("/api/lastfm")
            .then(function (r) { return r.json(); })
            .then(function (songs) {
              var el = document.getElementById("songs-reel");
              if (el && Array.isArray(songs)) el.innerHTML = songs.map(renderSong).join("");
            })
            .catch(function () {});

          fetch("/api/strava")
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data.error) return;
              var section = document.getElementById("strava-section");
              var reel = document.getElementById("strava-reel");
              var summary = document.getElementById("strava-summary");
              if (section && data.activities && data.activities.length > 0) {
                section.style.display = "";
                if (reel) reel.innerHTML = data.activities.map(renderActivity).join("");
                if (summary && data.stats) {
                  summary.innerHTML = '<div class="StravaSummary">'
                    + renderSummaryRow(data.stats.weekly, "7d")
                    + renderSummaryRow(data.stats.monthly, "30d")
                    + "</div>";
                }
              }
            })
            .catch(function () {});
        }

        refresh();
        setInterval(refresh, REFRESH_MS);
      })();
    </script>
  </body>
</html>
