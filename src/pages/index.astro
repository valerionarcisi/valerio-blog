---
import BaseHead from "~/components/BaseHead.astro";
import StructuredData from "~/components/StructuredData.astro";
import FoglioHeader from "~/components/FoglioHeader.astro";
import FoglioFooter from "~/components/FoglioFooter.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "~/consts";
import { getLetterboxdRss, parseXmlContent } from "~/services/letterboxd";
import { getMovieById } from "~/services/tmdb";
import { fetchRecentTracks } from "~/services/audioscrobbler";
import { getCollection } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";
import "~/styles/foglio.css";
import "./FoglioHome.css";

const lastWatchedMovies = async () => {
  const xml = await getLetterboxdRss();
  const parsedXml = (await parseXmlContent(await xml.text())) as any;

  const moviePromises = parsedXml.rss.channel[0].item
    .filter((item: any) => item?.["tmdb:movieId"]?.[0])
    .map(async (item: any) => {
      try {
        const movie = await getMovieById(item["tmdb:movieId"][0]);
        return { ...movie, ...item };
      } catch (error) {
        console.error(
          `Failed to fetch movie with ID ${item["tmdb:movieId"][0]}`,
          error
        );
        return null;
      }
    });

  const watchedMovies = await Promise.all(moviePromises);
  return watchedMovies.filter(Boolean);
};

const allBlogEntries = await getCollection("blog");
const posts = allBlogEntries
  .filter((e) => getLangFromId(e.id) === "it")
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5)
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));

const allFilmEntries = await getCollection("films");
const films = allFilmEntries
  .filter((e) => getLangFromId(e.id) === "it")
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .slice(0, 4)
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));

const [lastWatched, lastSongs] = await Promise.all([
  lastWatchedMovies().catch(() => []),
  fetchRecentTracks().catch(() => []),
]);

function formatDate(dateStr: string | Date): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString("it-IT", { day: "numeric", month: "short", year: "numeric" });
}
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang="it" />
    <StructuredData
      type="website"
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      url={Astro.url.href}
      image="/img/avatar.png"
    />
  </head>
  <body>
    <FoglioHeader lang="it" />
    <hr class="foglio-rule" />

    <!-- 1. Hero -->
    <section class="fh-hero">
      <div class="fh-hero-text">
        <div class="fh-hero-eyebrow">Filmmaker · Porto Sant'Elpidio</div>
        <h1>Scrivo storie. <em>Le più fortunate</em> diventano film.</h1>
        <p class="fh-hero-lede">
          Faccio cortometraggi nelle Marche. Sto sviluppando <em>Oh Writers</em>, un editor per sceneggiature pensato per il mercato italiano. Qui dentro trovi i film che ho chiuso, quelli che sto scrivendo, e i pezzi che metto giù mentre lavoro.
        </p>
      </div>
      <aside class="fh-portrait">
        <div class="fh-portrait-img"></div>
        <div class="fh-portrait-caption">Valerio · 2026</div>
      </aside>
    </section>

    <!-- 2. Adesso -->
    <section class="fh-now">
      <div class="fh-now-inner">
        <h2>Adesso.</h2>
        <div class="fh-now-body">
          <p>
            <em class="acc">Oh Writers</em> — un editor per sceneggiature, italiano, costruito per come si scrive un copione qui da noi. Soggetto, scaletta, breakdown, budget, location, schedule: tutto nello stesso posto.
          </p>
          <p>
            <em class="acc">Non fa ridere</em> — il mio nuovo cortometraggio. Quattro giorni di riprese al Ristorante L'Oasi del Gusto a Piane di Falerone, sessanta persone sul set. Ora è in montaggio.
          </p>
          <a href="/blog/how-i-display-my-latest-watched-movies-using-letterboxd-rss-feed" class="foglio-readmore fh-now-link">Vedi il tour di Oh Writers →</a>
        </div>
      </div>
    </section>

    <!-- 3. Film grid -->
    <section class="fh-films">
      <div class="fh-section-head">
        <h2>Film</h2>
        <a href="/films/" class="foglio-readmore">Vedi tutto →</a>
      </div>
      <div class="fh-films-grid">
        {films.map((film) => (
          <a
            href={`/films/${film.slug}/`}
            class={`fh-film${film.status === "in-production" ? " fh-film--wip" : ""}`}
          >
            <div class="fh-film-frame">
              <div
                class="fh-film-poster"
                style={`background-image: url('${film.coverImage}')`}
              >
                {film.status === "in-production" && (
                  <span class="fh-film-wip-badge">in lavorazione</span>
                )}
              </div>
            </div>
            <div class="fh-film-meta">{film.year} · {film.role}</div>
            <h3><em>{film.title}</em></h3>
            {film.plot && <p>{film.plot.slice(0, 80)}…</p>}
          </a>
        ))}
      </div>
    </section>

    <!-- 4. Blog spread -->
    <section class="fh-writing">
      <div class="fh-section-head">
        <h2>Blog</h2>
        <a href="/blog/" class="foglio-readmore">Vedi tutto →</a>
      </div>
      {posts.length > 0 && (
        <div class="fh-writing-grid">
          <a href={`/blog/${posts[0].slug}/`} class="fh-post-featured">
            <div class="fh-post-featured-num">N° 01 · l'ultimo</div>
            <h3 set:html={posts[0].title} />
            {posts[0].extract && <p>{posts[0].extract}</p>}
            <div class="fh-post-featured-meta">
              <span>{formatDate(posts[0].date)}</span>
              {posts[0].tags?.[0] && <span>{posts[0].tags[0]}</span>}
              <span class="foglio-status foglio-status--stabile">stabile</span>
            </div>
          </a>

          <div class="fh-post-secondary">
            {posts.slice(1, 5).map((post) => (
              <a href={`/blog/${post.slug}/`} class="fh-post-row">
                <div class="fh-post-row-meta">
                  {formatDate(post.date)}{post.tags?.[0] ? ` · ${post.tags[0]}` : ""}
                </div>
                <h4 set:html={post.title} />
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- 5. Library -->
    <section class="fh-library">
      <div class="fh-library-inner">
        <div class="fh-lib-block">
          <h3>Visti di recente.</h3>
          {lastWatched.length > 0 ? (
            <ul class="fh-lib-list fh-lib-list--films">
              {(lastWatched as any[]).slice(0, 5).map((movie: any) => (
                <li>
                  <div
                    class="fh-lib-cover"
                    style={movie.poster_path ? `background-image: url('https://image.tmdb.org/t/p/w92/${movie.poster_path}')` : ""}
                  ></div>
                  <div class="fh-lib-title">
                    <em>{movie["letterboxd:filmTitle"]?.[0]}</em>
                  </div>
                  <div class="fh-lib-detail">{movie["letterboxd:watchedDate"]?.[0]}</div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="fh-lib-fallback">Dati non disponibili al momento.</p>
          )}
          <a href="/blog/how-i-display-my-latest-watched-movies-using-letterboxd-rss-feed" class="foglio-readmore" style="display:inline-block;margin-top:1.2rem;">Come l'ho costruito →</a>
        </div>

        <div class="fh-lib-block">
          <h3>Ascoltato.</h3>
          {lastSongs.length > 0 ? (
            <ul class="fh-lib-list fh-lib-list--music">
              {(lastSongs as any[]).slice(0, 5).map((song: any) => (
                <li>
                  <div
                    class="fh-lib-cover"
                    style={song.image?.[3]?.["#text"] ? `background-image: url('${song.image[3]["#text"]}')` : ""}
                  ></div>
                  <div class="fh-lib-title">
                    {song.artist?.["#text"]} — <em>{song.name}</em>
                  </div>
                  <div class="fh-lib-detail">{song.date?.["#text"] ?? "di recente"}</div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="fh-lib-fallback">Dati non disponibili al momento.</p>
          )}
          <a href="/blog/how-i-display-my-recently-played-music-using-lastfm-api" class="foglio-readmore" style="display:inline-block;margin-top:1.2rem;">Come l'ho costruito →</a>
        </div>
      </div>
    </section>

    <!-- 6. About strip -->
    <section class="fh-about-strip">
      <p class="fh-quote">"Sono uno che inventa storie. <em class="acc">Poi cerca di farle vedere</em> a qualcuno."</p>
      <a href="/who-i-am" class="foglio-readmore">Chi sono →</a>
    </section>

    <FoglioFooter lang="it" />
  </body>
</html>
