---
import FoglioFilmLayout from "~/layouts/FoglioFilmLayout.astro";
import { getCollection, render } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";

export async function getStaticPaths() {
  const allFilms = await getCollection("films");
  return allFilms
    .filter((e) => getLangFromId(e.id) === "en")
    .map((entry) => ({
      params: { slug: getSlugFromId(entry.id) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const film = entry.data;
const slug = getSlugFromId(entry.id);
---

<FoglioFilmLayout
  title={film.title}
  year={film.year}
  role={film.role}
  status={film.status}
  plot={film.plot}
  coverImage={film.coverImage}
  youtubeUrl={film.youtubeUrl}
  trailerLocalPath={film.trailerLocalPath}
  letterboxdUrl={film.letterboxdUrl}
  technicalSpecs={film.technicalSpecs}
  crew={film.crew}
  cast={film.cast}
  festivals={film.festivals}
  distribution={film.distribution}
  specialThanks={film.specialThanks}
  images={film.images}
  slug={slug}
  lang="en"
>
  <Content />
</FoglioFilmLayout>
