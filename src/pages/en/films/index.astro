---
import FoglioFilmsIndexLayout from "~/layouts/FoglioFilmsIndexLayout.astro";
import { getCollection } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";

const allFilms = await getCollection("films");
const films = allFilms
  .filter((e) => getLangFromId(e.id) === "en")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map((e) => ({
    title: e.data.title,
    year: e.data.year,
    role: e.data.role,
    status: e.data.status,
    sortOrder: e.data.sortOrder,
    coverImage: e.data.coverImage,
    plot: e.data.plot,
    festivals: e.data.festivals,
    slug: getSlugFromId(e.id),
  }));
---

<FoglioFilmsIndexLayout films={films} lang="en" />
