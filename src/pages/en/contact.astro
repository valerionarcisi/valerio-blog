---
import FoglioLayout from "~/layouts/FoglioLayout.astro";
import { SITE_TITLE } from "~/consts";
---

<FoglioLayout
  title={`Contact · ${SITE_TITLE}`}
  description="Get in touch for collaborations, screenplays, ideas, or anything else. I reply to everyone."
  lang="en"
  pageId="contact"
>
  <div class="ct-page">
    <header class="ct-head">
      <p class="ct-eyebrow">Contact</p>
      <h1><em class="acc">Get in touch.</em></h1>
      <p class="ct-lede">
        For collaborations, screenplays, ideas — or just to say something.<br />
        I reply to everyone, same day.
      </p>
    </header>

    <section class="ct-body">
      <div class="ct-block">
        <h2 class="ct-block-label">Email</h2>
        <a href="mailto:valerio.narcisi@gmail.com" class="ct-primary-link">
          valerio.narcisi@gmail.com
        </a>
      </div>

      <div class="ct-block">
        <h2 class="ct-block-label">Elsewhere</h2>
        <ul class="ct-links">
          <li>
            <span class="ct-link-role">GitHub</span>
            <a href="https://github.com/valerionarcisi" class="ct-link" target="_blank" rel="noopener noreferrer">
              github.com/valerionarcisi
            </a>
          </li>
          <li>
            <span class="ct-link-role">LinkedIn</span>
            <a href="https://www.linkedin.com/in/valerionarcisi/" class="ct-link" target="_blank" rel="noopener noreferrer">
              linkedin.com/in/valerionarcisi
            </a>
          </li>
          <li>
            <span class="ct-link-role">Letterboxd</span>
            <a href="https://letterboxd.com/valerionarcisi/" class="ct-link" target="_blank" rel="noopener noreferrer">
              letterboxd.com/valerionarcisi
            </a>
          </li>
        </ul>
      </div>

      <div class="ct-block">
        <h2 class="ct-block-label">About films</h2>
        <p class="ct-note">
          If you have a film project, a screenplay you'd like me to read, or even just
          a rough idea — write me. No filter needed.
        </p>
      </div>
    </section>
  </div>
</FoglioLayout>
