---
import BaseHead from "~/components/BaseHead.astro";
import FoglioHeader from "~/components/FoglioHeader.astro";
import FoglioFooter from "~/components/FoglioFooter.astro";
import NonFaRidereGame from "~/components/NonFaRidereGame.astro";
import { SITE_TITLE } from "~/consts";
import "~/styles/foglio.css";
import "~/layouts/FoglioFilmLayout.css";

const cover = "/img/blog/non-fa-ridere-backstage/open-grezzo-palco.jpg";
const plot =
  "Filippo is the pizza maker at L'Oasi del Gusto restaurant in Piane di Falerone. One evening, while the orders never stop, the place hosts an improvised open mic. Between customers who don't recognise him, a delivery driver running late, the village grandfather and Giulio grabbing the mic without asking — Filippo just needs to survive the night.";

const stills = [
  { src: "/img/blog/non-fa-ridere-backstage/pizzaioli-vetro.jpg", alt: "The pizza makers behind the pizzeria glass" },
  { src: "/img/blog/non-fa-ridere-backstage/filippo-mic.jpg", alt: "Filippo at the mic during the open mic" },
  { src: "/img/blog/non-fa-ridere-backstage/set-signore.jpg", alt: "Filippo, the boom and the ladies at the table" },
  { src: "/img/blog/non-fa-ridere-backstage/forno-troupe.jpg", alt: "The crew in front of the oven" },
  { src: "/img/blog/non-fa-ridere-backstage/attori-tavolo.jpg", alt: "The actors at the table" },
  { src: "/img/blog/non-fa-ridere-backstage/pizzaiolo-ritratto.jpg", alt: "The pizza maker, portrait behind the counter" },
  { src: "/img/blog/non-fa-ridere-backstage/signore-tavolo.jpg", alt: "The ladies at the table in the dining room" },
  { src: "/img/blog/non-fa-ridere-backstage/operatore-camera.jpg", alt: "The operator setting up the camera" },
  { src: "/img/blog/non-fa-ridere-backstage/monitor-camera.jpg", alt: "The camera monitor during a take" },
  { src: "/img/blog/non-fa-ridere-backstage/tavolo-risate.jpg", alt: "Laughs at the table during the shoot" },
];
---

<html lang="en" class="foglio">
  <head>
    <BaseHead
      title={`Non Fa Ridere (2026) | ${SITE_TITLE}`}
      description={plot}
      cover={cover}
      lang="en"
    />
  </head>
  <body>
    <FoglioHeader lang="en" active="films" />
    <main>

    <header class="ff-head">
      <div class="ff-eyebrow">
        <span>2026</span>
        <span>Directed by Valerio Narcisi</span>
        <span class="foglio-status foglio-status--in-lavorazione">In production</span>
      </div>
      <h1 class="ff-title">Non Fa Ridere</h1>
      <p class="ff-credit"><em>Written by Valerio Narcisi &amp; Stefano Teodori · Directed by Valerio Narcisi</em></p>
    </header>

    <section class="ff-poster">
      <div
        class="ff-poster-img"
        style={`background-image: url('${cover}')`}
        role="img"
        aria-label="Non Fa Ridere"
      ></div>
    </section>

    <section class="ff-body ff-body--single">
      <div class="ff-synopsis">
        <h2>Plot.</h2>
        <p>{plot}</p>
        <p>
          The film is in Fermo Marche dialect. It was shot over four days at
          Ristorante L'Oasi del Gusto in Piane di Falerone, with sixty people on
          set. Currently in post-production.
        </p>
      </div>
    </section>

    <section class="ff-stills nfr-game-block">
      <h2>While you wait, play.</h2>
      <p class="nfr-game-intro">
        Filippo throws pizzas at every character from the script. Three levels:
        the dining room, the kitchen, the stage.
      </p>
      <NonFaRidereGame lang="en" />
    </section>

    <section class="ff-stills">
      <h2>From the set.</h2>
      <div class="ff-stills-grid">
        {stills.map((img, i) => (
          <button
            class="ff-plate"
            data-src={img.src}
            aria-label={`Open image ${i + 1}: ${img.alt}`}
            style={`background-image: url('${img.src}')`}
          ></button>
        ))}
      </div>
      <a href="/en/blog/non-fa-ridere-backstage/" class="nfr-readmore">
        Read the backstage story →
      </a>
    </section>

    <div class="ff-lightbox" id="ff-lightbox" role="dialog" aria-modal="true" aria-label="Set gallery" hidden>
      <button class="ff-lightbox-prev" aria-label="Previous">←</button>
      <img class="ff-lightbox-img" alt="" />
      <button class="ff-lightbox-next" aria-label="Next">→</button>
      <button class="ff-lightbox-close" aria-label="Close">✕</button>
      <div class="ff-lightbox-counter"></div>
    </div>

    </main>
    <FoglioFooter lang="en" />

    <script is:inline>
      (function () {
        var plates = Array.from(document.querySelectorAll(".ff-plate"));
        var lb = document.getElementById("ff-lightbox");
        if (!lb || !plates.length) return;
        var img = lb.querySelector(".ff-lightbox-img");
        var counter = lb.querySelector(".ff-lightbox-counter");
        var closeBtn = lb.querySelector(".ff-lightbox-close");
        var prevBtn = lb.querySelector(".ff-lightbox-prev");
        var nextBtn = lb.querySelector(".ff-lightbox-next");
        var idx = 0;
        function show(i) {
          idx = (i + plates.length) % plates.length;
          img.src = plates[idx].getAttribute("data-src");
          img.alt = plates[idx].getAttribute("aria-label") || "";
          counter.textContent = (idx + 1) + " / " + plates.length;
        }
        function open(i) {
          show(i);
          lb.hidden = false;
          lb.classList.add("is-open");
          document.body.style.overflow = "hidden";
        }
        function close() {
          lb.hidden = true;
          lb.classList.remove("is-open");
          document.body.style.overflow = "";
        }
        plates.forEach(function (b, i) {
          b.addEventListener("click", function () { open(i); });
        });
        prevBtn.addEventListener("click", function () { show(idx - 1); });
        nextBtn.addEventListener("click", function () { show(idx + 1); });
        closeBtn.addEventListener("click", close);
        lb.addEventListener("click", function (e) { if (e.target === lb) close(); });
        document.addEventListener("keydown", function (e) {
          if (lb.hidden) return;
          if (e.key === "Escape") close();
          if (e.key === "ArrowLeft") show(idx - 1);
          if (e.key === "ArrowRight") show(idx + 1);
        });
      })();
    </script>
  </body>
</html>

<style>
  .ff-body--single {
    grid-template-columns: 1fr;
  }
  .ff-body--single .ff-synopsis {
    max-width: 760px;
  }

  .nfr-game-block {
    margin-top: 5rem;
  }

  .nfr-game-intro {
    font-family: var(--foglio-serif);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--foglio-ink-soft);
    margin: -1rem 0 1.5rem;
  }

  .nfr-readmore {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--foglio-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--foglio-accent);
    border-bottom: 1px solid var(--foglio-accent-soft);
    padding-bottom: 2px;
    text-decoration: none;
  }
</style>
