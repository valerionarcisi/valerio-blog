---
import BaseHead from "~/components/BaseHead.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import StructuredData from "~/components/StructuredData.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "~/consts";
import Hero from "~/components/Hero.astro";
import Title from "~/components/Title.astro";
import Card from "~/components/Card.astro";
import { getLetterboxdRss, parseXmlContent } from "~/services/letterboxd";
import { getMovieById } from "~/services/tmdb";
import Reel from "~/components/Reel.astro";
import "~/pages/index.css";
import { fetchRecentTracks } from "~/services/audioscrobbler";
import { fetchRecentActivities, fetchFullStats } from "~/services/strava";
import ActivityList from "~/components/ActivityList.astro";
import StravaSummary from "~/components/StravaSummary.astro";
import RunWeeklyChart from "~/components/RunWeeklyChart.astro";
import ActivityDonut from "~/components/ActivityDonut.astro";
import { getCollection } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";

const lastWatchedMovies = async () => {
  const xml = await getLetterboxdRss();
  const parsedXml = (await parseXmlContent(await xml.text())) as any;

  const moviePromises = parsedXml.rss.channel[0].item
    .filter((item: any) => item?.["tmdb:movieId"]?.[0])
    .map(async (item: any) => {
      try {
        const movie = await getMovieById(item["tmdb:movieId"][0]);
        return { ...movie, ...item };
      } catch (error) {
        console.error(
          `Failed to fetch movie with ID ${item["tmdb:movieId"][0]}`,
          error
        );
        return null;
      }
    });

  const watchedMovies = await Promise.all(moviePromises);
  return watchedMovies.filter(Boolean);
};

const allEntries = await getCollection("blog");
const posts = allEntries
  .filter((e) => getLangFromId(e.id) === "en")
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6)
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));

const [lastWatched, lastSongs, lastActivities, fullStats] = await Promise.all([
  lastWatchedMovies(),
  fetchRecentTracks(),
  fetchRecentActivities(5).catch(() => []),
  fetchFullStats().catch(() => null),
]);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <StructuredData
      type="website"
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      url={Astro.url.href}
      image="/img/avatar.png"
    />
  </head>
  <body>
    <Header />
    <Hero
      title="Hi, I'm Valerio_"
      role="developer.filmmaker"
      subtitle="I solve problems. I tell stories."
      aiTagline="AI-assisted, human-driven"
      callToActions={[
        {
          label: "Connect with me",
          href: "http://linkedin.com/in/cv-valerio-narcisi",
        },
        {
          label: "Watch Caramella's Trailer",
          href: "https://www.youtube.com/watch?v=UnQ8NSXYXao",
        },
      ]}
      latestPost={posts[0]}
      lang="en"
    />
    <main>
      <section id="last-watched">
        <Title title="Last watched movies" />
        <div class="ReelContainer" id="movies-reel">
          {
            lastWatched.map((movie: any) => (
              <Reel
                type="movie"
                vote_average={movie.vote_average}
                vote_count={movie.vote_count}
                url={`https://image.tmdb.org/t/p/w185/${movie.poster_path}`}
                href={movie.link[0]}
                title={movie["letterboxd:filmTitle"][0]}
                watchedDate={movie["letterboxd:watchedDate"][0]}
              />
            ))
          }
        </div>
      </section>
      <section>
        <Title title="Last Listened songs" />
        <div class="ReelContainer" id="songs-reel">
          {
            lastSongs.map((song) => (
              <Reel
                type="song"
                artist={song.artist["#text"]}
                album={song.album["#text"]}
                url={song.image[3]["#text"]}
                href={song.url}
                title={song.name}
                watchedDate={
                  song?.date
                    ? song.date["#text"]
                    : new Date().toLocaleDateString("en-us", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })
                }
              />
            ))
          }
        </div>
      </section>
      <section id="strava-section" style={lastActivities.length === 0 ? "display:none" : ""}>
        <Title title="Latest activities" />
        <div class="strava-top" id="strava-top">
          <div id="strava-summary">
            {fullStats && (
              <StravaSummary stats={fullStats.periodStats} />
            )}
          </div>
          {fullStats && (
            <div id="strava-donut">
              <ActivityDonut
                distribution={fullStats.typeDistribution}
                totalActivities={fullStats.periodStats.monthly.totalActivities}
              />
            </div>
          )}
        </div>
        <div class="strava-chart-full" id="strava-charts">
          {fullStats && (
            <RunWeeklyChart weeks={fullStats.weeklyRunStats} />
          )}
        </div>
        <ActivityList activities={lastActivities} />
      </section>
      <section>
        <Title title="Latest posts" />
        <div class="cards-grid">
          {
            posts?.map((post) => (
              <Card
                date={post.date}
                title={post.title}
                extract={post.extract}
                slug={post.slug}
                coverImage={post.coverImage}
                tags={post.tags}
                lang="en"
              />
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var REFRESH_MS = 15 * 60 * 1000;
        var MOVIE_PLACEHOLDER = "https://placeholder.pics/svg/178x278/1a1b26/8a8a8e/No%20Poster";
        var SONG_PLACEHOLDER = "https://placeholder.pics/svg/185x185/1a1b26/8a8a8e/No%20Cover";

        function fmtDate(dateStr) {
          if (!dateStr) return "";
          var d = new Date(dateStr);
          return d.toLocaleDateString("en-us", { month: "short", day: "numeric" });
        }

        function renderMovie(m) {
          var img = m.posterPath
            ? "https://image.tmdb.org/t/p/w185" + m.posterPath
            : MOVIE_PLACEHOLDER;
          var vote = m.voteAverage
            ? '<span class="vote">' + m.voteAverage.toFixed(1) + "</span>"
            : "";
          return '<div class="Reel movie">'
            + '<a href="' + m.link + '" target="_blank" rel="noopener noreferrer">'
            + '<div class="thumbnail"><img src="' + img + '" alt="' + m.title + '" loading="lazy" />' + vote + "</div>"
            + "</a>"
            + '<div class="info"><h3 class="reel-title">' + m.title + "</h3>"
            + '<p class="reel-date">' + fmtDate(m.watchedDate) + "</p></div></div>";
        }

        function renderSong(s) {
          var img = s.image || SONG_PLACEHOLDER;
          var date = s.date ? fmtDate(s.date) : fmtDate(new Date().toISOString());
          return '<div class="Reel song">'
            + '<a href="' + s.url + '" target="_blank" rel="noopener noreferrer">'
            + '<div class="thumbnail"><img src="' + img + '" alt="' + s.name + '" loading="lazy" /></div>'
            + "</a>"
            + '<div class="info"><h3 class="reel-title">' + s.name + "</h3>"
            + '<p class="reel-artist">' + s.artist + "</p>"
            + '<p class="reel-album">' + s.album + "</p>"
            + '<p class="reel-date">' + date + "</p></div></div>";
        }

        function renderActivity(a) {
          var stats = "";
          if (a.hasDistance) stats += "<span>" + a.formattedDistance + "</span>";
          stats += "<span>" + a.formattedDuration + "</span>";
          if (a.formattedPace) stats += '<span class="pace">' + a.formattedPace + "</span>";
          if (a.formattedElevation) stats += "<span>" + a.formattedElevation + "</span>";
          return '<a class="activity-row" href="' + a.url + '" target="_blank" rel="noopener noreferrer">'
            + '<span class="activity-dot" style="background:' + a.color + '"></span>'
            + '<span class="activity-name">' + a.name + "</span>"
            + '<span class="activity-stats">' + stats + "</span>"
            + '<span class="activity-date">' + a.formattedDate + "</span></a>";
        }

        function renderSummaryRow(s, badge) {
          var html = '<div class="summary-row">'
            + '<span class="summary-badge">' + badge + "</span>"
            + '<span class="summary-km">' + s.distance + "</span>"
            + '<span class="summary-sep">·</span>'
            + '<span class="summary-meta">' + s.count + " att.</span>";
          if (s.pace) html += '<span class="summary-sep">·</span><span class="summary-pace">' + s.pace + "</span>";
          if (s.elevation) html += '<span class="summary-sep">·</span><span class="summary-meta">' + s.elevation + "</span>";
          html += "</div>";
          return html;
        }

        function fmtPace(secPerKm) {
          var m = Math.floor(secPerKm / 60);
          var s = Math.round(secPerKm % 60);
          return m + ":" + (s < 10 ? "0" : "") + s + " /km";
        }

        function renderLineChart(weeks) {
          var hasData = false;
          for (var i = 0; i < weeks.length; i++) { if (weeks[i].runs > 0) hasData = true; }
          if (!hasData) return '<div class="RunWeeklyChart"><div class="chart-empty">No recent runs</div></div>';

          var svgW = 440, svgH = 170, padX = 40, padY = 24, padBottom = 28;
          var chartW = svgW - padX * 2, chartH = svgH - padY - padBottom;
          var distances = [], paces = [];
          for (var i = 0; i < weeks.length; i++) {
            distances.push(weeks[i].distance / 1000);
            if (weeks[i].pace > 0) paces.push(weeks[i].pace);
          }
          var maxDist = Math.max.apply(null, distances.concat([1]));
          var minPace = paces.length > 0 ? Math.min.apply(null, paces) - 15 : 240;
          var maxPace = paces.length > 0 ? Math.max.apply(null, paces) + 15 : 420;
          var xStep = weeks.length > 1 ? chartW / (weeks.length - 1) : chartW;

          var bestIdx = 0;
          for (var i = 1; i < distances.length; i++) { if (distances[i] > distances[bestIdx]) bestIdx = i; }

          var distPts = [], pacePts = [];
          for (var i = 0; i < weeks.length; i++) {
            var x = padX + i * xStep;
            var dy = padY + chartH - (distances[i] / maxDist) * chartH;
            distPts.push({ x: x, y: dy, v: distances[i] });
            if (weeks[i].pace > 0) {
              var norm = (maxPace - weeks[i].pace) / (maxPace - minPace);
              var py = padY + chartH - norm * chartH;
              pacePts.push({ x: x, y: py, v: weeks[i].pace });
            }
          }

          var distLine = "", distArea = "", paceLine = "";
          for (var i = 0; i < distPts.length; i++) {
            distLine += (i === 0 ? "M" : "L") + distPts[i].x + "," + distPts[i].y + " ";
          }
          distArea = distLine + "L" + distPts[distPts.length - 1].x + "," + (padY + chartH) + " L" + distPts[0].x + "," + (padY + chartH) + " Z";
          for (var i = 0; i < pacePts.length; i++) {
            paceLine += (i === 0 ? "M" : "L") + pacePts[i].x + "," + pacePts[i].y + " ";
          }

          var svg = "";
          var gridPcts = [0.25, 0.5, 0.75];
          for (var g = 0; g < gridPcts.length; g++) {
            var gy = padY + chartH - chartH * gridPcts[g];
            svg += '<line x1="' + padX + '" y1="' + gy + '" x2="' + (svgW - padX) + '" y2="' + gy + '" stroke="#252528" stroke-width="0.5" stroke-dasharray="3,4"/>';
          }
          svg += '<line x1="' + padX + '" y1="' + (padY + chartH) + '" x2="' + (svgW - padX) + '" y2="' + (padY + chartH) + '" stroke="#333" stroke-width="0.5"/>';

          var distYVals = [0, maxDist / 2, maxDist];
          for (var i = 0; i < distYVals.length; i++) {
            var ly = padY + chartH - (distYVals[i] / maxDist) * chartH;
            svg += '<text x="' + (padX - 4) + '" y="' + (ly + 2) + '" text-anchor="end" fill="#fc4c02" font-size="7" font-family="JetBrains Mono, monospace" opacity="0.6">' + distYVals[i].toFixed(0) + "</text>";
          }
          var paceYVals = [minPace, (minPace + maxPace) / 2, maxPace];
          for (var i = 0; i < paceYVals.length; i++) {
            var ly = padY + chartH - ((maxPace - paceYVals[i]) / (maxPace - minPace)) * chartH;
            var pm = Math.floor(paceYVals[i] / 60);
            var ps = Math.round(paceYVals[i] % 60);
            svg += '<text x="' + (svgW - padX + 4) + '" y="' + (ly + 2) + '" text-anchor="start" fill="#c8a000" font-size="7" font-family="JetBrains Mono, monospace" opacity="0.6">' + pm + ":" + (ps < 10 ? "0" : "") + ps + "</text>";
          }

          svg += '<path d="' + distArea + '" fill="#fc4c02" opacity="0.08"/>';
          svg += '<path d="' + distLine + '" fill="none" stroke="#fc4c02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
          if (pacePts.length > 1) {
            svg += '<path d="' + paceLine + '" fill="none" stroke="#c8a000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="4,3"/>';
          }

          for (var i = 0; i < distPts.length; i++) {
            var isBest = i === bestIdx && distances[bestIdx] > 0;
            var elev = weeks[i].elevation > 0 ? " ↑" + Math.round(weeks[i].elevation) + "m" : "";
            var tip = weeks[i].weekLabel + ": " + distPts[i].v.toFixed(1) + " km — " + weeks[i].runs + " runs" + elev;
            if (isBest) svg += '<circle cx="' + distPts[i].x + '" cy="' + distPts[i].y + '" r="9" fill="#fc4c02" opacity="0.12"/>';
            svg += '<g><circle cx="' + distPts[i].x + '" cy="' + distPts[i].y + '" r="' + (isBest ? 5 : 3.5) + '" fill="' + (isBest ? "#ff6b2b" : "#fc4c02") + '" stroke="#151518" stroke-width="' + (isBest ? 2 : 1.5) + '"/>';
            svg += '<title>' + tip + "</title></g>";
          }
          for (var i = 0; i < weeks.length; i++) {
            if (weeks[i].runs > 0) {
              svg += '<text x="' + distPts[i].x + '" y="' + (distPts[i].y - 8) + '" text-anchor="middle" fill="#8a8a8e" font-size="6" font-family="JetBrains Mono, monospace">' + weeks[i].runs + "x</text>";
            }
          }
          for (var i = 0; i < pacePts.length; i++) {
            svg += '<g><circle cx="' + pacePts[i].x + '" cy="' + pacePts[i].y + '" r="2.5" fill="#c8a000" stroke="#151518" stroke-width="1"/>';
            svg += '<title>' + fmtPace(pacePts[i].v) + "</title></g>";
          }

          for (var i = 0; i < weeks.length; i++) {
            var x = padX + i * xStep;
            svg += '<text x="' + x + '" y="' + (svgH - 6) + '" text-anchor="middle" fill="#8a8a8e" font-size="6.5" font-family="JetBrains Mono, monospace">' + weeks[i].weekLabel + "</text>";
          }

          var header = '<div class="chart-header"><span class="chart-title">Weekly running</span>'
            + '<div class="chart-legend"><span class="legend-item"><span class="legend-line dist"></span>km</span>'
            + '<span class="legend-item"><span class="legend-line pace"></span>pace</span></div></div>';

          return '<div class="RunWeeklyChart">' + header + '<svg viewBox="0 0 ' + svgW + " " + svgH + '" role="img">' + svg + "</svg></div>";
        }

        function renderDonut(dist, total) {
          var r = 36, sw = 8, cx = 50, cy = 50;
          var circ = 2 * Math.PI * r;
          var acc = 0;
          var arcs = '<circle cx="50" cy="50" r="36" fill="none" stroke="#252528" stroke-width="8"/>';
          for (var i = 0; i < dist.length; i++) {
            var seg = dist[i];
            var len = (seg.percentage / 100) * circ;
            arcs += '<circle cx="50" cy="50" r="36" fill="none" stroke="' + seg.color + '" stroke-width="8" stroke-dasharray="' + len + " " + (circ - len) + '" stroke-dashoffset="' + (-acc) + '" stroke-linecap="round" transform="rotate(-90 50 50)" opacity="0.85"><title>' + seg.label + ": " + seg.count + " (" + seg.percentage + "%)</title></circle>";
            acc += len;
          }
          var svg = '<svg viewBox="0 0 100 100" role="img">' + arcs
            + '<text x="50" y="46" text-anchor="middle" fill="#e8e6e1" font-size="14" font-weight="700" font-family="Staatliches, sans-serif">' + total + "</text>"
            + '<text x="50" y="58" text-anchor="middle" fill="#8a8a8e" font-size="6">att.</text></svg>';
          var legend = "";
          for (var i = 0; i < dist.length; i++) {
            var s = dist[i];
            legend += '<div class="legend-item"><span class="legend-dot" style="background:' + s.color + '"></span><span class="legend-text">' + s.label + '</span><span class="legend-pct">' + s.percentage + "%</span></div>";
          }
          return '<div class="ActivityDonut"><div class="donut-chart">' + svg + '</div><div class="donut-legend">' + legend + "</div></div>";
        }

        function fixBrokenImages(container, placeholder) {
          if (!container) return;
          container.querySelectorAll("img").forEach(function (img) {
            function onFail() { img.removeEventListener("error", onFail); img.src = placeholder; }
            img.addEventListener("error", onFail);
            if (img.complete && img.naturalWidth === 0 && img.src !== placeholder) onFail();
          });
        }

        function refresh() {
          fetch("/api/letterboxd")
            .then(function (r) { return r.json(); })
            .then(function (movies) {
              var el = document.getElementById("movies-reel");
              if (el && Array.isArray(movies)) {
                el.innerHTML = movies.map(renderMovie).join("");
                fixBrokenImages(el, MOVIE_PLACEHOLDER);
              }
            })
            .catch(function () {});

          fetch("/api/lastfm")
            .then(function (r) { return r.json(); })
            .then(function (songs) {
              var el = document.getElementById("songs-reel");
              if (el && Array.isArray(songs)) {
                el.innerHTML = songs.map(renderSong).join("");
                fixBrokenImages(el, SONG_PLACEHOLDER);
              }
            })
            .catch(function () {});

          fetch("/api/strava")
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data.error) return;
              var section = document.getElementById("strava-section");
              var reel = document.getElementById("strava-reel");
              var summary = document.getElementById("strava-summary");
              var charts = document.getElementById("strava-charts");
              var donutEl = document.getElementById("strava-donut");
              if (section && data.activities && data.activities.length > 0) {
                section.style.display = "";
                if (reel) reel.innerHTML = data.activities.map(renderActivity).join("");
                if (summary && data.stats) {
                  summary.innerHTML = '<div class="StravaSummary">'
                    + renderSummaryRow(data.stats.weekly, "7d")
                    + renderSummaryRow(data.stats.monthly, "30d")
                    + "</div>";
                }
                if (donutEl && data.typeDistribution) {
                  var total = data.stats ? data.stats.monthly.count : 0;
                  donutEl.innerHTML = renderDonut(data.typeDistribution, total);
                }
                if (charts && data.weeklyRunStats) {
                  charts.innerHTML = renderLineChart(data.weeklyRunStats);
                }
              }
            })
            .catch(function () {});
        }

        refresh();
        setInterval(refresh, REFRESH_MS);
      })();
    </script>
  </body>
</html>
