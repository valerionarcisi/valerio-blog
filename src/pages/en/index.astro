---
import BaseHead from "~/components/BaseHead.astro";
import StructuredData from "~/components/StructuredData.astro";
import FoglioHeader from "~/components/FoglioHeader.astro";
import FoglioFooter from "~/components/FoglioFooter.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "~/consts";
import { getLetterboxdRss, parseXmlContent } from "~/services/letterboxd";
import { getMovieById, extractDirectors } from "~/services/tmdb";
import { formatMoneyCompact } from "~/lib/format-money";
import { getTopPosts } from "~/lib/top-posts";
import { fetchPostStats } from "~/lib/post-stats";
import { fetchRecentTracks } from "~/services/audioscrobbler";
import { getCollection } from "astro:content";
import { getLangFromId, getSlugFromId } from "~/i18n/utils";
import "~/styles/foglio.css";
import "~/pages/FoglioHome.css";

const lastWatchedMovies = async () => {
  const xml = await getLetterboxdRss();
  const parsedXml = (await parseXmlContent(await xml.text())) as any;

  const moviePromises = parsedXml.rss.channel[0].item
    .filter((item: any) => item?.["tmdb:movieId"]?.[0])
    .map(async (item: any) => {
      try {
        const movie = await getMovieById(item["tmdb:movieId"][0]);
        return { ...movie, ...item, directors: extractDirectors(movie) };
      } catch (error) {
        console.error(
          `Failed to fetch movie with ID ${item["tmdb:movieId"][0]}`,
          error
        );
        return null;
      }
    });

  const watchedMovies = await Promise.all(moviePromises);
  return watchedMovies.filter(Boolean);
};

const allBlogEntries = await getCollection("blog");
const allPosts = allBlogEntries
  .filter((e) => getLangFromId(e.id) === "en")
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));
const postsByDate = [...allPosts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const featuredPost = postsByDate[0];

const SECONDARY_LIMIT = 5;
const postStats = await fetchPostStats();
const topPostsRaw = await getTopPosts({ lang: "en", days: 90, limit: 12 });
const slugSet = new Set(allPosts.map((p) => p.slug));
const topPosts = topPostsRaw
  .filter((tp) => slugSet.has(tp.slug) && tp.slug !== featuredPost?.slug)
  .slice(0, SECONDARY_LIMIT)
  .map((tp) => {
    const post = allPosts.find((p) => p.slug === tp.slug)!;
    return { ...post, views: tp.views };
  });

const fallbackPosts = postsByDate
  .slice(1)
  .filter((p) => !topPosts.find((tp) => tp.slug === p.slug))
  .slice(0, SECONDARY_LIMIT - topPosts.length)
  .map((p) => ({ ...p, views: 0 }));

const secondaryPosts = [...topPosts, ...fallbackPosts];

const posts = postsByDate.slice(0, 5);

const allFilmEntries = await getCollection("films");
const films = allFilmEntries
  .filter((e) => getLangFromId(e.id) === "en")
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .slice(0, 4)
  .map((e) => ({
    ...e.data,
    slug: getSlugFromId(e.id),
  }));

const [lastWatched, lastSongs] = await Promise.all([
  lastWatchedMovies().catch(() => []),
  fetchRecentTracks().catch(() => []),
]);

function formatDate(dateStr: string | Date): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
}
---

<!doctype html>
<html lang="en" class="foglio">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang="en" />
    <StructuredData
      type="website"
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      url={Astro.url.href}
      image="/img/avatar.png"
    />
  </head>
  <body>
    <FoglioHeader lang="en" />
    <main>
    <hr class="foglio-rule" />

    <!-- 1. Hero -->
    <section class="fh-hero">
      <div class="fh-hero-text">
        <div class="fh-hero-eyebrow">Filmmaker · Developer · Porto Sant'Elpidio</div>
        <h1>I write stories. <em>The lucky ones</em> become films.</h1>
        <p class="fh-hero-lede">
          I make films and I write code — <em class="acc">what I really do, in both, is solve problems</em>. Here you'll find the shorts, the screenplays in progress, and <em>Oh Writers</em>, the Italian screenplay editor I wish I'd had.
        </p>
      </div>
      <aside class="fh-portrait">
        <div class="fh-portrait-img"></div>
        <div class="fh-portrait-caption">Valerio · 2026</div>
      </aside>
    </section>

    <!-- 2. Now -->
    <section class="fh-now">
      <div class="fh-now-inner">
        <h2>Now.</h2>
        <div class="fh-now-body">
          <p>
            <em class="acc">Oh Writers</em> — a screenplay editor, Italian, built for how we write scripts here. Treatment, outline, breakdown, budget, locations, schedule: everything in one place.
          </p>
          <p>
            <em class="acc">Non fa ridere</em> — my new short film. Four days of shooting at Ristorante L'Oasi del Gusto in Piane di Falerone, sixty people on set. Now in editing.
          </p>
          <a href="mailto:valerio.narcisi@gmail.com?subject=Request%20Oh%20Writers%20tour&body=Hi%20Valerio%2C%0A%0AI%27d%20love%20to%20see%20a%20demo%2Ftour%20of%20Oh%20Writers.%0A%0AThanks%21" class="foglio-readmore fh-now-link">Request the Oh Writers tour →</a>
        </div>
      </div>
    </section>

    <!-- 3. Films grid -->
    <section class="fh-films">
      <div class="fh-section-head">
        <h2>Films</h2>
        <a href="/en/films/" class="foglio-readmore">See all →</a>
      </div>
      <div class="fh-films-grid">
        {films.map((film) => (
          <a
            href={`/en/films/${film.slug}/`}
            class={`fh-film${film.status === "in-production" ? " fh-film--wip" : ""}`}
          >
            <div class="fh-film-frame">
              <div
                class="fh-film-poster"
                style={`background-image: url('${film.posterImage ?? film.coverImage}')`}
              >
                {film.status === "in-production" && (
                  <span class="fh-film-wip-badge">in production</span>
                )}
              </div>
            </div>
            <div class="fh-film-meta">{film.year} · {film.role}</div>
            <h3>{film.title}</h3>
            {film.plot && <p>{film.plot.slice(0, 80)}…</p>}
          </a>
        ))}
      </div>
    </section>

    <!-- 4. Blog spread -->
    <section class="fh-writing">
      <div class="fh-section-head">
        <h2>Blog</h2>
        <a href="/en/blog/" class="foglio-readmore">See all →</a>
      </div>
      {featuredPost && (
        <div class="fh-writing-grid">
          <a href={`/en/blog/${featuredPost.slug}/`} class="fh-post-featured">
            {featuredPost.coverImage && (
              <div
                class="fh-post-featured-cover"
                style={`background-image: url('${featuredPost.coverImage}')`}
                role="img"
                aria-label={featuredPost.title}
              />
            )}
            <div class="fh-post-featured-body">
              <div class="fh-post-featured-num">No. 01 · latest</div>
              <h3 set:html={featuredPost.title} />
              {featuredPost.extract && <p>{featuredPost.extract}</p>}
              <div class="fh-post-featured-meta">
                <span>{formatDate(featuredPost.date)}</span>
                {featuredPost.tags?.[0] && <span>{featuredPost.tags[0]}</span>}
                <span class="foglio-status foglio-status--stabile">stable</span>
                {(postStats.claps[featuredPost.slug] ?? 0) > 0 && (
                  <span>♥ {postStats.claps[featuredPost.slug]}</span>
                )}
                {(postStats.comments[featuredPost.slug] ?? 0) > 0 && (
                  <span>{postStats.comments[featuredPost.slug]} comments</span>
                )}
              </div>
            </div>
          </a>

          <div class="fh-post-secondary">
            <div class="fh-post-secondary-label">Most read</div>
            {secondaryPosts.map((post) => {
              const claps = postStats.claps[post.slug] ?? 0;
              const comments = postStats.comments[post.slug] ?? 0;
              return (
                <a href={`/en/blog/${post.slug}/`} class="fh-post-row">
                  <div class="fh-post-row-meta">
                    {formatDate(post.date)}{post.tags?.[0] ? ` · ${post.tags[0]}` : ""}
                    {post.views > 0 && <span class="fh-post-row-views">{post.views} reads</span>}
                    {claps > 0 && <span class="fh-post-row-stat">♥ {claps}</span>}
                    {comments > 0 && <span class="fh-post-row-stat fh-post-row-stat-dim">{comments} comments</span>}
                  </div>
                  <h4 set:html={post.title} />
                </a>
              );
            })}
          </div>
        </div>
      )}
    </section>

    <!-- 5. Library -->
    <section class="fh-library">
      <div class="fh-library-inner">
        <div class="fh-lib-block" data-watched-home>
          <h3>Recently watched.</h3>
          {lastWatched.length > 0 ? (
            <ul class="fh-lib-list fh-lib-list--films" data-watched-list>
              {(lastWatched as any[]).slice(0, 5).map((movie: any) => (
                <li>
                  <div
                    class="fh-lib-cover"
                    style={movie.poster_path ? `background-image: url('https://image.tmdb.org/t/p/w92/${movie.poster_path}')` : ""}
                  ></div>
                  <div class="fh-lib-title">
                    <em>{movie["letterboxd:filmTitle"]?.[0]}</em>
                    {(() => {
                      const b = formatMoneyCompact(movie.budget);
                      const r = formatMoneyCompact(movie.revenue);
                      if (!b && !r) return null;
                      return (
                        <span class="fh-lib-money" title="Budget → Box office">
                          {b ?? "—"} <span class="fh-lib-money-arrow">→</span> {r ?? "—"}
                        </span>
                      );
                    })()}
                    {movie.directors && movie.directors.length > 0 && (
                      <span class="fh-lib-director">by {movie.directors.join(", ")}</span>
                    )}
                  </div>
                  <div class="fh-lib-detail">{(() => {
                    const raw = movie["letterboxd:watchedDate"]?.[0];
                    if (!raw) return "";
                    const d = new Date(raw);
                    return isNaN(d.getTime()) ? raw : d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
                  })()}</div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="fh-lib-fallback">Data not available right now.</p>
          )}
          <div class="fh-lib-actions">
            <a href="/en/watched" class="foglio-readmore">See all →</a>
            <a href="/en/blog/" class="foglio-readmore fh-lib-secondary">How I built it →</a>
          </div>
        </div>

        <div class="fh-lib-block">
          <h3>Listened.</h3>
          {lastSongs.length > 0 ? (
            <ul class="fh-lib-list fh-lib-list--music">
              {(lastSongs as any[]).slice(0, 5).map((song: any) => (
                <li>
                  <div
                    class="fh-lib-cover"
                    style={song.image?.[3]?.["#text"] ? `background-image: url('${song.image[3]["#text"]}')` : ""}
                  ></div>
                  <div class="fh-lib-title">
                    {song.artist?.["#text"]} — <em>{song.name}</em>
                  </div>
                  <div class="fh-lib-detail">{(() => {
                    const raw = song.date?.["#text"];
                    if (!raw) return "recently";
                    const d = new Date(raw + " UTC");
                    return isNaN(d.getTime()) ? raw : d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
                  })()}</div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="fh-lib-fallback">Data not available right now.</p>
          )}
          <div class="fh-lib-actions">
            <a href="/en/listening" class="foglio-readmore">See all →</a>
            <a href="/en/blog/" class="foglio-readmore fh-lib-secondary">How I built it →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. About strip -->
    <section class="fh-about-strip">
      <p class="fh-quote">"Making a film or building a product — in the end it's the same thing. <em class="acc">A group of people trusting a vision</em>, and getting there together."</p>
      <a href="/en/who-i-am" class="foglio-readmore">About me →</a>
    </section>

    </main>
    <FoglioFooter lang="en" />

    <script>
      import { fetchWatched, renderCompact } from "~/scripts/watched-movies";
      const block = document.querySelector<HTMLElement>("[data-watched-home]");
      if (block) {
        fetchWatched()
          .then((movies) => {
            if (movies.length > 0) renderCompact(block, movies, { locale: "en-GB", byLabel: "by" });
          })
          .catch(() => {});
      }
    </script>
  </body>
</html>
