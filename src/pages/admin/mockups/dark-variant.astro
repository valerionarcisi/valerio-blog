---
export const prerender = false;
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mockup B — Notturno</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #0c0c0d;
        --bg-2: #131315;
        --ink: #ece8de;
        --ink-soft: #8a847a;
        --rule: #232325;
        --accent: #d9b88a;
        --accent-strong: #f0c68a;
        --serif: "Cormorant Garamond", "Iowan Old Style", Georgia, serif;
        --sans: "Inter", -apple-system, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, monospace;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.6rem 2.4rem;
        border-bottom: 1px solid var(--rule);
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
      }
      .nav-brand {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.2rem;
        text-transform: none;
        letter-spacing: 0;
        color: var(--ink);
      }
      .nav-links { display: flex; gap: 2rem; }
      .nav-links a:hover { color: var(--accent); }

      .hero {
        position: relative;
        min-height: 88vh;
        display: grid;
        grid-template-columns: 1.4fr 1fr;
      }
      .hero-image {
        background: url("/img/caramella/STILL_00.jpg") center / cover;
        position: relative;
      }
      .hero-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 60%, var(--bg) 100%);
      }
      .hero-text {
        padding: 6rem 4rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 620px;
      }
      .hero-eyebrow {
        font-family: var(--mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
        margin-bottom: 1.8rem;
      }
      .hero h1 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(2.6rem, 4.6vw, 4.4rem);
        line-height: 1.04;
        letter-spacing: -0.005em;
        margin: 0 0 1.6rem;
      }
      .hero h1 em {
        font-style: italic;
        color: var(--accent-strong);
        font-weight: 500;
      }
      .hero-lede {
        font-family: var(--serif);
        font-size: 1.2rem;
        line-height: 1.55;
        color: var(--ink-soft);
        margin: 0;
      }
      .hero-pic-caption {
        position: absolute;
        bottom: 1.5rem;
        left: 2rem;
        font-family: var(--mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
      }

      .featured-list {
        max-width: 1280px;
        margin: 0 auto;
        padding: 6rem 2.4rem;
      }
      .section-eyebrow {
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ink-soft);
        border-bottom: 1px solid var(--rule);
        padding-bottom: 1rem;
        margin-bottom: 3rem;
      }
      .section-eyebrow span { color: var(--accent); }

      .films {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem 3rem;
      }
      .film-card .plate {
        aspect-ratio: 16 / 10;
        background-size: cover;
        background-position: center;
        margin-bottom: 1.5rem;
      }
      .film-card-1 .plate { background-image: url("/img/caramella/STILL_02.jpg"); }
      .film-card-2 .plate { background-image: url("/img/arturo/frame-300s.jpg"); }
      .film-meta {
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
        margin-bottom: 0.6rem;
      }
      .film-card h2 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(1.8rem, 2.4vw, 2.4rem);
        line-height: 1.1;
        margin: 0 0 0.8rem;
      }
      .film-card h2 em { font-style: italic; }
      .film-card p {
        font-family: var(--serif);
        font-size: 1.1rem;
        line-height: 1.55;
        color: var(--ink-soft);
        margin: 0;
      }

      .writing {
        background: var(--bg-2);
        border-top: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
      }
      .writing-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 6rem 2.4rem;
      }
      .post-list {
        display: flex;
        flex-direction: column;
      }
      .post {
        display: grid;
        grid-template-columns: 1fr 2fr 1fr;
        gap: 2rem;
        padding: 1.8rem 0;
        border-bottom: 1px solid var(--rule);
        align-items: baseline;
      }
      .post:hover h3 { color: var(--accent); }
      .post-date {
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
      }
      .post h3 {
        font-family: var(--serif);
        font-weight: 500;
        font-size: 1.5rem;
        line-height: 1.2;
        margin: 0;
        transition: color 0.15s;
      }
      .post h3 em { font-style: italic; }
      .post-tag {
        font-family: var(--mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
        text-align: right;
      }

      .now {
        max-width: 1280px;
        margin: 0 auto;
        padding: 6rem 2.4rem;
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 5rem;
      }
      .now h2 {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 2rem;
        margin: 0;
      }
      .now-body p {
        font-family: var(--serif);
        font-size: 1.2rem;
        line-height: 1.6;
        color: var(--ink);
        margin: 0 0 1rem;
      }
      .now-body em { font-style: italic; color: var(--accent-strong); }

      .footer {
        border-top: 1px solid var(--rule);
      }
      .footer-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 3rem 2.4rem;
        display: flex;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <a href="#" class="nav-brand">Valerio Narcisi</a>
      <div class="nav-links">
        <a href="#">Films</a>
        <a href="#">Writing</a>
        <a href="#">Notes</a>
        <a href="#">About</a>
        <a href="#">IT</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-image">
        <div class="hero-pic-caption">Caramella · 2025 · frame</div>
      </div>
      <div class="hero-text">
        <div class="hero-eyebrow">Filmmaker · Italy</div>
        <h1>I invent stories. <em>I write them down</em>, I shoot them.</h1>
        <p class="hero-lede">
          Short films, screenplays in progress, technical essays, and the notes that hold them together. There's no right order to start from.
        </p>
      </div>
    </section>

    <section class="featured-list">
      <div class="section-eyebrow">Recent films · <span>2024–2025</span></div>
      <div class="films">
        <article class="film-card film-card-1">
          <div class="plate"></div>
          <div class="film-meta">Short · 14 min · 2025</div>
          <h2><em>Caramella</em></h2>
          <p>A girl, a candy, an afternoon that changes direction. Premiered at Fano Film Festival 2025.</p>
        </article>
        <article class="film-card film-card-2">
          <div class="plate"></div>
          <div class="film-meta">Short · 11 min · 2024</div>
          <h2><em>Arturo</em></h2>
          <p>An old man builds a kite the day he stops being afraid of the wind.</p>
        </article>
      </div>
    </section>

    <section class="writing">
      <div class="writing-inner">
        <div class="section-eyebrow">Recent writing · <span>essays + notes</span></div>
        <div class="post-list">
          <article class="post">
            <div class="post-date">May 2026</div>
            <h3>The Result Pattern with React Query</h3>
            <div class="post-tag">Essay · 12 min</div>
          </article>
          <article class="post">
            <div class="post-date">Apr 2026</div>
            <h3>From meditation to <em>functional programming</em></h3>
            <div class="post-tag">Note · 4 min</div>
          </article>
          <article class="post">
            <div class="post-date">Mar 2026</div>
            <h3>How I show my Strava activities</h3>
            <div class="post-tag">Essay · 8 min</div>
          </article>
          <article class="post">
            <div class="post-date">Feb 2026</div>
            <h3>The screenplay as <em>source code</em></h3>
            <div class="post-tag">Note · 5 min</div>
          </article>
        </div>
      </div>
    </section>

    <section class="now">
      <h2>Now.</h2>
      <div class="now-body">
        <p>
          Building <em>Oh Writers</em>: a screenwriting editor designed around the Italian market. Dashboard, treatment, breakdown, budget, locations, schedule — one unified flow.
        </p>
        <p>
          Writing a new short. 23 pages of draft. 17 more to go.
        </p>
        <p>
          Reading <em>Reality Hunger</em> by David Shields. Watching Pietro Marcello.
        </p>
      </div>
    </section>

    <footer class="footer">
      <div class="footer-inner">
        <div>© 2026 Valerio Narcisi</div>
        <div>Mockup B · Notturno</div>
      </div>
    </footer>
  </body>
</html>
