---
import { verifyAdminToken } from "~/lib/auth";
import AdminNav from "~/components/AdminNav.astro";
import { days, snacks } from "~/data/meal-plan";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = verifyAdminToken(token);

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

const mealEmoji: Record<string, string> = {
  "Colazione": "🌅",
  "Pranzo": "🍝",
  "Cena": "🌙",
  "Cena (libera)": "🍕",
  "Spuntino": "🍎",
};
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Piano Alimentare</title>
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0a0a0c;
        color: #e8e6e1;
        padding: 1rem;
        min-height: 100vh;
        font-size: 1.05rem;
        -webkit-text-size-adjust: 100%;
      }

      .day-tabs {
        display: flex;
        gap: 0.25rem;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 0.5rem;
        margin-bottom: 1rem;
        scrollbar-width: none;
      }
      .day-tabs::-webkit-scrollbar { display: none; }

      .day-tab {
        flex-shrink: 0;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        border: 1px solid #333;
        background: #151518;
        color: #999;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
      }
      .day-tab:hover { border-color: #555; color: #ccc; }
      .day-tab.active {
        background: #c8a000;
        color: #0a0a0c;
        border-color: #c8a000;
        font-weight: 700;
      }

      .day-content { display: none; }
      .day-content.active { display: block; }

      .meal-card {
        background: #151518;
        border: 1px solid #252528;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
      }

      .meal-header {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.6rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .meal-header .emoji { font-size: 1.1rem; }

      .oil-badge {
        display: inline-block;
        font-size: 0.82rem;
        font-weight: 500;
        background: #1a2a1a;
        color: #6abf6a;
        padding: 0.15rem 0.5rem;
        border-radius: 1rem;
        margin-left: auto;
        white-space: nowrap;
      }
      .oil-badge.no-oil {
        background: #2a1a1a;
        color: #bf6a6a;
      }

      .meal-items {
        list-style: none;
        padding: 0;
      }
      .meal-items li {
        font-size: 0.85rem;
        line-height: 1.5;
        padding: 0.25rem 0 0.25rem 1.2rem;
        position: relative;
        color: #ccc;
      }
      .meal-items li::before {
        content: "•";
        position: absolute;
        left: 0.25rem;
        color: #666;
      }

      details.alternatives {
        margin-top: 0.5rem;
        border-top: 1px solid #252528;
        padding-top: 0.5rem;
      }
      details.alternatives summary {
        font-size: 0.9rem;
        color: #c8a000;
        cursor: pointer;
        user-select: none;
        padding: 0.25rem 0;
        list-style: none;
      }
      details.alternatives summary::-webkit-details-marker { display: none; }
      details.alternatives summary::before {
        content: "▸ ";
        display: inline;
      }
      details.alternatives[open] summary::before {
        content: "▾ ";
      }

      .alt-option {
        padding: 0.5rem 0;
        border-bottom: 1px dashed #1f1f22;
      }
      .alt-option:last-child { border-bottom: none; }

      .alt-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
      }

      .snack-section {
        margin-bottom: 1rem;
      }
      .snack-section-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #e8e6e1;
        margin-bottom: 0.5rem;
        padding-left: 0.25rem;
      }
      .snack-option {
        font-size: 0.85rem;
        line-height: 1.5;
        padding: 0.35rem 0.5rem;
        color: #ccc;
        border-radius: 0.35rem;
      }
      .snack-option:nth-child(odd) {
        background: #111114;
      }
      .snack-option .snack-num {
        color: #666;
        font-size: 0.88rem;
        margin-right: 0.3rem;
      }

      @media (max-width: 500px) {
        body { padding: 0.75rem; }
        .day-tab { padding: 0.45rem 0.75rem; font-size: 0.8rem; }
        .meal-card { padding: 0.75rem; }
      }
    </style>
  </head>
  <body>
    <AdminNav currentPage="meal-plan" token={token} />

    <div class="day-tabs" role="tablist">
      {days.map((day) => (
        <button
          class="day-tab"
          data-day={day.id}
          role="tab"
          aria-selected="false"
        >
          {day.short}
        </button>
      ))}
      <button class="day-tab" data-day="snacks" role="tab" aria-selected="false">
        Spuntini
      </button>
    </div>

    {days.map((day) => (
      <div
        class="day-content"
        data-panel={day.id}
        role="tabpanel"
      >
        <h2 style="font-size:1.1rem; margin-bottom:0.75rem; color:#e8e6e1;">
          {day.label}
        </h2>

        {day.meals.map((meal) => {
          const emoji = mealEmoji[meal.name] || "🍽️";
          const mainOption = meal.options[0];
          const altOptions = meal.options.slice(1);
          const altCount = altOptions.length;

          return (
            <div class="meal-card">
              <div class="meal-header">
                <span class="emoji">{emoji}</span>
                {meal.name}
                {mainOption.oil && (
                  <span class:list={["oil-badge", { "no-oil": mainOption.oil.toLowerCase().includes("no") }]}>
                    {mainOption.oil}
                  </span>
                )}
              </div>

              <ul class="meal-items">
                {mainOption.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>

              {altCount > 0 && (
                <details class="alternatives">
                  <summary>
                    {altCount === 1 ? "1 alternativa" : `${altCount} alternative`}
                  </summary>
                  {altOptions.map((opt, j) => (
                    <div class="alt-option">
                      {altCount > 1 && (
                        <div class="alt-label">Opzione {j + 2}</div>
                      )}
                      {opt.oil && opt.oil !== mainOption.oil && (
                        <span class:list={["oil-badge", { "no-oil": opt.oil.toLowerCase().includes("no") }]} style="margin-bottom:0.3rem; display:inline-block;">
                          {opt.oil}
                        </span>
                      )}
                      <ul class="meal-items">
                        {opt.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </details>
              )}
            </div>
          );
        })}
      </div>
    ))}

    <div class="day-content" data-panel="snacks" role="tabpanel">
      <h2 style="font-size:1.1rem; margin-bottom:0.75rem; color:#e8e6e1;">
        Spuntini
      </h2>

      {snacks.map((section) => (
        <div class="meal-card snack-section">
          <div class="meal-header">
            <span class="emoji">🍎</span>
            {section.name}
          </div>
          <div>
            {section.options.map((items, i) => (
              <div class="snack-option">
                <span class="snack-num">{i + 1}.</span>
                {items.join(" + ")}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <script is:inline>
      var dayMap = ['dom','lun','mar','mer','gio','ven','sab'];
      var todayId = dayMap[new Date().getDay()];

      function selectTab(id) {
        document.querySelectorAll('.day-tab').forEach(function(t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.day-content').forEach(function(p) { p.classList.remove('active'); });
        var tab = document.querySelector('[data-day="' + id + '"]');
        var panel = document.querySelector('[data-panel="' + id + '"]');
        if (tab) { tab.classList.add('active'); tab.setAttribute('aria-selected', 'true'); }
        if (panel) panel.classList.add('active');
      }

      selectTab(todayId);

      document.querySelectorAll('.day-tab').forEach(function(tab) {
        tab.addEventListener('click', function() { selectTab(tab.dataset.day); });
      });
    </script>
  </body>
</html>
