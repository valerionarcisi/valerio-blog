---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import { days, snacks } from "~/data/meal-plan";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

import { Icon } from "astro-icon/components";

const mealIconName: Record<string, string> = {
  "Colazione": "ph:coffee",
  "Pranzo": "ph:bowl-food",
  "Cena": "ph:bowl-steam",
  "Cena (libera)": "ph:pizza",
  "Spuntino": "ph:carrot",
};
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Piano Alimentare</title>
    <style is:global>
      .foglio body.admin .day-tabs {
        display: flex;
        gap: 0.4rem;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 0.5rem;
        margin-bottom: 1rem;
        scrollbar-width: none;
      }
      .foglio body.admin .day-tabs::-webkit-scrollbar { display: none; }

      .foglio body.admin .day-tab {
        flex-shrink: 0;
        padding: 0.45rem 0.9rem;
        border-radius: var(--foglio-radius-sm);
        border: 1px solid var(--foglio-rule);
        background: var(--foglio-paper);
        color: var(--foglio-ink-soft);
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
      }
      .foglio body.admin .day-tab:hover { border-color: var(--foglio-accent); color: var(--foglio-accent); }
      .foglio body.admin .day-tab.active {
        background: var(--foglio-accent);
        color: var(--foglio-paper);
        border-color: var(--foglio-accent);
        font-weight: 700;
      }

      .foglio body.admin .day-content { display: none; }
      .foglio body.admin .day-content.active { display: block; }

      .foglio body.admin .meal-card {
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-md);
        padding: 1rem;
        margin-bottom: 0.75rem;
      }

      .foglio body.admin .meal-header {
        font-family: var(--foglio-serif);
        font-weight: 500;
        font-size: var(--foglio-fs-md);
        color: var(--foglio-ink);
        margin-bottom: 0.6rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--foglio-rule);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .foglio body.admin .meal-header .meal-icon { width: 1.2rem; height: 1.2rem; color: var(--foglio-accent); flex-shrink: 0; }

      .foglio body.admin .oil-badge {
        display: inline-block;
        font-family: var(--foglio-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1px solid rgba(46, 139, 87, 0.5);
        color: #2e8b57;
        padding: 0.1rem 0.5rem;
        border-radius: 2px;
        margin-left: auto;
        white-space: nowrap;
      }
      .foglio body.admin .oil-badge.no-oil {
        border-color: rgba(192, 57, 43, 0.5);
        color: #c0392b;
      }

      .foglio body.admin .meal-items {
        list-style: none;
        padding: 0;
      }
      .foglio body.admin .meal-items li {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.55;
        padding: 0.2rem 0 0.2rem 1rem;
        position: relative;
        color: var(--foglio-ink-soft);
      }
      .foglio body.admin .meal-items li::before {
        content: "·";
        position: absolute;
        left: 0.25rem;
        color: var(--foglio-accent);
        font-weight: 700;
      }

      .foglio body.admin details.alternatives {
        margin-top: 0.5rem;
        border-top: 1px solid var(--foglio-rule);
        padding-top: 0.5rem;
      }
      .foglio body.admin details.alternatives summary {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--foglio-accent);
        cursor: pointer;
        user-select: none;
        padding: 0.25rem 0;
        list-style: none;
      }
      .foglio body.admin details.alternatives summary::-webkit-details-marker { display: none; }
      .foglio body.admin details.alternatives summary::before { content: "▸ "; display: inline; }
      .foglio body.admin details.alternatives[open] summary::before { content: "▾ "; }

      .foglio body.admin .alt-option {
        padding: 0.5rem 0;
        border-bottom: 1px dashed var(--foglio-rule);
      }
      .foglio body.admin .alt-option:last-child { border-bottom: none; }

      .foglio body.admin .alt-label {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 600;
        color: var(--foglio-ink-mute);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 0.25rem;
      }

      .foglio body.admin .snack-section { margin-bottom: 1rem; }
      .foglio body.admin .snack-option {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.5;
        padding: 0.4rem 0.5rem;
        color: var(--foglio-ink-soft);
      }
      .foglio body.admin .snack-option:nth-child(odd) {
        background: var(--foglio-paper-2);
        border-radius: var(--foglio-radius-sm);
      }
      .foglio body.admin .snack-option .snack-num {
        font-family: var(--foglio-mono);
        color: var(--foglio-accent);
        font-size: var(--foglio-fs-mono);
        margin-right: 0.4rem;
      }

      @media (max-width: 500px) {
        .foglio body.admin .meal-card { padding: 0.75rem; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="meal-plan" token={token} />

    <h1><em class="acc">Piano alimentare.</em></h1>

    <div class="day-tabs" role="tablist">
      {days.map((day) => (
        <button
          class="day-tab"
          data-day={day.id}
          role="tab"
          aria-selected="false"
        >
          {day.short}
        </button>
      ))}
      <button class="day-tab" data-day="snacks" role="tab" aria-selected="false">
        Spuntini
      </button>
    </div>

    {days.map((day) => (
      <div
        class="day-content"
        data-panel={day.id}
        role="tabpanel"
      >
        <h2 style="margin-bottom:0.75rem;">
          {day.label}
        </h2>

        {day.meals.map((meal) => {
          const iconName = mealIconName[meal.name] || "ph:fork-knife";
          const mainOption = meal.options[0];
          const altOptions = meal.options.slice(1);
          const altCount = altOptions.length;

          return (
            <div class="meal-card">
              <div class="meal-header">
                <Icon name={iconName} class="meal-icon" size={20} is:inline />
                {meal.name}
                {mainOption.oil && (
                  <span class:list={["oil-badge", { "no-oil": mainOption.oil.toLowerCase().includes("no") }]}>
                    {mainOption.oil}
                  </span>
                )}
              </div>

              <ul class="meal-items">
                {mainOption.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>

              {altCount > 0 && (
                <details class="alternatives">
                  <summary>
                    {altCount === 1 ? "1 alternativa" : `${altCount} alternative`}
                  </summary>
                  {altOptions.map((opt, j) => (
                    <div class="alt-option">
                      {altCount > 1 && (
                        <div class="alt-label">Opzione {j + 2}</div>
                      )}
                      {opt.oil && opt.oil !== mainOption.oil && (
                        <span class:list={["oil-badge", { "no-oil": opt.oil.toLowerCase().includes("no") }]} style="margin-bottom:0.3rem; display:inline-block;">
                          {opt.oil}
                        </span>
                      )}
                      <ul class="meal-items">
                        {opt.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </details>
              )}
            </div>
          );
        })}
      </div>
    ))}

    <div class="day-content" data-panel="snacks" role="tabpanel">
      <h2 style="margin-bottom:0.75rem;">
        Spuntini
      </h2>

      {snacks.map((section) => (
        <div class="meal-card snack-section">
          <div class="meal-header">
            <Icon name="ph:carrot" class="meal-icon" size={20} is:inline />
            {section.name}
          </div>
          <div>
            {section.options.map((items, i) => (
              <div class="snack-option">
                <span class="snack-num">{i + 1}.</span>
                {items.join(" + ")}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <script is:inline>
      var dayMap = ['dom','lun','mar','mer','gio','ven','sab'];
      var todayId = dayMap[new Date().getDay()];

      function selectTab(id) {
        document.querySelectorAll('.day-tab').forEach(function(t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.day-content').forEach(function(p) { p.classList.remove('active'); });
        var tab = document.querySelector('[data-day="' + id + '"]');
        var panel = document.querySelector('[data-panel="' + id + '"]');
        if (tab) { tab.classList.add('active'); tab.setAttribute('aria-selected', 'true'); }
        if (panel) panel.classList.add('active');
      }

      selectTab(todayId);

      document.querySelectorAll('.day-tab').forEach(function(tab) {
        tab.addEventListener('click', function() { selectTab(tab.dataset.day); });
      });
    </script>
  </body>
</html>
