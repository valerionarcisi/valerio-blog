      function renderOsChart(data) {
        if (!data || !data.length) return;
        var top5 = data.slice(0, 5);
        var labels = top5.map(function(d) { return d.os || "unknown"; });
        var values = top5.map(function(d) { return Number(d.visitors); });
        var barColors = ["#4ecdc4", "#c9a84c", "#e74c3c", "#9b59b6", "#3498db"];

