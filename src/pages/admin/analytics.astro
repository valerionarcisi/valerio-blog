---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Analytics · Admin</title>
    <style is:global>
      /* Dark page chrome, cream Foglio surfaces */
      :root {
        --ax-page-bg: #131210;
        --ax-page-bg-2: #1c1a16;
        --ax-page-rule: #2e2a23;
        --ax-page-ink: #f4f1e8;
        --ax-page-ink-soft: rgba(255,255,255,0.86);
        --ax-page-ink-mute: rgba(255,255,255,0.66);
        --ax-pos: #2e8b57;
        --ax-neg: #c0392b;
        --ax-cyan: #00b4a6;
      }

      .foglio,
      .foglio body.admin {
        background: var(--ax-page-bg);
        color: var(--ax-page-ink);
        padding: 0;
      }

      .foglio body.admin .ax-wrap {
        padding: 1.25rem 1rem 3rem;
        max-width: 100%;
      }

      /* Header */
      .foglio body.admin .ax-head {
        border-bottom: 1px solid var(--ax-page-rule);
        padding-bottom: 1.25rem;
        margin-bottom: 1.5rem;
      }
      .foglio body.admin .ax-eyebrow {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ax-page-ink-soft);
        margin: 0 0 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.7rem;
        flex-wrap: wrap;
      }
      .foglio body.admin .ax-live {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.18rem 0.55rem;
        border: 1px solid var(--foglio-accent);
        border-radius: 999px;
        color: var(--foglio-accent);
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .foglio body.admin .ax-live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--foglio-accent); animation: ax-pulse 2s ease-in-out infinite; }
      @keyframes ax-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

      /* Page title — serif italic, like comments */
      .foglio body.admin .ax-head h1 {
        font-family: var(--foglio-serif);
        font-weight: 500;
        font-size: var(--foglio-fs-3xl);
        letter-spacing: -0.01em;
        line-height: 1.1;
        color: var(--ax-page-ink);
        margin: 0;
      }
      .foglio body.admin .ax-head h1 em.acc,
      .foglio body.admin .ax-head h1 .acc {
        color: var(--foglio-accent-soft);
        font-style: italic;
      }

      /* Controls — period pills on dark */
      .foglio body.admin .ax-controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--foglio-mono);
        font-size: 11px;
        margin-top: 1rem;
      }
      .foglio body.admin .ax-periods {
        display: inline-flex;
        gap: 0;
        border: 1px solid var(--ax-page-rule);
        border-radius: var(--foglio-radius-sm);
        padding: 3px;
        background: var(--ax-page-bg-2);
        flex-wrap: wrap;
      }
      .foglio body.admin .ax-periods button {
        padding: 0.4rem 0.8rem;
        background: transparent;
        border: none;
        color: var(--ax-page-ink-soft);
        cursor: pointer;
        border-radius: var(--foglio-radius-sm);
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.15s, background 0.15s;
      }
      .foglio body.admin .ax-periods button:hover { color: var(--foglio-paper); background: rgba(255,255,255,0.04); }
      .foglio body.admin .ax-periods button.active { background: var(--foglio-accent); color: var(--foglio-paper); }

      .foglio body.admin .ax-navstrip {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--ax-page-rule);
        border-radius: var(--foglio-radius-sm);
        overflow: hidden;
        background: var(--ax-page-bg-2);
      }
      .foglio body.admin .ax-navstrip button {
        background: transparent;
        border: none;
        padding: 0.35rem 0.55rem;
        color: var(--ax-page-ink-soft);
        cursor: pointer;
        font-size: 12px;
      }
      .foglio body.admin .ax-navstrip button:hover:not(:disabled) { color: var(--foglio-accent-soft); }
      .foglio body.admin .ax-navstrip button:disabled { opacity: 0.3; cursor: not-allowed; }
      .foglio body.admin .ax-navstrip .ax-cal-label {
        padding: 0.35rem 0.65rem;
        border-left: 1px solid var(--ax-page-rule);
        border-right: 1px solid var(--ax-page-rule);
        color: var(--ax-page-ink);
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        cursor: pointer;
        white-space: nowrap;
      }

      .foglio body.admin .ax-daterange { display: none; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
      .foglio body.admin .ax-daterange.open { display: inline-flex; }
      .foglio body.admin .ax-daterange input[type="date"] {
        font-family: var(--foglio-mono);
        font-size: 11px;
        padding: 0.3rem 0.45rem;
        background: var(--ax-page-bg-2);
        border: 1px solid var(--ax-page-rule);
        border-radius: var(--foglio-radius-sm);
        color: var(--ax-page-ink);
        color-scheme: dark;
      }
      .foglio body.admin .ax-daterange button {
        padding: 0.3rem 0.7rem;
        background: var(--foglio-accent);
        color: var(--foglio-paper);
        border: none;
        border-radius: var(--foglio-radius-sm);
        cursor: pointer;
        font-family: var(--foglio-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      /* Stats — cream paper cards on dark page */
      .foglio body.admin .ax-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.6rem;
        margin: 0 0 2rem;
      }
      .foglio body.admin .ax-stat {
        padding: 0.95rem 0.95rem;
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-md);
        position: relative;
        color: var(--foglio-ink);
      }
      .foglio body.admin .ax-stat-label {
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--foglio-ink-soft);
        margin-bottom: 0.55rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .foglio body.admin .ax-stat-info {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 1px solid var(--foglio-rule);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        color: var(--foglio-ink-mute);
        cursor: help;
      }
      .foglio body.admin .ax-stat-value {
        font-family: var(--foglio-serif);
        font-weight: 500;
        font-size: 1.95rem;
        line-height: 1;
        color: var(--foglio-ink);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
      }
      .foglio body.admin .ax-stat-value.acc { color: var(--foglio-accent); font-style: italic; }
      .foglio body.admin .ax-stat-delta {
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 0.5rem;
        color: var(--foglio-ink-mute);
      }
      .foglio body.admin .ax-stat-delta.up { color: var(--ax-pos); }
      .foglio body.admin .ax-stat-delta.down { color: var(--ax-neg); }
      .foglio body.admin .ax-stat-tooltip {
        display: none;
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        z-index: 5;
        background: var(--foglio-paper-2);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-sm);
        padding: 0.6rem 0.8rem;
        font-family: var(--foglio-mono);
        font-size: 11px;
        color: var(--foglio-ink-soft);
        line-height: 1.4;
        box-shadow: var(--foglio-shadow);
      }
      .foglio body.admin .ax-stat:hover .ax-stat-tooltip { display: block; }
      .foglio body.admin .ax-stat.suspect { border-color: rgba(192, 57, 43, 0.45); background: var(--foglio-paper); }
      .foglio body.admin .ax-stat.suspect .ax-stat-value { color: var(--ax-neg); }
      .foglio body.admin .ax-flag-btn {
        margin-top: 0.55rem;
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.3rem 0.6rem;
        background: var(--ax-neg);
        color: var(--foglio-paper);
        border: none;
        border-radius: var(--foglio-radius-sm);
        cursor: pointer;
        display: none;
      }
      .foglio body.admin .ax-flag-btn:hover { background: #a02d20; }

      /* Section heads — serif italic, like comments card-title */
      .foglio body.admin .ax-section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin: 2rem 0 0.9rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--ax-page-rule);
      }
      .foglio body.admin .ax-section-head h2 {
        font-family: var(--foglio-serif);
        font-weight: 500;
        font-style: italic;
        font-size: var(--foglio-fs-lg);
        text-transform: none;
        letter-spacing: 0;
        color: var(--foglio-accent-soft);
        margin: 0;
      }
      .foglio body.admin .ax-section-head .ax-section-meta {
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ax-page-ink-mute);
      }

      /* Chart container — cream paper card */
      .foglio body.admin .ax-chart-wrap {
        padding: 1rem;
        min-height: 240px;
        width: 100%;
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-md);
      }
      .foglio body.admin .ax-chart-wrap canvas { width: 100% !important; height: 240px !important; }

      /* Grids */
      .foglio body.admin .ax-grid-2,
      .foglio body.admin .ax-grid-3 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      /* Lists — /visti style: borders only, no card surface, hover accent */
      .foglio body.admin .ax-list { list-style: none; margin: 0; padding: 0; }
      .foglio body.admin .ax-list li {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 0.8rem;
        padding: 0.85rem 0.25rem;
        border-bottom: 1px solid var(--ax-page-rule);
        border-left: 2px solid transparent;
        background: transparent;
        font-family: var(--foglio-mono);
        font-size: 13px;
        color: var(--ax-page-ink);
        transition: border-left-color 0.15s, padding-left 0.15s, color 0.15s;
      }
      .foglio body.admin .ax-list li:hover { border-left-color: var(--foglio-accent-soft); padding-left: 0.6rem; }
      .foglio body.admin .ax-list .ax-key { color: var(--ax-page-ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .foglio body.admin .ax-list .ax-key.path { font-family: var(--foglio-mono); color: var(--ax-page-ink); }
      .foglio body.admin .ax-list .ax-val {
        font-family: var(--foglio-mono);
        font-size: 12px;
        color: var(--foglio-accent-soft);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        font-weight: 600;
      }
      .foglio body.admin .ax-list .ax-bar { display: none; }

      .foglio body.admin .ax-empty {
        font-family: var(--foglio-mono);
        font-style: italic;
        color: var(--ax-page-ink-mute);
        padding: 1rem 0.25rem;
        font-size: 12px;
        border-bottom: 1px solid var(--ax-page-rule);
      }

      /* Engaged */
      .foglio body.admin .ax-engaged li { grid-template-columns: 1fr auto; align-items: center; }
      .foglio body.admin .ax-engaged .ax-eng-main { min-width: 0; }
      .foglio body.admin .ax-engaged .ax-eng-main .ax-eng-title {
        font-family: var(--foglio-serif);
        font-size: 14px;
        color: var(--ax-page-ink);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
      }
      .foglio body.admin .ax-engaged .ax-eng-meta {
        font-family: var(--foglio-mono);
        font-size: 10px;
        color: var(--ax-page-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 0.25rem;
      }
      .foglio body.admin .ax-engaged .ax-eng-meta b { font-weight: 600; color: var(--foglio-accent-soft); }
      .foglio body.admin .ax-engaged .ax-eng-pv {
        font-family: var(--foglio-mono);
        font-size: 11px;
        color: var(--ax-cyan);
        white-space: nowrap;
      }

      /* Map */
      .foglio body.admin .ax-map-card {
        margin: 0.5rem 0 0;
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-md);
        padding: 0.6rem;
      }
      .foglio body.admin #world-map {
        height: 280px;
        width: 100%;
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-sm);
        background: var(--ax-page-bg-2);
      }
      .foglio body.admin .ax-map-legend {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-top: 0.6rem;
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--foglio-ink-soft);
      }
      .foglio body.admin .ax-map-legend-bar {
        width: 120px;
        height: 6px;
        border-radius: 3px;
        background: linear-gradient(90deg, var(--foglio-paper-2), var(--foglio-accent));
      }
      .leaflet-container { background: var(--ax-page-bg-2) !important; font-family: var(--foglio-mono) !important; }
      .leaflet-control-zoom a { background: var(--foglio-paper) !important; color: var(--foglio-ink) !important; border-color: var(--foglio-rule) !important; }
      .leaflet-control-zoom a:hover { background: var(--foglio-paper-2) !important; color: var(--foglio-accent) !important; }
      .ax-map-tip {
        background: var(--foglio-paper) !important;
        border: 1px solid var(--foglio-rule) !important;
        color: var(--foglio-ink) !important;
        padding: 0.4rem 0.6rem !important;
        font-family: var(--foglio-mono) !important;
        font-size: 11px !important;
        box-shadow: var(--foglio-shadow) !important;
        border-radius: var(--foglio-radius-sm) !important;
      }
      .ax-map-tip b { color: var(--foglio-accent); }

      /* Recent visitors — featured live feed card */
      .foglio body.admin .ax-section-head--live {
        margin-top: 0.5rem;
        padding-bottom: 0.4rem;
        border-bottom: none;
      }
      .foglio body.admin .ax-section-head--live h2 {
        font-size: var(--foglio-fs-xl);
        font-style: italic;
        color: var(--foglio-accent);
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
      }
      .foglio body.admin .ax-section-head--live h2 .ax-live-dot {
        width: 9px;
        height: 9px;
        background: #2e8b57;
        box-shadow: 0 0 0 0 rgba(46, 139, 87, 0.55);
        animation: ax-live-pulse-lg 2.4s ease-out infinite;
        position: relative;
        top: 1px;
      }
      @keyframes ax-live-pulse-lg {
        0%   { box-shadow: 0 0 0 0    rgba(46, 139, 87, 0.55); }
        70%  { box-shadow: 0 0 0 12px rgba(46, 139, 87, 0); }
        100% { box-shadow: 0 0 0 0    rgba(46, 139, 87, 0); }
      }
      .foglio body.admin .ax-recent-card {
        background: var(--ax-page-bg-2);
        border: 1px solid var(--ax-page-rule);
        border-left: 3px solid var(--foglio-accent);
        border-radius: var(--foglio-radius-md);
        padding: 0.5rem 1.1rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 6px 20px -10px rgba(0,0,0,0.55);
      }
      .foglio body.admin .ax-recent { margin: 0; padding: 0; list-style: none; }
      .foglio body.admin .ax-recent li {
        display: grid;
        grid-template-columns: auto 1fr auto auto;
        gap: 0.85rem;
        align-items: center;
        padding: 0.95rem 0.25rem;
        border-bottom: 1px solid var(--ax-page-rule);
        border-left: 2px solid transparent;
        background: transparent;
        font-family: var(--foglio-mono);
        font-size: 12px;
        color: var(--ax-page-ink);
        transition: border-left-color 0.15s, padding-left 0.15s;
      }
      .foglio body.admin .ax-recent li:last-child { border-bottom: none; }
      .foglio body.admin .ax-recent li:hover { border-left-color: var(--foglio-accent-soft); padding-left: 0.6rem; }
      .foglio body.admin .ax-recent li.flagged { opacity: 0.4; text-decoration: line-through; }
      .foglio body.admin .ax-recent li.suspect { border-left-color: var(--ax-neg); }
      .foglio body.admin .ax-recent .ax-flag { font-size: 1.25rem; line-height: 1; }
      .foglio body.admin .ax-recent .ax-path { color: var(--ax-page-ink); overflow: hidden; min-width: 0; }
      .foglio body.admin .ax-recent .ax-path > :first-child {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
        font-family: var(--foglio-serif);
        font-size: 15px;
        font-weight: 500;
        color: var(--ax-page-ink);
      }
      .foglio body.admin .ax-recent .ax-meta {
        color: var(--ax-page-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        display: block;
        margin-top: 0.25rem;
        font-size: 10.5px;
        white-space: normal;
        font-family: var(--foglio-mono);
      }
      .foglio body.admin .ax-recent .ax-time {
        color: var(--ax-page-ink-mute);
        white-space: nowrap;
        font-size: 11.5px;
        font-variant-numeric: tabular-nums;
      }
      .foglio body.admin .ax-recent .ax-bot {
        background: transparent;
        border: 1px solid var(--ax-page-rule);
        border-radius: var(--foglio-radius-sm);
        padding: 0.25rem 0.45rem;
        cursor: pointer;
        color: var(--ax-page-ink-mute);
        font-size: 12px;
        transition: all 0.15s;
      }
      .foglio body.admin .ax-recent .ax-bot:hover { border-color: var(--ax-neg); color: var(--ax-neg); }

      .foglio body.admin .ax-bulk-flag {
        font-family: var(--foglio-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.35rem 0.7rem;
        background: transparent;
        color: var(--ax-neg);
        border: 1px solid var(--ax-neg);
        border-radius: var(--foglio-radius-sm);
        cursor: pointer;
        display: none;
      }
      .foglio body.admin .ax-bulk-flag:hover { background: var(--ax-neg); color: var(--foglio-paper); }

      .foglio body.admin .ax-loading,
      .foglio body.admin .ax-error {
        font-family: var(--foglio-mono);
        font-style: italic;
        padding: 1.2rem 0.25rem;
        color: var(--ax-page-ink-mute);
        text-align: center;
        font-size: 12px;
      }
      .foglio body.admin .ax-error { color: var(--ax-neg); }

      /* Tablet */
      @media (min-width: 768px) {
        .foglio body.admin .ax-wrap { padding: 1.75rem 1.75rem 4rem; }
        .foglio body.admin .ax-head h1 { font-size: var(--foglio-fs-4xl); }
        .foglio body.admin .ax-stats { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
        .foglio body.admin .ax-stat-value { font-size: 2.2rem; }
        .foglio body.admin .ax-grid-2 { grid-template-columns: 1fr 1fr; gap: 2rem; }
        .foglio body.admin .ax-grid-3 { grid-template-columns: 1fr 1fr; gap: 2rem; }
        .foglio body.admin #world-map { height: 360px; }
        .foglio body.admin .ax-chart-wrap canvas { height: 280px !important; }

        .foglio body.admin .ax-list li {
          grid-template-columns: 1fr auto 80px;
          padding: 0.7rem 0.25rem;
        }
        .foglio body.admin .ax-list .ax-bar {
          display: block;
          width: 80px;
          height: 2px;
          background: var(--ax-page-rule);
          overflow: hidden;
          align-self: center;
        }
        .foglio body.admin .ax-list .ax-bar-fill { display: block; height: 100%; background: var(--foglio-accent); }
        .foglio body.admin .ax-engaged li { grid-template-columns: 1fr auto; }
        .foglio body.admin .ax-recent li { grid-template-columns: auto 1fr auto auto; }
      }

      /* Desktop */
      @media (min-width: 1024px) {
        .foglio body.admin .ax-wrap { padding: 2rem 2.5rem 5rem; max-width: 1400px; }
        .foglio body.admin .ax-head h1 { font-size: var(--foglio-fs-5xl); }
        .foglio body.admin .ax-stats { grid-template-columns: repeat(6, 1fr); }
        .foglio body.admin .ax-grid-3 { grid-template-columns: 1fr 1fr 1fr; gap: 2.5rem; }
        .foglio body.admin #world-map { height: 420px; }
        .foglio body.admin .ax-chart-wrap canvas { height: 320px !important; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="analytics" token={token} />

    <div class="ax-wrap">
      <header class="ax-head">
        <p class="ax-eyebrow">
          <span>Admin · Analytics</span>
