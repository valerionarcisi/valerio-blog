      function renderReferrersChart(data) {
        if (!data || !data.length) return;
        var top5 = data.slice(0, 5);
        var others = data.slice(5).reduce(function(sum, r) { return sum + Number(r.visitors); }, 0);
        var labels = top5.map(function(d) { return d.referrer || "Direct"; });
        var values = top5.map(function(d) { return Number(d.visitors); });
        if (others > 0) { labels.push("Other"); values.push(others); }

        var ctx = document.getElementById("referrers-chart").getContext("2d");
        referrersChart = new Chart(ctx, {
          type: "doughnut",
          data: { labels: labels, datasets: [{ data: values, backgroundColor: CHART_COLORS.referrers.slice(0, values.length), borderColor: "#111113", borderWidth: 2 }] },
          options: {
            responsive: true, cutout: "55%",
            plugins: { legend: { position: "bottom", labels: { color: "#8a8a8e", font: { size: 11 }, padding: 12, usePointStyle: true, pointStyle: "circle" } }, tooltip: DOUGHNUT_TOOLTIP }
          }
        });
      }

      var leafletMap = null;
      var geoLayer = null;
      var GEOJSON_URL = "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-50m.json";
      var _topoCache = null;

      function getMapColor(val, maxVal) {
        if (!val || !maxVal) return "#1a1b1e";
        var t = Math.max(0.15, val / maxVal);
        var r = Math.round(26 + (78 - 26) * t);
        var g = Math.round(27 + (205 - 27) * t);
        var b = Math.round(30 + (196 - 30) * t);
        return "rgb(" + r + "," + g + "," + b + ")";
      }

      // ISO 3166-1 numeric → Alpha-2 mapping (countries we track)
      var NUM_TO_ALPHA2 = {"840":"US","124":"CA","076":"BR","484":"MX","032":"AR","826":"GB","250":"FR","276":"DE","724":"ES","380":"IT","620":"PT","528":"NL","056":"BE","756":"CH","040":"AT","616":"PL","203":"CZ","752":"SE","578":"NO","246":"FI","208":"DK","372":"IE","642":"RO","348":"HU","300":"GR","100":"BG","804":"UA","643":"RU","792":"TR","392":"JP","410":"KR","156":"CN","356":"IN","036":"AU","554":"NZ","682":"SA","784":"AE","818":"EG","710":"ZA","566":"NG","376":"IL","404":"KE","360":"ID","702":"SG","764":"TH","704":"VN","608":"PH","586":"PK","458":"MY","170":"CO","152":"CL","604":"PE","862":"VE","191":"HR","705":"SI","703":"SK","688":"RS","233":"EE","428":"LV","440":"LT","442":"LU","470":"MT","050":"BD","364":"IR","504":"MA"};

      function initLeafletMap() {
        if (leafletMap) return;
        leafletMap = L.map("world-map", {
          center: [30, 10],
          zoom: 2,
          minZoom: 1,
          maxZoom: 6,
          zoomControl: true,
          attributionControl: false,
          scrollWheelZoom: true
        });
        L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", {
          subdomains: "abcd",
          maxZoom: 6
        }).addTo(leafletMap);
      }

      function renderWorldMap(countries) {
        initLeafletMap();
        var countryMap = {};
        var maxVal = 0;
        (countries || []).forEach(function(c) {
          var v = Number(c.visitors) || 0;
          if (c.country) { countryMap[c.country] = v; if (v > maxVal) maxVal = v; }
        });
        document.getElementById("map-max-label").textContent = maxVal > 0 ? fmt(maxVal) : "0";

        if (geoLayer) { leafletMap.removeLayer(geoLayer); geoLayer = null; }

        function applyGeo(topoData) {
          // topojson → geojson conversion (inline, no extra lib)
          var objects = topoData.objects;
          var key = Object.keys(objects)[0];
          var geometries = objects[key].geometries;
          var arcs = topoData.arcs;
          var transform = topoData.transform;

          function decodeArc(arcIdx) {
            var reverse = arcIdx < 0;
            var arc = arcs[reverse ? ~arcIdx : arcIdx];
            var coords = [];
            var x = 0, y = 0;
            for (var i = 0; i < arc.length; i++) {
              x += arc[i][0]; y += arc[i][1];
              var lng = x * transform.scale[0] + transform.translate[0];
              var lat = y * transform.scale[1] + transform.translate[1];
              coords.push([lng, lat]);
            }
            if (reverse) coords.reverse();
            return coords;
          }

          function decodeRing(ring) {
            var coords = [];
            for (var i = 0; i < ring.length; i++) {
              coords = coords.concat(decodeArc(ring[i]));
            }
            return coords;
          }

          var features = geometries.map(function(geom) {
            var id = geom.id || (geom.properties && geom.properties.iso_a2);
            var alpha2 = NUM_TO_ALPHA2[id] || id;
            var coordinates;
            if (geom.type === "Polygon") {
              coordinates = [geom.arcs.map(decodeRing)];
              return { type: "Feature", properties: { code: alpha2 }, geometry: { type: "Polygon", coordinates: coordinates[0].length ? coordinates[0] : [[]] } };
            } else if (geom.type === "MultiPolygon") {
              coordinates = geom.arcs.map(function(polygon) { return polygon.map(decodeRing); });
              return { type: "Feature", properties: { code: alpha2 }, geometry: { type: "MultiPolygon", coordinates: coordinates } };
            }
            return null;
          }).filter(Boolean);

          var geojson = { type: "FeatureCollection", features: features };

          geoLayer = L.geoJSON(geojson, {
            style: function(feature) {
              var code = feature.properties.code;
              var val = countryMap[code] || 0;
              var suspects = _suspectCountries[code] || 0;
              var isSuspect = suspects > 0 && suspects >= val * 0.5;
              return {
                fillColor: isSuspect ? "rgba(231,76,60,0.4)" : getMapColor(val, maxVal),
                weight: isSuspect ? 1.5 : 0.5,
                color: isSuspect ? "#e74c3c" : "#333",
                fillOpacity: val > 0 ? 0.85 : 0.3
              };
            },
            onEachFeature: function(feature, layer) {
              var code = feature.properties.code;
              var val = countryMap[code] || 0;
              var suspects = _suspectCountries[code] || 0;
              if (val > 0 || suspects > 0) {
                var tip = "<b>" + code + "</b> — <span>" + fmt(val) + "</span> visitors";
                if (suspects > 0) {
                  tip += " <span style='color:#e74c3c'>(" + suspects + " sospetti)</span>";
                }
                layer.bindTooltip(tip, { className: "map-info-tooltip", sticky: true });
                var hoverColor = suspects > 0 && suspects >= val * 0.5 ? "#e74c3c" : "#4ecdc4";
                layer.on("mouseover", function(e) {
                  layer.setStyle({ weight: 2, color: hoverColor, fillOpacity: 0.95 });
                  layer.bringToFront();
                });
                layer.on("mouseout", function(e) {
                  geoLayer.resetStyle(layer);
                });
              }
            }
          }).addTo(leafletMap);
        }

        if (_topoCache) {
          applyGeo(_topoCache);
        } else {
          fetch(GEOJSON_URL)
            .then(function(r) { return r.json(); })
            .then(function(data) { _topoCache = data; applyGeo(data); })
            .catch(function() {});
        }
      }

      var PERIOD_DAYS = { "today": 1, "7d": 7, "30d": 30, "90d": 90, "12m": 365 };
      var currentPeriod = "30d";
      var currentFrom = null;
      var currentTo = null;

      function savePeriod(period, from, to) {
        try {
          var state = { period: period };
          if (from) state.from = from;
          if (to) state.to = to;
          localStorage.setItem("_ap", JSON.stringify(state));
        } catch(e) {}
      }

      function loadSavedPeriod() {
        try {
          var raw = localStorage.getItem("_ap");
          if (!raw) return null;
          return JSON.parse(raw);
        } catch(e) { return null; }
      }

      function dateStr(d) { return d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-" + String(d.getDate()).padStart(2, "0"); }

      function fmtCalDate(isoStr) {
        var d = new Date(isoStr + "T00:00:00");
        return d.getDate() + " " + MONTHS_SHORT[d.getMonth()];
      }

      function fmtCalDateFull(isoStr) {
        var d = new Date(isoStr + "T00:00:00");
        return d.getDate() + " " + MONTHS_SHORT[d.getMonth()] + " " + d.getFullYear();
      }

      function updatePeriodLabel() {
        var label = document.getElementById("cal-label");
        if (!currentFrom || !currentTo) { label.textContent = ""; return; }

        var text;
        if (currentFrom === currentTo) {
          var d = new Date(currentFrom + "T00:00:00");
          text = "\ud83d\udcc5 " + DAYS_SHORT[d.getDay()] + " " + fmtCalDateFull(currentFrom);
        } else if (currentPeriod === "12m") {
          var fromD = new Date(currentFrom + "T00:00:00");
          var toD = new Date(currentTo + "T00:00:00");
          text = "\ud83d\udcc5 " + MONTHS_SHORT[fromD.getMonth()] + " " + fromD.getFullYear() + " — " + MONTHS_SHORT[toD.getMonth()] + " " + toD.getFullYear();
        } else {
          var fromYear = currentFrom.slice(0, 4);
          var toYear = currentTo.slice(0, 4);
          if (fromYear === toYear) {
            text = "\ud83d\udcc5 " + fmtCalDate(currentFrom) + " — " + fmtCalDateFull(currentTo);
          } else {
            text = "\ud83d\udcc5 " + fmtCalDateFull(currentFrom) + " — " + fmtCalDateFull(currentTo);
          }
        }
        label.textContent = text;
      }

      function updateNavButtons() {
        var nextBtn = document.getElementById("nav-next");
        var today = dateStr(new Date());
        nextBtn.disabled = !currentTo || currentTo >= today;
      }

      function navigatePeriod(direction) {
        var days = PERIOD_DAYS[currentPeriod] || 30;
        var shift = days * direction;

        var from, to;
        if (currentFrom && currentTo) {
          from = new Date(currentFrom + "T00:00:00");
          to = new Date(currentTo + "T00:00:00");
        } else {
          to = new Date();
          from = new Date(Date.now() - (days - 1) * 86400000);
        }

        from = new Date(from.getTime() + shift * 86400000);
        to = new Date(to.getTime() + shift * 86400000);

        var today = new Date();
        if (to > today) to = today;

        var fromStr = dateStr(from);
        var toStr = dateStr(to);

        document.querySelectorAll(".periods button").forEach(function(b) { b.classList.remove("active"); });
        document.getElementById("date-from").value = fromStr;
        document.getElementById("date-to").value = toStr;

        currentFrom = fromStr;
        currentTo = toStr;
        savePeriod(currentPeriod, fromStr, toStr);
        updatePeriodLabel();
        updateNavButtons();

        loadData("custom&from=" + fromStr + "&to=" + toStr, true);
      }

      function loadData(period, skipSave) {
        var basePeriod = period.split("&")[0];

        if (basePeriod !== "custom") {
          currentPeriod = basePeriod;
          var days = PERIOD_DAYS[basePeriod] || 30;
          currentTo = dateStr(new Date());
          currentFrom = dateStr(new Date(Date.now() - (days - 1) * 86400000));
        } else {
          var match = period.match(/from=(\d{4}-\d{2}-\d{2}).*to=(\d{4}-\d{2}-\d{2})/);
          if (match) {
            currentFrom = match[1];
            currentTo = match[2];
          }
        }

        if (!skipSave) savePeriod(currentPeriod, currentFrom, currentTo);
        updatePeriodLabel();
        updateNavButtons();

        document.querySelectorAll(".periods button").forEach(function(b) {
          b.classList.toggle("active", b.dataset.period === basePeriod);
        });

        fetch("/api/stats?period=" + period, {
          headers: { Authorization: "Bearer " + token }
        })
        .then(function(r) { if (!r.ok) throw new Error("Failed"); return r.json(); })
        .then(function(d) {
          var s = d.summary;
          document.getElementById("s-pageviews").textContent = fmt(s.pageviews);
          document.getElementById("s-visitors").textContent = fmt(s.visitors);
          document.getElementById("s-time").textContent = fmtTime(s.avg_time_on_page);
          document.getElementById("s-scroll").textContent = s.avg_scroll_depth + "%";
          document.getElementById("s-bounce").textContent = s.bounce_rate + "%";

          var suspectN = d.suspicious ? d.suspicious.count : 0;
          document.getElementById("s-suspects").textContent = fmt(suspectN);
          var flagBtn = document.getElementById("flag-suspects-btn");
          flagBtn.style.display = suspectN > 0 ? "block" : "none";
          flagBtn.disabled = false;
          flagBtn.textContent = "\ud83e\udd16 Flag all as bot (" + suspectN + ")";

          _suspectCountries = {};
          if (d.suspicious && d.suspicious.countries) {
            d.suspicious.countries.forEach(function(c) {
              if (c.country) _suspectCountries[c.country] = Number(c.suspects) || 0;
            });
          }

          var groupBy = d.period.groupBy || (period === "today" ? "hour" : period === "12m" ? "month" : "day");
          var rawDates = d.chart.map(function(c) { return c.date; });
          var labels = rawDates.map(function(dt) { return fmtChartLabel(dt, groupBy); });
          var pvData = d.chart.map(function(c) { return Number(c.pageviews); });
          var vData = d.chart.map(function(c) { return Number(c.visitors); });

          if (chartInstance) chartInstance.destroy();
          var ctx = document.getElementById("chart").getContext("2d");
          chartInstance = new Chart(ctx, {
            type: "line",
            data: {
              labels: labels,
              datasets: [
                {
                  label: "Pageviews", data: pvData,
                  borderColor: "#c9a84c", backgroundColor: "rgba(201,168,76,0.08)",
                  fill: true, tension: 0.4, pointRadius: 3, pointHoverRadius: 6,
                  pointBackgroundColor: "#c9a84c", pointBorderColor: "#0a0a0c", pointBorderWidth: 2,
                  borderWidth: 2.5
                },
                {
                  label: "Visitors", data: vData,
                  borderColor: "#4ecdc4", backgroundColor: "rgba(78,205,196,0.05)",
                  fill: true, tension: 0.4, pointRadius: 3, pointHoverRadius: 6,
                  pointBackgroundColor: "#4ecdc4", pointBorderColor: "#0a0a0c", pointBorderWidth: 2,
                  borderWidth: 2.5
                }
              ]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: {
                legend: {
                  labels: { color: "#8a8a8e", font: { size: 11 }, usePointStyle: true, pointStyle: "circle", padding: 16 }
                },
                tooltip: {
                  backgroundColor: "rgba(20,20,22,0.95)",
                  titleColor: "#e8e6e1",
                  bodyColor: "#e8e6e1",
                  borderColor: "rgba(255,255,255,0.1)",
                  borderWidth: 1,
                  cornerRadius: 6,
                  padding: 10,
                  titleFont: { size: 12, weight: "600" },
                  bodyFont: { size: 12 },
                  displayColors: true,
                  boxPadding: 4,
                  callbacks: {
                    title: function(items) {
                      var idx = items[0].dataIndex;
                      return fmtTooltipTitle(rawDates[idx], groupBy);
                    }
                  }
                }
              },
              scales: {
                x: {
                  ticks: { color: "#8a8a8e", font: { size: 10 }, maxRotation: 45, minRotation: 0, maxTicksLimit: 14, autoSkip: true },
                  grid: { color: "rgba(255,255,255,0.03)", drawTicks: false },
                  border: { color: "rgba(255,255,255,0.06)" }
                },
                y: {
                  ticks: { color: "#8a8a8e", font: { size: 10 }, padding: 8 },
                  grid: { color: "rgba(255,255,255,0.04)", drawTicks: false },
                  border: { display: false },
                  beginAtZero: true
                }
              },
              interaction: { intersect: false, mode: "index" }
            }
          });

          destroyCharts();
          renderWorldMap(d.countries);
          renderDevicesChart(d.devices);
          renderBrowsersChart(d.browsers);
          renderOsChart(d.os);
          renderReferrersChart(d.referrers);

          var utmCard = document.getElementById("utm-table-card");
          var utmHtml = '';
          if (d.utm_sources && d.utm_sources.length) utmHtml += renderTable("UTM Sources", d.utm_sources, "utm_source", "visitors", false);
          if (d.utm_campaigns && d.utm_campaigns.length) utmHtml += renderTable("UTM Campaigns", d.utm_campaigns, "utm_campaign", "visitors", false);
          utmCard.innerHTML = utmHtml || '<div class="table-card"><h3>UTM Sources</h3><div class="loading">No UTM data</div></div>';

          var html = '';
          var trafficHtml = renderTable("Pages", d.top_pages, "pathname", "visitors", true) +
                            renderTable("Countries", d.countries, "country", "visitors", false);
          if (trafficHtml) {
            html += '<div class="section-title">Content & Geo</div><div class="tables-grid">' + trafficHtml + '</div>';
          }

          var langHtml = renderTable("Languages", d.languages, "lang", "visitors", false);
          if (langHtml) {
            html += '<div class="tables-grid compact">' + langHtml + '</div>';
          }

          document.getElementById("tables").innerHTML = html;

          document.getElementById("recent-list").innerHTML = renderRecentVisitors(d.recent_visitors);
        })
        .catch(function(e) {
          var errDiv = document.createElement("div");
          errDiv.className = "error";
          errDiv.textContent = "Failed to load data: " + e.message;
          var tables = document.getElementById("tables");
          tables.textContent = "";
          tables.appendChild(errDiv);
        });
      }

      function loadLive() {
        fetch("/api/stats/live", {
          headers: { Authorization: "Bearer " + token }
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          document.getElementById("live-count").textContent = d.active;
        })
        .catch(function() {});
      }

      document.querySelectorAll(".periods button").forEach(function(b) {
        b.addEventListener("click", function() {
          currentPeriod = b.dataset.period;
          loadData(b.dataset.period);
        });
      });

      document.getElementById("date-go").addEventListener("click", function() {
        var from = document.getElementById("date-from").value;
        var to = document.getElementById("date-to").value;
        if (from && to) {
          currentFrom = from;
          currentTo = to;
          document.querySelectorAll(".periods button").forEach(function(b) { b.classList.remove("active"); });
          document.getElementById("date-range").style.display = "none";
          loadData("custom&from=" + from + "&to=" + to);
        }
      });

      document.getElementById("nav-prev").addEventListener("click", function() { navigatePeriod(-1); });
      document.getElementById("nav-next").addEventListener("click", function() { navigatePeriod(1); });
      document.getElementById("flag-all-bots").addEventListener("click", flagAllBots);

      document.getElementById("flag-suspects-btn").addEventListener("click", function() {
        var btn = document.getElementById("flag-suspects-btn");
        if (!currentFrom || !currentTo) return;
        btn.disabled = true;
        btn.textContent = "Flagging...";
        fetch("/api/admin/bot", {
          method: "POST",
          headers: { Authorization: "Bearer " + token, "Content-Type": "application/json" },
          body: JSON.stringify({ flagSuspicious: true, from: currentFrom, to: currentTo })
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          btn.textContent = d.flagged + " flagged!";
          setTimeout(function() {
            if (currentFrom && currentTo) {
              loadData("custom&from=" + currentFrom + "&to=" + currentTo, true);
            } else {
              loadData(currentPeriod);
            }
          }, 1000);
        })
        .catch(function() { btn.textContent = "Error"; });
      });

      document.getElementById("cal-label").addEventListener("click", function() {
        var dr = document.getElementById("date-range");
        dr.style.display = dr.style.display === "none" ? "flex" : "none";
      });

      var todayStr = dateStr(new Date());
      document.getElementById("date-to").value = todayStr;
      document.getElementById("date-from").value = dateStr(new Date(Date.now() - 30 * 86400000));

      var saved = loadSavedPeriod();
      if (saved && saved.period) {
        currentPeriod = saved.period;
        if (saved.from && saved.to) {
          currentFrom = saved.from;
          currentTo = saved.to;
          document.getElementById("date-from").value = saved.from;
          document.getElementById("date-to").value = saved.to;
          loadData("custom&from=" + saved.from + "&to=" + saved.to);
        } else {
          loadData(saved.period);
        }
      } else {
        loadData("30d");
      }

      loadLive();
      setInterval(loadLive, 30000);
    </script>
  </body>
</html>
