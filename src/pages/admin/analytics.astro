    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script is:inline define:vars={{ token }}>
      var ADMIN_TOKEN = token;
      var AUTH_HEADERS = { "Authorization": "Bearer " + ADMIN_TOKEN };
      var chartInstance = null;

      var FOGLIO_ACCENT = "#a8451a";
      var FOGLIO_ACCENT_SOFT = "#c8714a";
      var FOGLIO_PAPER = "#fbf7ee";
      var FOGLIO_PAPER_2 = "#f1ebdd";
      var FOGLIO_INK = "#221a12";
      var FOGLIO_INK_SOFT = "#5e4d3a";
      var FOGLIO_RULE = "#d8cebd";
      var CYAN = "#00b4a6";

      function fmt(n) { n = Number(n) || 0; return n >= 1000 ? (n / 1000).toFixed(1) + "k" : String(n); }
      function fmtTime(s) { s = Number(s) || 0; return s >= 60 ? Math.floor(s / 60) + "m " + (s % 60) + "s" : s + "s"; }
      function escapeHtml(s) { var d = document.createElement("div"); d.appendChild(document.createTextNode(String(s))); return d.innerHTML; }

      var DAYS_SHORT = ["Dom", "Lun", "Mar", "Mer", "Gio", "Ven", "Sab"];
      var MONTHS_SHORT = ["Gen", "Feb", "Mar", "Apr", "Mag", "Giu", "Lug", "Ago", "Set", "Ott", "Nov", "Dic"];

      function fmtChartLabel(dateStr, groupBy) {
        if (groupBy === "hour") return dateStr.slice(11, 16);
        if (groupBy === "month") { var p = dateStr.split("-"); return MONTHS_SHORT[parseInt(p[1], 10) - 1] + " " + p[0].slice(2); }
        var d = new Date(dateStr + "T00:00:00");
        return DAYS_SHORT[d.getDay()] + " " + d.getDate() + " " + MONTHS_SHORT[d.getMonth()];
      }
      function fmtTooltipTitle(dateStr, groupBy) {
        if (groupBy === "hour") return dateStr;
        if (groupBy === "month") { var p = dateStr.split("-"); return MONTHS_SHORT[parseInt(p[1], 10) - 1] + " " + p[0]; }
        var d = new Date(dateStr + "T00:00:00");
        return DAYS_SHORT[d.getDay()] + " " + d.getDate() + " " + MONTHS_SHORT[d.getMonth()] + " " + d.getFullYear();
      }
      function dateStr(d) { return d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-" + String(d.getDate()).padStart(2, "0"); }

      function fmtCalDate(iso) { var d = new Date(iso + "T00:00:00"); return d.getDate() + " " + MONTHS_SHORT[d.getMonth()]; }
      function fmtCalDateFull(iso) { var d = new Date(iso + "T00:00:00"); return d.getDate() + " " + MONTHS_SHORT[d.getMonth()] + " " + d.getFullYear(); }

      function setDelta(el, pct) {
        if (pct == null) { el.textContent = ""; el.className = "ax-stat-delta"; return; }
        var prefix = pct > 0 ? "▲ " : pct < 0 ? "▼ " : "= ";
        el.textContent = prefix + Math.abs(pct).toFixed(1) + "% vs periodo prec.";
        el.className = "ax-stat-delta " + (pct > 0 ? "up" : pct < 0 ? "down" : "");
      }

      function renderListRows(rows, keyField, valueField, isPath, ulId, emptyMsg) {
        var ul = document.getElementById(ulId);
        if (!ul) return;
        if (!rows || !rows.length) { ul.innerHTML = '<li class="ax-empty">' + (emptyMsg || "Nessun dato.") + '</li>'; return; }
        var max = Number(rows[0][valueField]) || 1;
        ul.innerHTML = rows.map(function(r) {
          var key = r[keyField] != null && r[keyField] !== "" ? r[keyField] : "(diretto)";
          var val = Number(r[valueField]) || 0;
          var pct = Math.round(val / max * 100);
          return '<li>' +
            '<span class="ax-key' + (isPath ? ' path' : '') + '" title="' + escapeHtml(key) + '">' + escapeHtml(key) + '</span>' +
            '<span class="ax-val">' + fmt(val) + '</span>' +
            '<span class="ax-bar"><span class="ax-bar-fill" style="width:' + pct + '%"></span></span>' +
            '</li>';
        }).join("");
      }

      function renderEngaged(rows) {
        var ul = document.getElementById("engaged-list");
        if (!rows || !rows.length) { ul.innerHTML = '<li class="ax-empty">Nessun post con dati di engagement nel periodo.</li>'; return; }
        ul.innerHTML = rows.map(function(r) {
          var t = Number(r.avg_time) || 0;
          var s = Number(r.avg_scroll) || 0;
          var pv = Number(r.pageviews) || 0;
          return '<li>' +
            '<div class="ax-eng-main">' +
              '<span class="ax-eng-title" title="' + escapeHtml(r.pathname) + '">' + escapeHtml(r.pathname) + '</span>' +
              '<span class="ax-eng-meta"><b>' + fmtTime(t) + '</b> · scroll <b>' + s + '%</b></span>' +
            '</div>' +
            '<span class="ax-eng-pv">' + pv + ' pv</span>' +
            '</li>';
        }).join("");
      }

      var COUNTRY_FLAGS = {"IT":"🇮🇹","GB":"🇬🇧","FR":"🇫🇷","DE":"🇩🇪","ES":"🇪🇸","US":"🇺🇸","NL":"🇳🇱","BE":"🇧🇪","CH":"🇨🇭","AT":"🇦🇹","PT":"🇵🇹","PL":"🇵🇱","CZ":"🇨🇿","HU":"🇭🇺","RO":"🇷🇴","BG":"🇧🇬","GR":"🇬🇷","FI":"🇫🇮","SE":"🇸🇪","NO":"🇳🇴","DK":"🇩🇰","IE":"🇮🇪","UA":"🇺🇦","RU":"🇷🇺","TR":"🇹🇷","JP":"🇯🇵","KR":"🇰🇷","CN":"🇨🇳","IN":"🇮🇳","BR":"🇧🇷","CA":"🇨🇦","AU":"🇦🇺","MX":"🇲🇽","AR":"🇦🇷","EG":"🇪🇬","ZA":"🇿🇦","NZ":"🇳🇿","SG":"🇸🇬","AE":"🇦🇪","SA":"🇸🇦","IL":"🇮🇱"};
      function countryFlag(c) { return c && COUNTRY_FLAGS[c] ? COUNTRY_FLAGS[c] : "🌐"; }
      function deviceIcon(t) { return t === "mobile" ? "📱" : t === "tablet" ? "📋" : "💻"; }

      function timeAgo(dateStr) {
        var diff = Math.floor((new Date() - new Date(dateStr)) / 1000);
        if (diff < 60) return "ora";
        if (diff < 3600) return Math.floor(diff / 60) + "m";
        if (diff < 86400) return Math.floor(diff / 3600) + "h";
        var d = Math.floor(diff / 86400);
        return d === 1 ? "ieri" : d + "g";
      }

      var _lastVisitors = [];
      var _suspectCountries = {};

      function flagAsBot(hash, btn) {
        var row = btn.closest("li");
        btn.disabled = true;
        fetch("/api/admin/bot", { method: "POST", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + ADMIN_TOKEN }, body: JSON.stringify({ hash: hash }) })
          .then(function(r) {
            btn.disabled = false;
            if (!r.ok) return;
            row.classList.add("flagged");
            btn.textContent = "↺";
            btn.title = "Annulla flag bot";
            btn.onclick = function() { unflagAsBot(hash, btn); };
          });
      }
      function unflagAsBot(hash, btn) {
        var row = btn.closest("li");
        btn.disabled = true;
        fetch("/api/admin/bot", { method: "DELETE", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + ADMIN_TOKEN }, body: JSON.stringify({ hash: hash }) })
          .then(function(r) {
            btn.disabled = false;
            if (!r.ok) return;
            row.classList.remove("flagged");
            btn.textContent = "🤖";
            btn.title = "Flag come bot";
            btn.onclick = function() { flagAsBot(hash, btn); };
          });
      }
      window.flagAsBot = flagAsBot;
      window.unflagAsBot = unflagAsBot;

      function flagAllBots() {
        var hashes = [];
        _lastVisitors.forEach(function(v) {
          if (!v.visitor_hash) return;
          var noTime = v.time_on_page == null || Number(v.time_on_page) <= 5;
          var noScroll = v.scroll_depth == null || Number(v.scroll_depth) === 0;
          if (noTime && noScroll) hashes.push(v.visitor_hash);
        });
        if (!hashes.length) return;
        var btn = document.getElementById("flag-all-bots");
        btn.disabled = true; btn.textContent = "Flagging…";
        fetch("/api/admin/bot", { method: "POST", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + ADMIN_TOKEN }, body: JSON.stringify({ hashes: hashes }) })
          .then(function(r) { return r.json(); })
          .then(function(d) { btn.textContent = d.flagged + " flaggati"; });
      }

      function renderRecentVisitors(visitors) {
        _lastVisitors = visitors || [];
        var zero = _lastVisitors.filter(function(v) {
          if (!v.visitor_hash) return false;
          var noTime = v.time_on_page == null || Number(v.time_on_page) <= 5;
          var noScroll = v.scroll_depth == null || Number(v.scroll_depth) === 0;
          return noTime && noScroll;
        }).length;
        var bulk = document.getElementById("flag-all-bots");
        bulk.style.display = zero > 0 ? "inline-block" : "none";
        bulk.disabled = false;
        bulk.textContent = "Flag zero-engagement (" + zero + ")";

        var ul = document.getElementById("recent-list");
        if (!visitors || !visitors.length) { ul.innerHTML = '<li class="ax-loading">Nessun visitatore recente.</li>'; return; }

        ul.innerHTML = visitors.map(function(v) {
          var flag = countryFlag(v.country);
          var page = escapeHtml(v.pathname || "/");
          var device = deviceIcon(v.device_type);
          var browser = escapeHtml(v.browser || "?");
          var os = escapeHtml(v.os || "?");
          var ref = v.referrer ? escapeHtml(v.referrer) : "";
          var time = v.time_on_page != null ? fmtTime(Number(v.time_on_page)) : "";
          var scroll = v.scroll_depth != null ? v.scroll_depth + "%" : "";
          var ago = timeAgo(v.created_at);
          var hash = v.visitor_hash || "";

          var metaParts = [device + " " + browser + " / " + os];
          if (ref) metaParts.push("da " + ref);
          if (time) metaParts.push("⏱ " + time);
          if (scroll) metaParts.push("↓ " + scroll);

          var botBtn = hash ? '<button class="ax-bot" onclick="flagAsBot(\'' + escapeHtml(hash) + '\', this)" title="Flag come bot">🤖</button>' : '';
          var noTime = v.time_on_page == null || Number(v.time_on_page) <= 5;
          var noScroll = v.scroll_depth == null || Number(v.scroll_depth) === 0;
          var suspect = (noTime && noScroll && hash) ? ' suspect' : '';

          return '<li class="' + suspect.trim() + '">' +
            '<span class="ax-flag">' + flag + '</span>' +
            '<span class="ax-path"><span>' + page + '</span><span class="ax-meta">' + metaParts.join(" · ") + '</span></span>' +
            '<span class="ax-time">' + ago + '</span>' +
            botBtn +
            '</li>';
        }).join("");
      }

      /* Map */
      var leafletMap = null;
      var geoLayer = null;
      var GEOJSON_URL = "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-50m.json";
      var _topoCache = null;

      function hexToRgb(hex) {
        var m = hex.replace("#", "").match(/.{2}/g);
        return [parseInt(m[0], 16), parseInt(m[1], 16), parseInt(m[2], 16)];
      }
      var PAPER2_RGB = hexToRgb(FOGLIO_PAPER_2);
      var ACCENT_RGB = hexToRgb(FOGLIO_ACCENT);

      function getMapColor(val, maxVal) {
        if (!val || !maxVal) return "rgba(241,235,221,0.18)";
        var t = Math.max(0.22, val / maxVal);
        var r = Math.round(PAPER2_RGB[0] + (ACCENT_RGB[0] - PAPER2_RGB[0]) * t);
        var g = Math.round(PAPER2_RGB[1] + (ACCENT_RGB[1] - PAPER2_RGB[1]) * t);
        var b = Math.round(PAPER2_RGB[2] + (ACCENT_RGB[2] - PAPER2_RGB[2]) * t);
        return "rgb(" + r + "," + g + "," + b + ")";
      }

      var NUM_TO_ALPHA2 = {"840":"US","124":"CA","076":"BR","484":"MX","032":"AR","826":"GB","250":"FR","276":"DE","724":"ES","380":"IT","620":"PT","528":"NL","056":"BE","756":"CH","040":"AT","616":"PL","203":"CZ","752":"SE","578":"NO","246":"FI","208":"DK","372":"IE","642":"RO","348":"HU","300":"GR","100":"BG","804":"UA","643":"RU","792":"TR","392":"JP","410":"KR","156":"CN","356":"IN","036":"AU","554":"NZ","682":"SA","784":"AE","818":"EG","710":"ZA","566":"NG","376":"IL","404":"KE","360":"ID","702":"SG","764":"TH","704":"VN","608":"PH","586":"PK","458":"MY","170":"CO","152":"CL","604":"PE","862":"VE","191":"HR","705":"SI","703":"SK","688":"RS","233":"EE","428":"LV","440":"LT","442":"LU","470":"MT","050":"BD","364":"IR","504":"MA"};

      function initLeafletMap() {
        if (leafletMap) return;
        leafletMap = L.map("world-map", { center: [30, 10], zoom: 2, minZoom: 1, maxZoom: 6, zoomControl: true, attributionControl: false, scrollWheelZoom: true });
        L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", { subdomains: "abcd", maxZoom: 6 }).addTo(leafletMap);
      }

      function renderWorldMap(countries) {
        initLeafletMap();
        var countryMap = {};
        var maxVal = 0;
        (countries || []).forEach(function(c) {
          var v = Number(c.visitors) || 0;
          if (c.country) { countryMap[c.country] = v; if (v > maxVal) maxVal = v; }
        });
        document.getElementById("map-max-label").textContent = maxVal > 0 ? fmt(maxVal) : "0";
        document.getElementById("geo-meta").textContent = (countries || []).length + " paesi";

        if (geoLayer) { leafletMap.removeLayer(geoLayer); geoLayer = null; }

        function applyGeo(topoData) {
          var objects = topoData.objects;
          var key = Object.keys(objects)[0];
          var geometries = objects[key].geometries;
          var arcs = topoData.arcs;
          var transform = topoData.transform;

          function decodeArc(arcIdx) {
            var reverse = arcIdx < 0;
            var arc = arcs[reverse ? ~arcIdx : arcIdx];
            var coords = [];
            var x = 0, y = 0;
            for (var i = 0; i < arc.length; i++) {
              x += arc[i][0]; y += arc[i][1];
              var lng = x * transform.scale[0] + transform.translate[0];
              var lat = y * transform.scale[1] + transform.translate[1];
              coords.push([lng, lat]);
            }
            if (reverse) coords.reverse();
            return coords;
          }
          function decodeRing(ring) { var c = []; for (var i = 0; i < ring.length; i++) c = c.concat(decodeArc(ring[i])); return c; }

          var features = geometries.map(function(geom) {
            var id = geom.id || (geom.properties && geom.properties.iso_a2);
            var alpha2 = NUM_TO_ALPHA2[id] || id;
            if (geom.type === "Polygon") {
              return { type: "Feature", properties: { code: alpha2 }, geometry: { type: "Polygon", coordinates: geom.arcs.map(decodeRing) } };
            } else if (geom.type === "MultiPolygon") {
              return { type: "Feature", properties: { code: alpha2 }, geometry: { type: "MultiPolygon", coordinates: geom.arcs.map(function(p) { return p.map(decodeRing); }) } };
            }
            return null;
          }).filter(Boolean);

          geoLayer = L.geoJSON({ type: "FeatureCollection", features: features }, {
            style: function(feature) {
              var code = feature.properties.code;
              var val = countryMap[code] || 0;
              return {
                fillColor: val > 0 ? getMapColor(val, maxVal) : "rgba(255,255,255,0.06)",
                weight: val > 0 ? 0.8 : 0.4,
                color: val > 0 ? FOGLIO_PAPER : "rgba(255,255,255,0.18)",
                fillOpacity: val > 0 ? 0.92 : 0.35
              };
            },
            onEachFeature: function(feature, layer) {
              var code = feature.properties.code;
              var val = countryMap[code] || 0;
              if (val > 0) {
                layer.bindTooltip("<b>" + (countryFlag(code) + " " + code) + "</b> — " + fmt(val) + " visitatori", { className: "ax-map-tip", sticky: true });
                layer.on("mouseover", function() { layer.setStyle({ weight: 2, color: FOGLIO_ACCENT_SOFT, fillOpacity: 1 }); layer.bringToFront(); });
                layer.on("mouseout", function() { geoLayer.resetStyle(layer); });
              }
            }
          }).addTo(leafletMap);
        }

        if (_topoCache) applyGeo(_topoCache);
        else fetch(GEOJSON_URL).then(function(r) { return r.json(); }).then(function(d) { _topoCache = d; applyGeo(d); }).catch(function() {});
      }

      /* Period state */
      var PERIOD_DAYS = { "today": 1, "7d": 7, "30d": 30, "90d": 90, "12m": 365 };
      var currentPeriod = "30d";
      var currentFrom = null;
      var currentTo = null;

      function updatePeriodLabel() {
        var label = document.getElementById("cal-label");
        if (!currentFrom || !currentTo) { label.textContent = "—"; return; }
        var text;
        if (currentFrom === currentTo) {
          var d = new Date(currentFrom + "T00:00:00");
          text = DAYS_SHORT[d.getDay()] + " " + fmtCalDateFull(currentFrom);
        } else if (currentPeriod === "12m") {
          var fromD = new Date(currentFrom + "T00:00:00");
          var toD = new Date(currentTo + "T00:00:00");
          text = MONTHS_SHORT[fromD.getMonth()] + " " + fromD.getFullYear() + " — " + MONTHS_SHORT[toD.getMonth()] + " " + toD.getFullYear();
        } else {
          var fy = currentFrom.slice(0, 4), ty = currentTo.slice(0, 4);
          text = fy === ty ? (fmtCalDate(currentFrom) + " — " + fmtCalDateFull(currentTo)) : (fmtCalDateFull(currentFrom) + " — " + fmtCalDateFull(currentTo));
        }
        label.textContent = text;
      }

      function updateNavButtons() {
        var nextBtn = document.getElementById("nav-next");
        var today = dateStr(new Date());
        nextBtn.disabled = !currentTo || currentTo >= today;
      }

      function navigatePeriod(direction) {
        var days = PERIOD_DAYS[currentPeriod] || 30;
        var shift = days * direction;
        var from, to;
        if (currentFrom && currentTo) {
          from = new Date(currentFrom + "T12:00:00");
          to = new Date(currentTo + "T12:00:00");
        } else {
          to = new Date(); to.setHours(12, 0, 0, 0);
          from = new Date(to); from.setDate(from.getDate() - (days - 1));
        }
        from.setDate(from.getDate() + shift);
        to.setDate(to.getDate() + shift);
        var today = new Date();
        if (to > today) to = today;
        var fromStr = dateStr(from), toStr = dateStr(to);
        document.querySelectorAll(".ax-periods button").forEach(function(b) { b.classList.remove("active"); });
        currentFrom = fromStr; currentTo = toStr;
        updatePeriodLabel(); updateNavButtons();
        loadData("custom&from=" + fromStr + "&to=" + toStr);
      }

      function loadData(period) {
        var basePeriod = period.split("&")[0];
        if (basePeriod !== "custom") {
          currentPeriod = basePeriod;
          var days = PERIOD_DAYS[basePeriod] || 30;
          var now = new Date();
          currentTo = dateStr(now);
          var fromD = new Date(now); fromD.setDate(fromD.getDate() - (days - 1));
          currentFrom = dateStr(fromD);
        } else {
          var m = period.match(/from=(\d{4}-\d{2}-\d{2}).*to=(\d{4}-\d{2}-\d{2})/);
          if (m) { currentFrom = m[1]; currentTo = m[2]; }
        }
        updatePeriodLabel(); updateNavButtons();
        document.querySelectorAll(".ax-periods button").forEach(function(b) { b.classList.toggle("active", b.dataset.period === basePeriod); });

        fetch("/api/stats?period=" + period, { headers: AUTH_HEADERS })
          .then(function(r) { if (!r.ok) throw new Error("Failed"); return r.json(); })
          .then(function(d) {
            var s = d.summary;
            document.getElementById("s-pageviews").textContent = fmt(s.pageviews);
            document.getElementById("s-visitors").textContent = fmt(s.visitors);
            document.getElementById("s-time").textContent = fmtTime(s.avg_time_on_page);
            document.getElementById("s-scroll").textContent = s.avg_scroll_depth + "%";
            document.getElementById("s-bounce").textContent = s.bounce_rate + "%";
            setDelta(document.getElementById("s-pageviews-delta"), s.pageviews_delta_pct);
            setDelta(document.getElementById("s-visitors-delta"), s.visitors_delta_pct);

            var suspectN = d.suspicious ? d.suspicious.count : 0;
            document.getElementById("s-suspects").textContent = fmt(suspectN);
            var flagBtn = document.getElementById("flag-suspects-btn");
            flagBtn.style.display = suspectN > 0 ? "inline-block" : "none";
            flagBtn.disabled = false;
            flagBtn.textContent = "Flag come bot (" + suspectN + ")";

            _suspectCountries = {};
            if (d.suspicious && d.suspicious.countries) d.suspicious.countries.forEach(function(c) { if (c.country) _suspectCountries[c.country] = Number(c.suspects) || 0; });

            var groupBy = d.period.groupBy || (period === "today" ? "hour" : period === "12m" ? "month" : "day");
            var rawDates = d.chart.map(function(c) { return c.date; });
            var labels = rawDates.map(function(dt) { return fmtChartLabel(dt, groupBy); });
            var pvData = d.chart.map(function(c) { return Number(c.pageviews); });
            var vData = d.chart.map(function(c) { return Number(c.visitors); });

            if (chartInstance) chartInstance.destroy();
            var ctx = document.getElementById("chart").getContext("2d");
            var axisColor = "rgba(34,26,18,0.75)";
            var gridColor = "rgba(34,26,18,0.12)";
            chartInstance = new Chart(ctx, {
              type: "line",
              data: {
                labels: labels,
                datasets: [
                  { label: "Pageviews", data: pvData, borderColor: FOGLIO_ACCENT, backgroundColor: "rgba(168,69,26,0.14)", fill: true, tension: 0.35, pointRadius: 4, pointHoverRadius: 7, pointBackgroundColor: FOGLIO_ACCENT, pointBorderColor: FOGLIO_PAPER, pointBorderWidth: 2, borderWidth: 3 },
                  { label: "Visitatori", data: vData, borderColor: CYAN, backgroundColor: "rgba(0,180,166,0.08)", fill: true, tension: 0.35, pointRadius: 3, pointHoverRadius: 6, pointBackgroundColor: CYAN, pointBorderColor: FOGLIO_PAPER, pointBorderWidth: 2, borderWidth: 3, borderDash: [6, 4] }
                ]
              },
              options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                  legend: { labels: { color: FOGLIO_INK_SOFT, font: { family: "JetBrains Mono, monospace", size: 11 }, usePointStyle: true, pointStyle: "circle", padding: 16 } },
                  tooltip: {
                    backgroundColor: FOGLIO_PAPER, titleColor: FOGLIO_INK, bodyColor: FOGLIO_INK,
                    borderColor: FOGLIO_RULE, borderWidth: 1, cornerRadius: 4, padding: 10,
                    titleFont: { family: "JetBrains Mono, monospace", size: 11, weight: "600" },
                    bodyFont: { family: "JetBrains Mono, monospace", size: 11 },
                    callbacks: { title: function(items) { return fmtTooltipTitle(rawDates[items[0].dataIndex], groupBy); } }
                  }
                },
                scales: {
                  x: { ticks: { color: axisColor, font: { family: "JetBrains Mono, monospace", size: 10 }, maxRotation: 45, maxTicksLimit: 14, autoSkip: true }, grid: { color: gridColor, drawTicks: false }, border: { color: gridColor } },
                  y: { ticks: { color: axisColor, font: { family: "JetBrains Mono, monospace", size: 10 }, padding: 8 }, grid: { color: gridColor, drawTicks: false }, border: { display: false }, beginAtZero: true }
                },
                interaction: { intersect: false, mode: "index" }
              }
            });

            renderWorldMap(d.countries);
            renderListRows(d.sections, "section", "visitors", false, "sections-list", "Niente.");
            renderListRows(d.top_pages, "pathname", "visitors", true, "top-pages-list", "Niente.");
            renderEngaged(d.top_engaged_posts);
            renderListRows(d.referrers, "referrer", "visitors", false, "referrers-list", "Solo traffico diretto.");
            renderListRows(d.countries, "country", "visitors", false, "countries-list", "—");
            renderListRows(d.languages, "lang", "visitors", false, "languages-list", "—");
            renderListRows(d.devices, "device_type", "visitors", false, "devices-list", "—");
            renderListRows(d.browsers, "browser", "visitors", false, "browsers-list", "—");
            renderListRows(d.os, "os", "visitors", false, "os-list", "—");
            renderListRows(d.utm_sources, "utm_source", "visitors", false, "utm-sources-list", "Nessuna UTM nel periodo.");
            renderListRows(d.utm_campaigns, "utm_campaign", "visitors", false, "utm-campaigns-list", "Nessuna campagna nel periodo.");
            renderRecentVisitors(d.recent_visitors);
          })
          .catch(function(e) {
            document.getElementById("recent-list").innerHTML = '<li class="ax-error">Errore: ' + escapeHtml(e.message) + '</li>';
          });
      }

      function loadLive() {
        fetch("/api/stats/live", { headers: AUTH_HEADERS })
          .then(function(r) { return r.json(); })
          .then(function(d) { document.getElementById("live-count").textContent = d.active; })
          .catch(function() {});
      }

      function pollRecent() {
        if (document.hidden) return;
        if (currentPeriod !== "today") return;
        fetch("/api/stats?period=today", { headers: AUTH_HEADERS })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d && d.recent_visitors) renderRecentVisitors(d.recent_visitors);
          })
          .catch(function() {});
      }

      document.querySelectorAll(".ax-periods button").forEach(function(b) {
        b.addEventListener("click", function() { currentPeriod = b.dataset.period; loadData(b.dataset.period); });
      });
      document.getElementById("date-go").addEventListener("click", function() {
        var f = document.getElementById("date-from").value;
        var t = document.getElementById("date-to").value;
        if (f && t) {
          currentFrom = f; currentTo = t;
          document.querySelectorAll(".ax-periods button").forEach(function(b) { b.classList.remove("active"); });
          document.getElementById("date-range").classList.remove("open");
          loadData("custom&from=" + f + "&to=" + t);
        }
      });
      document.getElementById("nav-prev").addEventListener("click", function() { navigatePeriod(-1); });
      document.getElementById("nav-next").addEventListener("click", function() { navigatePeriod(1); });
      document.getElementById("flag-all-bots").addEventListener("click", flagAllBots);
      document.getElementById("unflag-recent").addEventListener("click", function() {
        var btn = document.getElementById("unflag-recent");
        var orig = btn.textContent;
        btn.disabled = true; btn.textContent = "Annullamento…";
        fetch("/api/admin/bot", { method: "DELETE", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + ADMIN_TOKEN }, body: JSON.stringify({ recentMinutes: 10 }) })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            btn.disabled = false;
            btn.textContent = d.unflagged > 0 ? d.unflagged + " annullati" : "Nessuno da annullare";
            setTimeout(function() { btn.textContent = orig; }, 2500);
            loadData(currentPeriod + (currentFrom && currentTo ? "&from=" + currentFrom + "&to=" + currentTo : ""));
          })
          .catch(function() { btn.disabled = false; btn.textContent = "Errore"; setTimeout(function() { btn.textContent = orig; }, 2500); });
      });
      document.getElementById("flag-suspects-btn").addEventListener("click", function() {
        var btn = document.getElementById("flag-suspects-btn");
        if (!currentFrom || !currentTo) return;
        btn.disabled = true; btn.textContent = "Flagging…";
        fetch("/api/admin/bot", { method: "POST", headers: { "Content-Type": "application/json", "Authorization": "Bearer " + ADMIN_TOKEN }, body: JSON.stringify({ flagSuspicious: true, from: currentFrom, to: currentTo }) })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            btn.textContent = d.flagged + " flaggati";
            setTimeout(function() { loadData("custom&from=" + currentFrom + "&to=" + currentTo); }, 800);
          })
          .catch(function() { btn.textContent = "Errore"; });
      });
      document.getElementById("cal-label").addEventListener("click", function() {
        document.getElementById("date-range").classList.toggle("open");
      });

      var todayStr = dateStr(new Date());
      document.getElementById("date-to").value = todayStr;
      document.getElementById("date-from").value = todayStr;

      loadData("today");
      loadLive();
      setInterval(loadLive, 30000);
      setInterval(pollRecent, 30000);
    </script>
  </body>
</html>
