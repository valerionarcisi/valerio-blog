      var DOUGHNUT_TOOLTIP = {
        backgroundColor: "rgba(20,20,22,0.95)", titleColor: "#e8e6e1", bodyColor: "#e8e6e1",
        borderColor: "rgba(255,255,255,0.1)", borderWidth: 1, cornerRadius: 6, padding: 10,
        bodyFont: { size: 12 }, displayColors: true, boxPadding: 4
      };

      function renderDevicesChart(data) {
        if (!data || !data.length) return;
        var labels = data.map(function(d) { return d.device_type || "unknown"; });
        var values = data.map(function(d) { return Number(d.visitors); });
        var colors = labels.map(function(l) { return CHART_COLORS.devices[l] || "#555"; });
        var total = values.reduce(function(a, b) { return a + b; }, 0);
        var topIdx = values.indexOf(Math.max.apply(null, values));

        document.getElementById("dc-device-val").textContent = Math.round(values[topIdx] / total * 100) + "%";
        document.getElementById("dc-device-lbl").textContent = labels[topIdx];

        var ctx = document.getElementById("devices-chart").getContext("2d");
        devicesChart = new Chart(ctx, {
          type: "doughnut",
          data: { labels: labels, datasets: [{ data: values, backgroundColor: colors, borderColor: "#111113", borderWidth: 2 }] },
