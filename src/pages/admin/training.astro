---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import ActivityHeatmap from "~/components/ActivityHeatmap.astro";
import { fetchFullStats } from "~/services/strava";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

const fullStats = await fetchFullStats().catch(() => null);
const heatmapDays = fullStats?.yearlyBreakdown ?? [];
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Allenamento</title>
    <style is:global>
      .foglio body.admin .week-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .foglio body.admin .week-stat { text-align: center; }
      .foglio body.admin .week-stat-val { font-family: var(--foglio-mono); font-size: var(--foglio-fs-lg); font-weight: 700; color: var(--foglio-accent); }
      .foglio body.admin .week-stat-val.gym { color: var(--foglio-accent-soft); }
      .foglio body.admin .week-stat-label { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-ink-soft); text-transform: uppercase; letter-spacing: 0.12em; margin-top: 0.15rem; }

      .foglio body.admin .load-bar-wrap { display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem; }
      .foglio body.admin .load-bar-bg { flex: 1; height: 4px; background: var(--foglio-rule); border-radius: 2px; }
      .foglio body.admin .load-bar-fill { height: 4px; border-radius: 2px; transition: width 0.5s; }
      .foglio body.admin .load-badge { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.1em; }
      .foglio body.admin .load-light  { background: rgba(46, 204, 113, 0.12); color: #2e8b57; }
      .foglio body.admin .load-normal { background: rgba(168, 69, 26, 0.12); color: var(--foglio-accent); }
      .foglio body.admin .load-heavy  { background: rgba(231, 76, 60, 0.15); color: #c0392b; }

      .foglio body.admin .suggestion-card {
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-accent);
        border-radius: var(--foglio-radius-md);
        padding: 1.5rem;
        margin-bottom: 1.25rem;
      }
      .foglio body.admin .suggestion-label { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--foglio-accent); margin-bottom: 0.5rem; }
      .foglio body.admin .suggestion-day { font-family: var(--foglio-mono); font-size: var(--foglio-fs-xs); color: var(--foglio-ink-soft); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.1em; }
      .foglio body.admin .suggestion-km { font-family: var(--foglio-serif); font-weight: 500; font-size: var(--foglio-fs-4xl); color: var(--foglio-ink); line-height: 1; margin-bottom: 0.25rem; font-variant-numeric: tabular-nums; }
      .foglio body.admin .suggestion-km span { font-family: var(--foglio-mono); font-size: var(--foglio-fs-md); color: var(--foglio-ink-soft); }
      .foglio body.admin .suggestion-type { font-family: var(--foglio-serif); font-style: italic; font-size: var(--foglio-fs-md); color: var(--foglio-accent); margin-bottom: 0.6rem; }
      .foglio body.admin .suggestion-pace { font-family: var(--foglio-mono); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); margin-bottom: 0.8rem; }
      .foglio body.admin .suggestion-weather { display: flex; align-items: center; gap: 0.5rem; font-family: var(--foglio-mono); font-size: var(--foglio-fs-xs); color: var(--foglio-ink-soft); margin-bottom: 0.8rem; }
      .foglio body.admin .suggestion-reason { font-family: var(--foglio-serif); font-style: italic; font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); line-height: 1.6; border-top: 1px solid var(--foglio-rule); padding-top: 0.8rem; }

      .foglio body.admin .chart-bars { display: flex; align-items: flex-end; gap: 4px; height: 80px; margin-bottom: 0.5rem; }
      .foglio body.admin .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; }
      .foglio body.admin .chart-bar { width: 100%; border-radius: 3px 3px 0 0; background: var(--foglio-rule-strong); transition: background 0.2s; min-height: 2px; }
      .foglio body.admin .chart-bar.current { background: var(--foglio-accent); }
      .foglio body.admin .chart-label { font-family: var(--foglio-mono); font-size: 0.5rem; color: var(--foglio-ink-mute); text-align: center; white-space: nowrap; overflow: hidden; }
      .foglio body.admin .chart-km { font-family: var(--foglio-mono); font-size: 0.55rem; color: var(--foglio-ink-soft); }

      .foglio body.admin .goal-row { display: flex; align-items: center; gap: 1rem; }
      .foglio body.admin .goal-pace { font-family: var(--foglio-mono); font-size: var(--foglio-fs-2xl); font-weight: 700; color: var(--foglio-accent); }
      .foglio body.admin .goal-info { flex: 1; }
      .foglio body.admin .goal-target { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); margin-bottom: 0.3rem; }
      .foglio body.admin .goal-delta { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; }
      .foglio body.admin .goal-bar-bg { height: 6px; background: var(--foglio-rule); border-radius: 3px; margin-top: 0.5rem; }
      .foglio body.admin .goal-bar-fill { height: 6px; background: var(--foglio-accent); border-radius: 3px; }

      .foglio body.admin .activity-list { display: flex; flex-direction: column; }
      .foglio body.admin .activity-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.8rem 0.25rem;
        text-decoration: none;
        color: inherit;
        transition: color 0.15s;
        border-bottom: 1px solid var(--foglio-rule);
      }
      .foglio body.admin .activity-row:last-child { border-bottom: none; }
      .foglio body.admin .activity-row:hover { color: var(--foglio-accent); }
      .foglio body.admin .activity-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
      .foglio body.admin .activity-name { flex: 1; font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink); }
      .foglio body.admin .activity-meta { display: flex; gap: 0.6rem; font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-ink-soft); }
      .foglio body.admin .activity-meta .pace { color: var(--foglio-accent); }
      .foglio body.admin .activity-date { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-ink-mute); white-space: nowrap; text-transform: uppercase; letter-spacing: 0.08em; }

      @media (max-width: 768px) {
        .foglio body.admin .week-stats { grid-template-columns: repeat(2, 1fr); }
        .foglio body.admin .chart-label { display: none; }
        .foglio body.admin .activity-meta { flex-wrap: wrap; gap: 0.4rem; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="training" token={token} />

    <h1><em class="acc">Allenamento.</em></h1>
    <p class="subtitle">Monitoraggio settimanale e suggerimento smart per il weekend</p>

    <div id="content">
      <div class="loading">Carico dati Strava…</div>
    </div>

    {heatmapDays.length > 0 && (
      <div class="section">
        <ActivityHeatmap days={heatmapDays} title="Attività ultimi 365 giorni" />
      </div>
    )}

    <script is:inline define:vars={{ token }}>
      const ADMIN_TOKEN = token;
      const API = '/api/training';

      function fmtPace(speedMs) {
        if (!speedMs || speedMs === 0) return '';
        const minKm = 1000 / 60 / speedMs;
        const m = Math.floor(minKm);
        const s = Math.round((minKm - m) * 60);
        return m + ':' + String(s).padStart(2, '0') + '/km';
      }
      function fmtDist(m) { return (m / 1000).toFixed(1) + ' km'; }
      function fmtDate(iso) {
        const d = new Date(iso);
        return d.toLocaleDateString('it-IT', { day: 'numeric', month: 'short' });
      }
      function secToMin(s) { const h = Math.floor(s/3600); const m = Math.floor((s%3600)/60); return h > 0 ? h+'h '+m+'m' : m+'m'; }
      var WX_SUN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M120 40V16a8 8 0 0 1 16 0v24a8 8 0 0 1-16 0m72 88a64 64 0 1 1-64-64a64.07 64.07 0 0 1 64 64m-16 0a48 48 0 1 0-48 48a48.05 48.05 0 0 0 48-48M58.34 69.66a8 8 0 0 0 11.32-11.32l-16-16a8 8 0 0 0-11.32 11.32Zm0 116.68l-16 16a8 8 0 0 0 11.32 11.32l16-16a8 8 0 0 0-11.32-11.32M192 72a8 8 0 0 0 5.66-2.34l16-16a8 8 0 0 0-11.32-11.32l-16 16A8 8 0 0 0 192 72m5.66 114.34a8 8 0 0 0-11.32 11.32l16 16a8 8 0 0 0 11.32-11.32ZM48 128a8 8 0 0 0-8-8H16a8 8 0 0 0 0 16h24a8 8 0 0 0 8-8m80 80a8 8 0 0 0-8 8v24a8 8 0 0 0 16 0v-24a8 8 0 0 0-8-8m112-88h-24a8 8 0 0 0 0 16h24a8 8 0 0 0 0-16"/></svg>';
      var WX_CLOUDSUN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M164 72a76.2 76.2 0 0 0-20.26 2.73a55.6 55.6 0 0 0-9.41-11.54l9.51-13.57a8 8 0 1 0-13.11-9.18L121.22 54A55.9 55.9 0 0 0 96 48h-1.74l-2.89-16.29a8 8 0 1 0-15.75 2.77l2.88 16.34a56.1 56.1 0 0 0-23.27 14.85l-13.62-9.53a8 8 0 1 0-9.17 13.11L46 78.77A55.55 55.55 0 0 0 40 104v1.72l-16.29 2.88a8 8 0 0 0 1.38 15.88a8 8 0 0 0 1.39-.12l16.32-2.88a55.7 55.7 0 0 0 5.86 12.42A52 52 0 0 0 84 224h80a76 76 0 0 0 0-152M56 104a40 40 0 0 1 72.54-23.24a76.26 76.26 0 0 0-35.62 40a52.14 52.14 0 0 0-31 4.17A40 40 0 0 1 56 104m108 104H84a36 36 0 1 1 4.78-71.69c-.37 2.37-.63 4.79-.77 7.23a8 8 0 0 0 16 .92a59 59 0 0 1 1.88-11.81c0-.16.09-.32.12-.48A60.06 60.06 0 1 1 164 208"/></svg>';
      var WX_FOG = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M120 208H72a8 8 0 0 1 0-16h48a8 8 0 0 1 0 16m64-16h-24a8 8 0 0 0 0 16h24a8 8 0 0 0 0-16m-24 32h-56a8 8 0 0 0 0 16h56a8 8 0 0 0 0-16m72-124a76.08 76.08 0 0 1-76 76H76a52 52 0 0 1 0-104a53 53 0 0 1 8.92.76A76.08 76.08 0 0 1 232 100m-16 0a60.06 60.06 0 0 0-120-3.54a8 8 0 0 1-16-.92q.21-3.66.77-7.23A38 38 0 0 0 76 88a36 36 0 0 0 0 72h80a60.07 60.07 0 0 0 60-60"/></svg>';
      var WX_RAIN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="m158.66 196.44l-32 48a8 8 0 1 1-13.32-8.88l32-48a8 8 0 0 1 13.32 8.88M232 92a76.08 76.08 0 0 1-76 76h-23.72l-29.62 44.44a8 8 0 1 1-13.32-8.88L113.05 168H76a52 52 0 0 1 0-104a53 53 0 0 1 8.92.76A76.08 76.08 0 0 1 232 92m-16 0a60.06 60.06 0 0 0-120-3.54a8 8 0 0 1-16-.92q.21-3.66.77-7.23A38 38 0 0 0 76 80a36 36 0 0 0 0 72h80a60.07 60.07 0 0 0 60-60"/></svg>';
      var WX_SNOW = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M88 196a12 12 0 1 1-12-12a12 12 0 0 1 12 12m28 4a12 12 0 1 0 12 12a12 12 0 0 0-12-12m48-16a12 12 0 1 0 12 12a12 12 0 0 0-12-12m-96 40a12 12 0 1 0 12 12a12 12 0 0 0-12-12m88 0a12 12 0 1 0 12 12a12 12 0 0 0-12-12m76-132a76.08 76.08 0 0 1-76 76H76a52 52 0 0 1 0-104a53 53 0 0 1 8.92.76A76.08 76.08 0 0 1 232 92m-16 0a60.06 60.06 0 0 0-120-3.54a8 8 0 0 1-16-.92q.21-3.66.77-7.23A38 38 0 0 0 76 80a36 36 0 0 0 0 72h80a60.07 60.07 0 0 0 60-60"/></svg>';
      var WX_STORM = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M156 16a76.2 76.2 0 0 0-71.08 48.76A53 53 0 0 0 76 64a52 52 0 0 0 0 104h37.87l-16.73 27.88A8 8 0 0 0 104 208h25.87l-16.73 27.88a8 8 0 0 0 13.72 8.24l24-40A8 8 0 0 0 144 192h-25.87l14.4-24H156a76 76 0 0 0 0-152m0 136H76a36 36 0 0 1 0-72a38 38 0 0 1 4.78.31q-.56 3.57-.77 7.23a8 8 0 0 0 16 .92A60.06 60.06 0 1 1 156 152"/></svg>';
      function weatherIcon(code) {
        if (code <= 1) return WX_SUN;
        if (code <= 3) return WX_CLOUDSUN;
        if (code <= 48) return WX_FOG;
        if (code <= 67) return WX_RAIN;
        if (code <= 77) return WX_SNOW;
        if (code <= 82) return WX_RAIN;
        return WX_STORM;
      }

      function computeReadiness(data) {
        const { currentWeekActivities, last4WeeklyKm, weekendLongRuns, last12WeeklyElevation } = data;

        const weekRuns = currentWeekActivities.filter(a => a.sportType === 'Run');
        const weekKm = weekRuns.reduce((s, a) => s + a.distance, 0) / 1000;
        const weekElev = currentWeekActivities.reduce((s, a) => s + a.elevation, 0);
        const hasGym = currentWeekActivities.some(a => a.sportType === 'WeightTraining');
        const avgKm4w = last4WeeklyKm.reduce((s, v) => s + v, 0) / Math.max(1, last4WeeklyKm.length);

        const recentLongs = weekendLongRuns.slice(-8);
        const lastLong = recentLongs[recentLongs.length - 1];
        const longestRecent = recentLongs.reduce((max, r) => Math.max(max, r.distanceM), 0) / 1000;
        const avgLong4w = recentLongs.slice(-4).reduce((s, r) => s + r.distanceM, 0) / Math.max(1, Math.min(4, recentLongs.length)) / 1000;

        const longs4 = recentLongs.slice(-4).filter(r => r.averageHeartrate);
        const hrAvg4w = longs4.length > 0 ? longs4.reduce((s, r) => s + r.averageHeartrate, 0) / longs4.length : 150;
        const hrLastLong = lastLong?.averageHeartrate ?? hrAvg4w;

        const paceAvg4w = recentLongs.slice(-4).reduce((s, r) => {
          return r.distanceM > 0 ? s + (r.movingTime / (r.distanceM / 1000)) : s;
        }, 0) / Math.max(1, Math.min(4, recentLongs.length));
        const paceLastLong = lastLong && lastLong.distanceM > 0
          ? lastLong.movingTime / (lastLong.distanceM / 1000) : paceAvg4w;

        const hillyRuns = weekendLongRuns.filter(r => r.elevation > 100);
        const lastHilly = hillyRuns[hillyRuns.length - 1];
        const daysSinceHilly = lastHilly
          ? Math.floor((Date.now() - new Date(lastHilly.date).getTime()) / 86400000)
          : 999;

        let readiness = 50;
        if (avgKm4w > 0) {
          const loadRatio = weekKm / avgKm4w;
          if (loadRatio < 0.6) readiness += 20;
          else if (loadRatio < 0.9) readiness += 10;
          else if (loadRatio > 1.2) readiness -= 15;
          else if (loadRatio > 1.0) readiness -= 5;
        }
        if (hrLastLong < hrAvg4w - 5) readiness += 15;
        else if (hrLastLong > hrAvg4w + 10) readiness -= 15;
        if (paceLastLong < paceAvg4w - 10) readiness += 10;
        if (hasGym && weekRuns.length >= 3) readiness -= 10;
        if (weekRuns.length >= 4) readiness -= 10;

        let targetKm;
        if (readiness >= 80) targetKm = Math.min(longestRecent + 3, longestRecent * 1.12);
        else if (readiness >= 60) targetKm = longestRecent * 1.05;
        else if (readiness >= 40) targetKm = avgLong4w || longestRecent;
        else targetKm = (avgLong4w || longestRecent) * 0.75;
        targetKm = Math.max(10, Math.round(targetKm));

        const weeksConsecEasy = Math.min(data._weeksConsecEasy ?? 0, 10);

        let type, paceHint, reason;
        if (readiness < 35) {
          type = 'recovery';
          targetKm = Math.round(Math.min(targetKm * 0.75, 14));
          paceHint = addSecToPace(paceAvg4w, 30);
          reason = 'Settimana intensa. Il corpo chiede recupero — corsa leggera per mantenere il ritmo senza accumulare fatica.';
        } else if (weekKm < 10 && weekRuns.length === 0) {
          type = 'easy';
          paceHint = addSecToPace(paceAvg4w, 15);
          reason = 'Settimana ferma. Esci per riattivare le gambe, senza pressione.';
        } else if (daysSinceHilly > 21 && weekElev < 50 && readiness >= 55) {
          type = 'hilly';
          var hillyHistory = data.weekendLongRuns.filter(function(r) { return r.elevation > 100; });
          var avgHillyElev = hillyHistory.length > 0
            ? Math.round(hillyHistory.slice(-4).reduce(function(s, r) { return s + r.elevation; }, 0) / Math.min(4, hillyHistory.length))
            : 180;
          var suggestedElev = readiness >= 70
            ? Math.round(avgHillyElev * 1.1 / 50) * 50
            : Math.round(avgHillyElev * 0.9 / 50) * 50;
          suggestedElev = Math.max(100, Math.min(400, suggestedElev));
          var elevRange = suggestedElev + '–' + (suggestedElev + 50) + 'm';
          paceHint = addSecToPace(paceAvg4w, 25) + ' · ↑' + elevRange + ' dislivello';
          reason = 'Non fai un collinare da oltre 3 settimane. Il lavoro in salita rafforza la muscolatura e migliora l\'efficienza. Target dislivello: ' + elevRange + '.';
        } else if (weeksConsecEasy >= 3) {
          type = 'fartlek';
          paceHint = fmtPaceFromSec(paceAvg4w) + ' — ultimi ' + Math.round(targetKm * 0.25) + 'km a ' + addSecToPace(paceAvg4w, -25);
          reason = 'Tre settimane facili consecutive. È il momento di inserire un segmento a ritmo più sostenuto — ti avvicina all\'obiettivo 4:40-4:50/km.';
        } else {
          type = 'long_easy';
          paceHint = addSecToPace(paceAvg4w, 5);
          reason = readiness >= 70
            ? 'Settimana ben gestita, gambe fresche. Puoi spingere sulla distanza — vai con fiducia.'
            : 'Settimana nella media. Corsa lunga standard, ascolta il corpo.';
        }

        return { readiness, targetKm, type, paceHint, reason, weekKm, weekRuns: weekRuns.length,
          hasGym, avgKm4w, weekElev, daysSinceHilly, longestRecent, avgLong4w, hrAvg4w, hrLastLong };
      }

      function addSecToPace(secPerKm, delta) {
        return fmtPaceFromSec(secPerKm + delta);
      }
      function fmtPaceFromSec(sec) {
        if (!sec || sec <= 0) return '5:30/km';
        const m = Math.floor(sec / 60);
        const s = Math.round(sec % 60);
        return m + ':' + String(s).padStart(2, '0') + '/km';
      }

      function typeLabel(type) {
        return { recovery: 'Recovery — ritmo facile', easy: 'Corsa facile', hilly: 'Collinare', fartlek: 'Long run con fartlek', long_easy: 'Long run' }[type] || 'Long run';
      }

      function loadClass(ratio) {
        if (ratio < 0.7) return 'light';
        if (ratio < 1.15) return 'normal';
        return 'heavy';
      }
      function loadLabel(ratio) {
        if (ratio < 0.7) return 'Settimana leggera';
        if (ratio < 1.15) return 'Nella media';
        return 'Settimana intensa';
      }

      function getWeekendWeather(weather) {
        if (!weather) return null;
        const today = new Date();
        const days = [];
        for (let i = 0; i <= 6; i++) {
          const d = new Date(today);
          d.setDate(d.getDate() + i);
          const dow = d.getDay();
          if (dow === 6 || dow === 0) {
            const key = d.toISOString().slice(0, 10);
            if (weather[key]) days.push({ date: key, dow, ...weather[key] });
          }
        }
        days.sort((a, b) => a.rain - b.rain);
        return days[0] ?? null;
      }

      function buildContent(data) {
        const { currentWeekActivities, weeklyRunStats, weather } = data;
        const ctx = computeReadiness(data);

        data._weeksConsecEasy = 3;

        const loadRatio = ctx.avgKm4w > 0 ? ctx.weekKm / ctx.avgKm4w : 0.8;
        const lc = loadClass(loadRatio);
        const barW = Math.min(100, Math.round(loadRatio * 80));
        const barColor = lc === 'light' ? '#2e8b57' : lc === 'normal' ? 'var(--foglio-accent)' : '#c0392b';

        const bestWeather = getWeekendWeather(weather);
        const suggestDay = bestWeather
          ? (bestWeather.dow === 6 ? 'Sabato' : 'Domenica')
          : 'Weekend';
        const weatherLine = bestWeather
          ? weatherIcon(bestWeather.code) + ' ' + Math.round(bestWeather.temp) + '°C · pioggia ' + bestWeather.rain + '%'
          : '';

        let adjustedKm = ctx.targetKm;
        let adjustedPace = ctx.paceHint;
        if (bestWeather && bestWeather.temp > 22) {
          adjustedKm = Math.max(10, adjustedKm - 2);
          adjustedPace += ' (caldo — idratati)';
        }

        const recentLongs = (data.weekendLongRuns || []).slice(-4);
        const currentPaceSec = recentLongs.length > 0
          ? recentLongs.reduce((s, r) => s + (r.distanceM > 0 ? r.movingTime / (r.distanceM / 1000) : 0), 0) / recentLongs.length
          : 0;
        const targetPaceSec = 4 * 60 + 45;
        const deltaSec = currentPaceSec > 0 ? Math.round(currentPaceSec - targetPaceSec) : null;
        const progressPct = deltaSec !== null
          ? Math.max(0, Math.min(100, Math.round((1 - deltaSec / 90) * 100)))
          : 20;

        const weeks = (weeklyRunStats || []).slice(-12);
        const maxKm = Math.max(...weeks.map(w => w.distance / 1000), 1);
        const chartHtml = weeks.map((w, i) => {
          const km = w.distance / 1000;
          const h = Math.round((km / maxKm) * 100);
          const isCurrent = i === weeks.length - 1;
          return `<div class="chart-bar-wrap">
            <div class="chart-km">${km > 0 ? km.toFixed(0) : ''}</div>
            <div class="chart-bar${isCurrent ? ' current' : ''}" style="height:${h}%"></div>
            <div class="chart-label">${w.weekLabel}</div>
          </div>`;
        }).join('');

        const actHtml = currentWeekActivities.slice().reverse().slice(0, 8).map(a => {
          const color = a.sportType === 'Run' ? 'var(--foglio-accent)' : a.sportType === 'WeightTraining' ? 'var(--foglio-accent-soft)' : 'var(--foglio-ink-soft)';
          const pace = a.sportType === 'Run' ? fmtPace(a.averageSpeed) : '';
          const km = a.distance > 0 ? fmtDist(a.distance) : '';
          const elev = a.elevation > 10 ? ' ↑' + Math.round(a.elevation) + 'm' : '';
          return `<a href="${a.url}" target="_blank" rel="noopener" class="activity-row">
            <div class="activity-dot" style="background:${color}"></div>
            <div class="activity-name">${a.name}</div>
            <div class="activity-meta">
              ${km ? '<span>' + km + '</span>' : ''}
              ${pace ? '<span class="pace">' + pace + '</span>' : ''}
              ${elev ? '<span>' + elev + '</span>' : ''}
              <span>${secToMin(a.movingTime)}</span>
            </div>
            <div class="activity-date">${fmtDate(a.date)}</div>
          </a>`;
        }).join('');

        return `
          <div class="section">
            <div class="section-title">Questa settimana</div>
            <div class="week-stats">
              <div class="week-stat">
                <div class="week-stat-val">${ctx.weekKm.toFixed(1)}</div>
                <div class="week-stat-label">km</div>
              </div>
              <div class="week-stat">
                <div class="week-stat-val">${ctx.weekRuns}</div>
                <div class="week-stat-label">corse</div>
              </div>
              <div class="week-stat">
                <div class="week-stat-val">${Math.round(ctx.weekElev)}</div>
                <div class="week-stat-label">m dislivello</div>
              </div>
              <div class="week-stat">
                <div class="week-stat-val gym">${ctx.hasGym ? '1' : '0'}</div>
                <div class="week-stat-label">palestra</div>
              </div>
            </div>
            <div class="load-bar-wrap">
              <div class="load-bar-bg">
                <div class="load-bar-fill" style="width:${barW}%;background:${barColor}"></div>
              </div>
              <span class="load-badge load-${lc}">${loadLabel(loadRatio)}</span>
            </div>
          </div>

          <div class="suggestion-card">
            <div class="suggestion-label">Suggerimento weekend</div>
            <div class="suggestion-day">${suggestDay}</div>
            <div class="suggestion-km">${adjustedKm}<span> km</span></div>
            <div class="suggestion-type">${typeLabel(ctx.type)}</div>
            <div class="suggestion-pace">${adjustedPace}</div>
            ${weatherLine ? `<div class="suggestion-weather">${weatherLine}</div>` : ''}
            <div class="suggestion-reason">${ctx.reason}</div>
          </div>

          <div class="section">
            <div class="section-title">Andamento 12 settimane</div>
            <div class="chart-bars">${chartHtml}</div>
          </div>

          <div class="section">
            <div class="section-title">Obiettivo gara — 4:40–4:50 /km</div>
            <div class="goal-row">
              <div class="goal-pace">${currentPaceSec > 0 ? fmtPaceFromSec(currentPaceSec) : '—'}</div>
              <div class="goal-info">
                <div class="goal-target">Target: 4:40–4:50 /km</div>
                <div class="goal-delta">${deltaSec !== null ? (deltaSec > 0 ? '-' + deltaSec + ' sec al traguardo' : 'Obiettivo raggiunto!') : ''}</div>
                <div class="goal-bar-bg">
                  <div class="goal-bar-fill" style="width:${progressPct}%"></div>
                </div>
              </div>
            </div>
          </div>

          ${currentWeekActivities.length > 0 ? `
          <div class="section">
            <div class="section-title">Questa settimana — attività</div>
            <div class="activity-list">${actHtml}</div>
          </div>` : ''}
        `;
      }

      async function load() {
        try {
          const res = await fetch(API, { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } });
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          document.getElementById('content').innerHTML = buildContent(data);
        } catch (e) {
          document.getElementById('content').innerHTML = '<div class="loading" style="color:#c0392b">Errore caricamento dati: ' + e.message + '</div>';
        }
      }

      load();
    </script>
  </body>
</html>
