---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

import { Icon } from "astro-icon/components";

const groceryList = [
  {
    category: "Pane e Carboidrati",
    icon: "ph:bread",
    cost: 12,
    items: [
      "Pane integrale o ai cereali (per accompagnare pranzi e cene)",
      "Gallette di riso o altro cereale (alternativa al pane)",
      "Fette wasa (alternativa al pane)",
      "Pasta (120g x ~3 porzioni settimanali)",
      "Riso basmati (120g x ~2 porzioni settimanali)",
      "Cereali alternativi: farro, orzo, quinoa, cous cous, grano saraceno (120g a porzione)",
      "Friselle integrali (2 da circa 60g l'una: pranzo Mar opz 2)",
      "Farina avena/integrale/tipo 1-2 (100g per piadina)",
    ],
  },
  {
    category: "Carne",
    icon: "ph:cow",
    cost: 28,
    items: [
      "Petto di pollo (200g x3: curry Gio + caesar salad Ven + Dom/opz)",
      "Macinata magra (180g hamburger Mer + 100g per condire pasta/legumi)",
      "Fesa di tacchino (100g millefoglie Mar + 150g opz Dom)",
      "Cotto magro (100g millefoglie Mar, alternativa)",
      "Galantina 150g (cena Mer opz 2)",
      "Carne rossa magra: fesa, noce, scamone, girello (200g x1 Lun/Gio cena)",
    ],
  },
  {
    category: "Pesce",
    icon: "ph:fish",
    cost: 30,
    items: [
      "Tonno al naturale 80g (x10-12 scatolette: pranzi Lun/Mar/Gio/Ven/Sab + cena Sab opz 2)",
      "Sgombro/salmone al naturale in scatola (~2 conf, 200g sgocciolato: pranzo Mer)",
      "Pesce magro fresco: merluzzo, platessa, spigola, orata (250g x1: cena Lun)",
      "Pesce spada / sgombro / tonno fresco (200-250g x1: cena Lun opz 2)",
      "Salmone affumicato (100g x1: cena Sab + opz pranzo Mer/Gio)",
    ],
  },
  {
    category: "Uova e Latticini",
    icon: "ph:egg",
    cost: 12,
    items: [
      "Uova (confezione da 6 — 3 uova Mar cena + 3 uova Gio pranzo opz 2)",
      "Yogurt greco 0% bianco (per salsa pollo al curry Gio + farcitura piadina Ven)",
      "Mozzarella light 100g (x4: millefoglie Mar + friselle Mar pranzo + cena Sab opz 2 + insalatona Dom)",
      "Ricotta 100g (x1: alternativa millefoglie Mar, Vallelata ricottina)",
      "Parmigiano grattugiato (per millefoglie)",
      "Formaggio magro spalmabile Exquisa Fitline / Philadelphia Protein (piadina Ven + cena Sab)",
    ],
  },
  {
    category: "Legumi",
    icon: "ph:grains",
    cost: 8,
    items: [
      "Ceci in scatola (x2: pranzo Lun/Sab opz 2 240g ciascuno)",
      "Lenticchie in scatola (x1-2: alternativa ceci pranzo Lun/Sab)",
      "Burger vegetali (x2 pz: cena Ven opz 1 — Bio Appetì, Valsoia, Ecor, Kioene, Granarolo)",
    ],
  },
  {
    category: "Verdura",
    icon: "ph:plant",
    cost: 18,
    items: [
      "Verdure a foglia verde: lattuga, rucola, valeriana, indivia, iceberg (insalatone Mar/Mer/Dom)",
      "Zucchine (millefoglie Mar + caesar salad Ven + contorno Mer/altro)",
      "Pomodorini (insalatone, friselle Mar, contorni vari)",
      "Carote (insalatone Mar/Mer/Dom)",
      "Sedano (insalatone Mar/Mer)",
      "Funghi (contorni opzionali)",
      "Avocado x1 grande (insalatona Mer pranzo opz 2 / farcitura piadina Ven)",
      "Verdure per contorno a sazietà (a scelta per ogni cena)",
    ],
  },
  {
    category: "Condimenti",
    icon: "ph:flower-tulip",
    cost: 6,
    note: "Molti durano più settimane",
    items: [
      "Olio extravergine di oliva (2-4 cucchiaini a pranzo e cena ogni giorno)",
      "Olive nere (30g insalatona Mer + cena Sab)",
      "Curry in polvere (pollo al curry Gio)",
      "Limoni x1 (succo mezzo limone: pollo al curry Gio)",
      "Vino bianco secco (per sfumare: pollo al curry Gio)",
      "Semi di lino/zucca/girasole (1 cucchiaio: insalatona Mar pranzo + caesar salad Ven)",
      "Erba cipollina (o altra spezia: caesar salad Ven)",
      "Noci secche / pinoli (10g: pranzo Mer)",
      "Spezie: rosmarino, timo, origano, aglio in polvere, basilico, prezzemolo",
    ],
  },
];

const totalCost = groceryList.reduce((sum, s) => sum + s.cost, 0);
const totalItems = groceryList.reduce((sum, s) => sum + s.items.length, 0);
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Lista della Spesa</title>
    <style is:global>
      .foglio body.admin .summary-bar {
        display: flex;
        gap: 1.5rem;
        align-items: baseline;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
      }
      .foglio body.admin .summary-total {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-2xl);
        font-weight: 500;
        color: var(--foglio-accent);
        font-variant-numeric: tabular-nums;
      }
      .foglio body.admin .summary-total small {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 500;
        color: var(--foglio-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .foglio body.admin .summary-detail {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        color: var(--foglio-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .foglio body.admin .grocery-list {
        display: flex;
        flex-direction: column;
      }

      .foglio body.admin .grocery-card {
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--foglio-rule);
        border-radius: 0;
      }
      .foglio body.admin .grocery-card summary {
        list-style: none;
        cursor: pointer;
        padding: 0.7rem 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-md);
        font-weight: 500;
        color: var(--foglio-ink);
      }
      .foglio body.admin .grocery-card summary::-webkit-details-marker { display: none; }
      .foglio body.admin .grocery-card summary::before {
        content: "▸";
        color: var(--foglio-ink-mute);
        font-size: 0.82rem;
        width: 0.8rem;
        flex-shrink: 0;
        transition: transform 0.15s;
      }
      .foglio body.admin .grocery-card[open] summary::before { content: "▾"; color: var(--foglio-accent); }

      .foglio body.admin .grocery-card .grocery-icon { width: 1.15rem; height: 1.15rem; color: var(--foglio-accent); flex-shrink: 0; }
      .foglio body.admin .grocery-count {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 400;
        color: var(--foglio-ink-mute);
      }
      .foglio body.admin .grocery-cost {
        margin-left: auto;
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-sm);
        font-weight: 600;
        color: var(--foglio-accent);
        font-variant-numeric: tabular-nums;
      }

      .foglio body.admin .grocery-body {
        padding: 0.2rem 0.25rem 0.8rem 1.4rem;
      }

      .foglio body.admin .grocery-note {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        color: var(--foglio-ink-soft);
        font-style: italic;
        margin-bottom: 0.4rem;
      }

      .foglio body.admin .grocery-items {
        list-style: none;
        padding: 0;
        columns: 2;
        column-gap: 1.5rem;
      }
      .foglio body.admin .grocery-items li {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.5;
        padding: 0.15rem 0 0.15rem 0.7rem;
        position: relative;
        color: var(--foglio-ink-soft);
        break-inside: avoid;
      }
      .foglio body.admin .grocery-items li::before {
        content: "·";
        position: absolute;
        left: 0;
        color: var(--foglio-accent);
        font-weight: 700;
      }

      @media (max-width: 500px) {
        .foglio body.admin .grocery-items { columns: 1; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="grocery" token={token} />

    <h1><em class="acc">Spesa settimanale.</em></h1>
    <p class="subtitle">Solo pranzi e cene</p>

    <div class="summary-bar">
      <div class="summary-total">
        ~{totalCost}€ <small>/settimana</small>
      </div>
      <div class="summary-detail">
        {totalItems} prodotti · {groceryList.length} categorie
      </div>
    </div>

    <div class="grocery-list">
      {groceryList.map((section) => (
        <details class="grocery-card">
          <summary>
            <Icon name={section.icon} class="grocery-icon" size={18} is:inline />
            {section.category}
            <span class="grocery-count">({section.items.length})</span>
            <span class="grocery-cost">~{section.cost}€</span>
          </summary>
          <div class="grocery-body">
            {"note" in section && section.note && (
              <div class="grocery-note">{section.note}</div>
            )}
            <ul class="grocery-items">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </body>
</html>
