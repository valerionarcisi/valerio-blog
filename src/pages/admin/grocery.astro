const totalCost = groceryList.reduce((sum, s) => sum + s.cost, 0);
const totalItems = groceryList.reduce((sum, s) => sum + s.items.length, 0);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Lista della Spesa</title>
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0a0a0c;
        color: #e8e6e1;
        padding: 1rem;
        min-height: 100vh;
        -webkit-text-size-adjust: 100%;
      }

      .summary-bar {
        display: flex;
        gap: 1.5rem;
        align-items: baseline;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
      }
      .summary-total {
        font-size: 1.6rem;
        font-weight: 800;
        color: #c8a000;
      }
      .summary-total small {
        font-size: 0.75rem;
        font-weight: 500;
        color: #888;
      }
      .summary-detail {
        font-size: 0.75rem;
        color: #888;
      }

      .grocery-list {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }

      .grocery-card {
        background: #151518;
        border: 1px solid #252528;
        border-radius: 0.5rem;
      }
      .grocery-card summary {
        list-style: none;
        cursor: pointer;
        padding: 0.55rem 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.85rem;
        font-weight: 600;
      }
      .grocery-card summary::-webkit-details-marker { display: none; }
      .grocery-card summary::before {
        content: "▸";
        color: #555;
        font-size: 0.7rem;
        width: 0.8rem;
        flex-shrink: 0;
      }
      .grocery-card[open] summary::before { content: "▾"; }
      .grocery-card[open] summary { border-bottom: 1px solid #252528; }

      .grocery-card .emoji { font-size: 1rem; }
      .grocery-count {
        font-size: 0.7rem;
        font-weight: 400;
        color: #666;
      }
      .grocery-cost {
        margin-left: auto;
        font-size: 0.75rem;
        font-weight: 600;
        color: #c8a000;
      }

      .grocery-body {
        padding: 0.4rem 0.75rem 0.5rem;
      }

      .grocery-note {
        font-size: 0.65rem;
        color: #666;
        font-style: italic;
        margin-bottom: 0.2rem;
      }

      .grocery-items {
        list-style: none;
        padding: 0;
        columns: 2;
        column-gap: 1rem;
      }
      .grocery-items li {
        font-size: 0.78rem;
        line-height: 1.4;
        padding: 0.1rem 0 0.1rem 0.7rem;
        position: relative;
        color: #bbb;
        break-inside: avoid;
      }
      .grocery-items li::before {
        content: "·";
        position: absolute;
        left: 0;
        color: #555;
        font-weight: 700;
      }

      @media (max-width: 500px) {
        body { padding: 0.75rem; }
        .summary-total { font-size: 1.4rem; }
        .grocery-items { columns: 1; }
      }
    </style>
  </head>
  <body>
    <AdminNav currentPage="grocery" token={token} />

    <h2 style="font-size:1.1rem; margin-bottom:0.75rem; color:#e8e6e1;">
      Lista della Spesa Settimanale
    </h2>

    <div class="summary-bar">
      <div class="summary-total">
        ~{totalCost}€ <small>/settimana</small>
      </div>
      <div class="summary-detail">
        {totalItems} prodotti · {groceryList.length} categorie
      </div>
    </div>

    <div class="grocery-list">
      {groceryList.map((section) => (
        <details class="grocery-card">
          <summary>
            <span class="emoji">{section.emoji}</span>
            {section.category}
            <span class="grocery-count">({section.items.length})</span>
            <span class="grocery-cost">~{section.cost}€</span>
          </summary>
          <div class="grocery-body">
            {"note" in section && section.note && (
              <div class="grocery-note">{section.note}</div>
            )}
            <ul class="grocery-items">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </body>
</html>
