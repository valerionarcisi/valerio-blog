---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

const groceryList = [
  {
    category: "Pane e Carboidrati",
    emoji: "🍞",
    cost: 12,
    items: [
      "Pane integrale o ai cereali (per accompagnare pranzi e cene)",
      "Gallette di riso o altro cereale (alternativa al pane)",
      "Fette wasa (alternativa al pane)",
      "Pasta (120g x ~3 porzioni settimanali)",
      "Riso basmati (120g x ~2 porzioni settimanali)",
      "Cereali alternativi: farro, orzo, quinoa, cous cous, grano saraceno (120g a porzione)",
      "Pan grattato (60g finocchi gratinati + 40g polpette broccoli)",
      "Farina avena/integrale/tipo 1-2 (100g per piadina)",
    ],
  },
  {
    category: "Carne",
    emoji: "🥩",
    cost: 25,
    items: [
      "Petto di pollo (200g x2: curry gio + Dom/Lun/Mar opz)",
      "Macinata magra (180g hamburger mer + 100g per condire pasta/legumi)",
      "Fesa di tacchino (100g millefoglie mar + 150g opz dom)",
      "Cotto magro (100g millefoglie mar, alternativa)",
      "Carne rossa magra: fesa, noce, scamone, girello (200g x1 Lun/Gio cena)",
    ],
  },
  {
    category: "Pesce",
    emoji: "🐟",
    cost: 30,
    items: [
      "Tonno al naturale 80g (x8-10 scatolette: pranzi Lun/Mar/Gio/Ven/Sab + cena Mer)",
      "Sgombro/salmone al naturale in scatola (~2 conf, 200g sgocciolato: pranzo Mer)",
      "Pesce magro fresco: merluzzo, platessa, spigola, orata (250g x1: cena Lun)",
      "Pesce spada / sgombro / tonno fresco (200-250g x1: cena Lun opz 2)",
      "Salmone affumicato (100g x1: cena Sab + opz pranzo Mer/Gio)",
    ],
  },
  {
    category: "Uova e Latticini",
    emoji: "🥚",
    cost: 12,
    items: [
      "Uova (confezione da 6 — 3 uova Mar cena + 3 uova Gio pranzo opz 2)",
      "Yogurt greco 0% bianco (per salsa pollo al curry Gio + farcitura piadina Ven)",
      "Mozzarella light 100g (x2: millefoglie Mar + caprese Mer / insalatona Dom)",
      "Ricotta 100g (x1: alternativa millefoglie Mar, Vallelata ricottina)",
      "Parmigiano grattugiato (per millefoglie, finocchi, polpette)",
      "Formaggio magro spalmabile Exquisa Fitline / Philadelphia Protein (piadina Ven + cena Sab)",
    ],
  },
  {
    category: "Legumi",
    emoji: "🫘",
    cost: 8,
    items: [
      "Ceci in scatola (x3: pranzo Lun/Sab opz 2 240g + cena Ven opz 2 240g)",
      "Lenticchie in scatola (x1-2: alternativa ceci pranzo Lun/Sab)",
      "Piselli 160g (x1: insalata patate Mar pranzo opz 2, anche surgelati)",
      "Burger vegetali (x2 pz: cena Ven — Bio Appetì, Valsoia, Ecor, Kioene, Granarolo)",
      "Farina di ceci (1 cucchiaio: polpette broccoli Sab)",
    ],
  },
  {
    category: "Verdura",
    emoji: "🥬",
    cost: 18,
    items: [
      "Verdure a foglia verde: lattuga, rucola, valeriana, indivia, iceberg (insalatone Mar/Mer/Dom)",
      "Zucchine (millefoglie Mar + contorno Mer/altro)",
      "Broccoli ~250g (polpette Sab cena)",
      "Finocchi ~300g (gratinati Ven cena)",
      "Pomodorini (insalatone e contorni vari)",
      "Carote (insalatone Mar/Mer/Dom)",
      "Sedano (insalatone Mar/Mer)",
      "Funghi (contorni opzionali)",
      "Patate 250g (insalata patate Mar pranzo opz 2)",
      "Avocado x1 grande (insalatona Mer pranzo opz 2 / farcitura piadina Ven)",
      "Verdure per contorno a sazietà (a scelta per ogni cena)",
    ],
  },
  {
    category: "Condimenti",
    emoji: "🫒",
    cost: 6,
    note: "Molti durano più settimane",
    items: [
      "Olio extravergine di oliva (2-4 cucchiaini a pranzo e cena ogni giorno)",
      "Olive nere (30g insalatona Mer + cena Sab)",
      "Curry in polvere (pollo al curry Gio)",
      "Limoni x1 (succo mezzo limone: pollo al curry Gio)",
      "Vino bianco secco (per sfumare: pollo al curry Gio)",
      "Semi di lino/zucca/girasole (1 cucchiaio: insalatona Mar pranzo)",
      "Noci secche / pinoli (10g: pranzo Mer)",
      "Spezie: rosmarino, timo, origano, aglio in polvere, basilico, prezzemolo",
    ],
  },
];

const totalCost = groceryList.reduce((sum, s) => sum + s.cost, 0);
const totalItems = groceryList.reduce((sum, s) => sum + s.items.length, 0);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Lista della Spesa</title>
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0a0a0c;
        color: #e8e6e1;
        padding: 1rem;
        min-height: 100vh;
        font-size: 1.05rem;
        -webkit-text-size-adjust: 100%;
      }

      .summary-bar {
        display: flex;
        gap: 1.5rem;
        align-items: baseline;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
      }
      .summary-total {
        font-size: 1.6rem;
        font-weight: 800;
        color: #c8a000;
      }
      .summary-total small {
        font-size: 0.88rem;
        font-weight: 500;
        color: #888;
      }
      .summary-detail {
        font-size: 0.88rem;
        color: #888;
      }

      .grocery-list {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }

      .grocery-card {
        background: #151518;
        border: 1px solid #252528;
        border-radius: 0.5rem;
      }
      .grocery-card summary {
        list-style: none;
        cursor: pointer;
        padding: 0.55rem 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.85rem;
        font-weight: 600;
      }
      .grocery-card summary::-webkit-details-marker { display: none; }
      .grocery-card summary::before {
        content: "▸";
        color: #555;
        font-size: 0.82rem;
        width: 0.8rem;
        flex-shrink: 0;
      }
      .grocery-card[open] summary::before { content: "▾"; }
      .grocery-card[open] summary { border-bottom: 1px solid #252528; }

      .grocery-card .emoji { font-size: 1rem; }
      .grocery-count {
        font-size: 0.82rem;
        font-weight: 400;
        color: #666;
      }
      .grocery-cost {
        margin-left: auto;
        font-size: 0.88rem;
        font-weight: 600;
        color: #c8a000;
      }

      .grocery-body {
        padding: 0.4rem 0.75rem 0.5rem;
      }

      .grocery-note {
        font-size: 0.78rem;
        color: #666;
        font-style: italic;
        margin-bottom: 0.2rem;
      }

      .grocery-items {
        list-style: none;
        padding: 0;
        columns: 2;
        column-gap: 1rem;
      }
      .grocery-items li {
        font-size: 0.78rem;
        line-height: 1.4;
        padding: 0.1rem 0 0.1rem 0.7rem;
        position: relative;
        color: #bbb;
        break-inside: avoid;
      }
      .grocery-items li::before {
        content: "·";
        position: absolute;
        left: 0;
        color: #555;
        font-weight: 700;
      }

      @media (max-width: 500px) {
        body { padding: 0.75rem; }
        .summary-total { font-size: 1.4rem; }
        .grocery-items { columns: 1; }
      }
    </style>
  </head>
  <body>
    <AdminNav currentPage="grocery" token={token} />

    <h2 style="font-size:1.1rem; margin-bottom:0.75rem; color:#e8e6e1;">
      Spesa Settimanale — Solo Pranzi e Cene
    </h2>

    <div class="summary-bar">
      <div class="summary-total">
        ~{totalCost}€ <small>/settimana</small>
      </div>
      <div class="summary-detail">
        {totalItems} prodotti · {groceryList.length} categorie
      </div>
    </div>

    <div class="grocery-list">
      {groceryList.map((section) => (
        <details class="grocery-card">
          <summary>
            <span class="emoji">{section.emoji}</span>
            {section.category}
            <span class="grocery-count">({section.items.length})</span>
            <span class="grocery-cost">~{section.cost}€</span>
          </summary>
          <div class="grocery-body">
            {"note" in section && section.note && (
              <div class="grocery-note">{section.note}</div>
            )}
            <ul class="grocery-items">
              {section.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>
  </body>
</html>
