          { t: "Integrazione", d: "Espandi la consapevolezza: suoni esterni, suono interno, respiro, sensazioni del corpo. Tutto insieme.", dur: "3 min" },
        ]},
      ];

      var focusAreas = [
        [{ icon: "🫁", title: "Respiro", text: "Oggi concentrati sulla qualità del respiro. Nota la differenza tra inspirazione ed espirazione." },
         { icon: "🌊", title: "Impermanenza", text: "Anicca. Osserva come ogni sensazione nasce, cambia e scompare." }],
        [{ icon: "⚡", title: "Sensazioni", text: "Oggi presta attenzione alle sensazioni sottili: formicolii, vibrazioni, calore." },
         { icon: "🪷", title: "Equanimità", text: "Pratica l'equilibrio perfetto: non desiderare il piacevole, non rifiutare lo spiacevole." }],
        [{ icon: "🧠", title: "Mente", text: "Osserva i pattern mentali di oggi. Quali pensieri tornano? Notali, etichettali, lasciali andare." },
         { icon: "💛", title: "Compassione", text: "Oggi pratica metta verso te stesso. Sei abbastanza. Stai facendo del tuo meglio." }],
        [{ icon: "🦴", title: "Corpo", text: "Il corpo è il tuo ancoramento. Nota le tensioni nascoste: mascella, spalle, addome." },
         { icon: "🔄", title: "Costanza", text: "La pratica regolare conta più della pratica perfetta. Anche 5 minuti oggi sono meglio di zero." }],
        [{ icon: "👁️", title: "Osservazione", text: "Oggi sii l'osservatore neutro. Non chi sente il dolore, ma chi osserva il dolore." },
         { icon: "🌙", title: "Silenzio", text: "Cerca momenti di silenzio nella giornata. Il silenzio non è assenza — è la presenza più pura." }],
        [{ icon: "🌬️", title: "Lasciare andare", text: "Oggi pratica il 'non-fare'. Non resistere a nulla, non aggrapparti a nulla." },
         { icon: "🎯", title: "Intenzione", text: "Setta un'intenzione per la pratica. Non un obiettivo: 'Oggi pratico per coltivare calma'." }],
        [{ icon: "✨", title: "Gratitudine", text: "Inizia con 30 secondi di gratitudine silenziosa. Per il corpo che funziona, per il tempo che hai." },
         { icon: "🏔️", title: "Stabilità", text: "Sii come una montagna: le nuvole passano, il vento soffia, ma la montagna resta." }],
      ];

      var q = quotes[dayOfYear % quotes.length];
      document.getElementById("daily-quote").innerHTML = '<div class="quote">"' + q.text + '"</div><div class="author">— ' + q.author + '</div>';

      var todayFocus = focusAreas[dayOfYear % focusAreas.length];
      document.getElementById("daily-focus").innerHTML = todayFocus.map(function(f) {
        return '<div class="focus-card"><div class="fc-icon">' + f.icon + '</div><div class="fc-title">' + f.title + '</div><div class="fc-text">' + f.text + '</div></div>';
      }).join("");

      var sess = sessions[dayOfYear % sessions.length];
      document.getElementById("daily-session").innerHTML =
        '<h2>' + sess.title + '</h2>' +
        sess.steps.map(function(s, i) {
          return '<div class="step"><div class="step-num">' + (i + 1) + '</div><div class="step-content"><div class="step-title">' + s.t + '</div><div class="step-desc">' + s.d + '</div><span class="step-duration">' + s.dur + '</span></div></div>';
        }).join("");

      // Voice
      var voiceEnabled = true;
      function speak(text, onEnd) {
        if (!voiceEnabled || !window.speechSynthesis) { if (onEnd) onEnd(); return; }
        window.speechSynthesis.cancel();
        var u = new SpeechSynthesisUtterance(text);
        u.lang = "it-IT"; u.rate = 0.85; u.pitch = 0.9;
        var voices = window.speechSynthesis.getVoices();
        var it = voices.filter(function(v) { return v.lang.startsWith("it"); });
        if (it.length > 0) u.voice = it[0];
        if (onEnd) u.onend = onEnd;
        window.speechSynthesis.speak(u);
      }

      document.getElementById("voice-toggle").addEventListener("click", function() {
        voiceEnabled = !voiceEnabled;
        this.textContent = voiceEnabled ? "Voce ON" : "Voce OFF";
        this.classList.toggle("active", voiceEnabled);
        if (!voiceEnabled) window.speechSynthesis.cancel();
      });

      // Wake Lock
      var wakeLock = null;
      async function requestWakeLock() {
        try { if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen'); } catch(e) {}
      }
      function releaseWakeLock() { if (wakeLock) { wakeLock.release(); wakeLock = null; } }
      document.addEventListener('visibilitychange', function() { if (document.visibilityState === 'visible' && isRunning) requestWakeLock(); });

      // Timer
      var timerSeconds = 600, timerTotal = 600;
      var timerInterval = null, isRunning = false;
      var guidedStepIdx = 0, guidedTimeouts = [];
      var timerEndTime = null, pausedRemaining = null;
      var CIRCUMFERENCE = 2 * Math.PI * 90;

      function fmtTimer(s) { var m = Math.floor(s/60); var sec = s%60; return (m<10?"0":"")+m+":"+(sec<10?"0":"")+sec; }
      function updateDisplay() {
        document.getElementById("timer-display").textContent = fmtTimer(timerSeconds);
        var progress = timerTotal > 0 ? timerSeconds / timerTotal : 1;
        document.getElementById("timer-ring").setAttribute("stroke-dashoffset", String(CIRCUMFERENCE * (1 - progress)));
      }

      function parseDuration(dur) { var m = dur.match(/(\d+)/); return m ? parseInt(m[1]) * 60 : 0; }

      function buildGuidedSchedule(totalSec) {
        var steps = sess.steps;
        var totalDeclared = 0;
        steps.forEach(function(s) { totalDeclared += parseDuration(s.dur); });
        var scale = totalDeclared > 0 ? totalSec / totalDeclared : 1;
        var schedule = [], elapsed = 0;
        steps.forEach(function(s, i) {
          var stepSec = Math.round(parseDuration(s.dur) * scale);
          if (stepSec === 0 && i < steps.length - 1) stepSec = Math.round(totalSec / steps.length);
          schedule.push({ at: elapsed, title: s.t, desc: s.d, duration: stepSec, idx: i });
          elapsed += stepSec;
        });
        return schedule;
      }

      function startGuidedVoice() {
        var schedule = buildGuidedSchedule(timerTotal);
        guidedTimeouts = [];
        speak("Iniziamo la sessione di oggi. " + sess.title + ". Trova una posizione comoda e chiudi gli occhi.");
        schedule.forEach(function(step) {
          var t = setTimeout(function() {
            guidedStepIdx = step.idx;
            document.getElementById("breath-label").textContent = step.title;
            speak(step.title + ". " + step.desc);
            var halfWay = Math.round(step.duration / 2);
            if (halfWay > 30 && step.idx < schedule.length - 1) {
              var ht = setTimeout(function() { if (isRunning) speak("Continua così. Resta presente."); }, halfWay * 1000);
              guidedTimeouts.push(ht);
            }
          }, step.at * 1000);
          guidedTimeouts.push(t);
        });
        var lastMin = setTimeout(function() { if (isRunning) speak("Un minuto alla fine. Porta la consapevolezza a tutto il corpo."); }, (timerTotal - 60) * 1000);
        guidedTimeouts.push(lastMin);
      }

      function clearGuidedVoice() { guidedTimeouts.forEach(function(t) { clearTimeout(t); }); guidedTimeouts = []; window.speechSynthesis.cancel(); }

      document.getElementById("timer-presets").addEventListener("click", function(e) {
        if (e.target.tagName !== "BUTTON" || isRunning) return;
        var min = parseInt(e.target.dataset.min);
        timerSeconds = min * 60; timerTotal = timerSeconds;
        updateDisplay();
        document.querySelectorAll(".timer-presets button").forEach(function(b) { b.classList.remove("active"); });
        e.target.classList.add("active");
      });

      var breathPhases = ["Inspira...", "Trattieni...", "Espira...", "Pausa..."];
      var breathIdx = 0, breathInterval = null;

      function timerTick() {
        if (!isRunning || !timerEndTime) return;
        var remaining = Math.max(0, Math.round((timerEndTime - Date.now()) / 1000));
        timerSeconds = remaining;
        updateDisplay();
        if (remaining <= 0) {
          clearInterval(timerInterval); clearInterval(breathInterval);
          clearGuidedVoice(); releaseWakeLock();
          isRunning = false; timerEndTime = null;
          var btn = document.getElementById("timer-start");
          btn.textContent = "Inizia"; btn.className = "timer-btn start";
          document.getElementById("breath-label").textContent = "Sessione completata";
          speak("La sessione è terminata. Apri lentamente gli occhi. Grazie per aver praticato.");
          autoSaveSession();
        }
      }

      function autoSaveSession() {
        var durationMin = Math.round(timerTotal / 60);
        saveSession(todayStr(), durationMin, sess.title);
      }

      document.getElementById("timer-start").addEventListener("click", function() {
        var btn = this;
        if (!isRunning) {
          isRunning = true;
          btn.textContent = "Pausa"; btn.className = "timer-btn pause";
          requestWakeLock();
          if (pausedRemaining != null) {
            timerEndTime = Date.now() + pausedRemaining * 1000;
            pausedRemaining = null;
          } else {
            timerEndTime = Date.now() + timerSeconds * 1000;
            startGuidedVoice();
          }
          breathIdx = 0;
          document.getElementById("breath-label").textContent = breathPhases[0];
          breathInterval = setInterval(function() {
            breathIdx = (breathIdx + 1) % 4;
            if (!window.speechSynthesis.speaking) document.getElementById("breath-label").textContent = breathPhases[breathIdx];
          }, 2000);
          timerInterval = setInterval(timerTick, 500);
        } else {
          isRunning = false;
          pausedRemaining = Math.max(0, Math.round((timerEndTime - Date.now()) / 1000));
          timerEndTime = null;
          clearInterval(timerInterval); clearInterval(breathInterval);
          clearGuidedVoice(); releaseWakeLock();
          btn.textContent = "Riprendi"; btn.className = "timer-btn start";
          document.getElementById("breath-label").textContent = "In pausa";
        }
      });

      document.getElementById("timer-reset").addEventListener("click", function() {
        isRunning = false; timerEndTime = null; pausedRemaining = null;
        clearInterval(timerInterval); clearInterval(breathInterval);
        clearGuidedVoice(); releaseWakeLock();
        var activePreset = document.querySelector(".timer-presets button.active");
        timerSeconds = activePreset ? parseInt(activePreset.dataset.min) * 60 : 600;
        timerTotal = timerSeconds;
        updateDisplay();
        document.getElementById("timer-start").textContent = "Inizia";
        document.getElementById("timer-start").className = "timer-btn start";
        document.getElementById("breath-label").textContent = "";
      });

      if (window.speechSynthesis) {
        window.speechSynthesis.getVoices();
        window.speechSynthesis.onvoiceschanged = function() { window.speechSynthesis.getVoices(); };
      }

      updateDisplay();
      loadData();
    </script>
