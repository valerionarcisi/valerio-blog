---
import { timeSafeEqual } from "~/lib/auth";
import AdminNav from "~/components/AdminNav.astro";
import { quotes as allQuotes } from "~/data/meditation-quotes.js";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, import.meta.env.ADMIN_TOKEN);

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

const quotesJson = JSON.stringify(allQuotes);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Meditazione Vipassana</title>
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, -apple-system, sans-serif; background: #0a0a0c; color: #e8e6e1; padding: 1.5rem; min-height: 100vh; }

      h1 { font-family: 'Staatliches', Impact, sans-serif; color: #c9a84c; font-size: 1.8rem; letter-spacing: 0.02em; margin-bottom: 0.3rem; }
      .subtitle { color: #8a8a8e; font-size: 0.85rem; margin-bottom: 1.5rem; }

      .day-badge {
        display: inline-block;
        background: rgba(155, 89, 182, 0.12);
        border: 1px solid rgba(155, 89, 182, 0.3);
        color: #bb86fc;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
        margin-bottom: 1.5rem;
      }

      /* Stats grid */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        margin-bottom: 1.5rem;
      }
      .stat-box {
        background: #141416;
        border: 1px solid #222;
        border-radius: 8px;
        padding: 0.75rem;
        text-align: center;
      }
      .stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.4rem; font-weight: 700; color: #bb86fc; }
      .stat-label { font-size: 0.65rem; color: #8a8a8e; margin-top: 0.2rem; text-transform: uppercase; letter-spacing: 0.05em; }

      /* Heatmap */
      .heatmap-section {
        background: #141416;
        border: 1px solid #222;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        overflow-x: auto;
      }
      .heatmap-title { font-size: 0.7rem; color: #8a8a8e; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
      .heatmap-grid {
        display: grid;
        grid-template-rows: repeat(7, 1fr);
        grid-auto-flow: column;
        gap: 2px;
        width: fit-content;
        min-width: 100%;
      }
      .heatmap-cell {
        width: 11px;
        height: 11px;
        border-radius: 2px;
        background: #1a1a1e;
        cursor: pointer;
        position: relative;
      }
      .heatmap-cell.selected { outline: 2px solid #c9a84c; outline-offset: 1px; z-index: 1; }
      .heatmap-cell.l1 { background: rgba(155, 89, 182, 0.25); }
      .heatmap-cell.l2 { background: rgba(155, 89, 182, 0.45); }
      .heatmap-cell.l3 { background: rgba(155, 89, 182, 0.7); }
      .heatmap-cell.l4 { background: #bb86fc; }
      .heatmap-cell.today { outline: 1px solid #c9a84c; outline-offset: 1px; }
      .heatmap-legend {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        margin-top: 0.5rem;
        font-size: 0.6rem;
        color: #666;
      }
      .heatmap-legend-cell {
        width: 10px;
        height: 10px;
        border-radius: 2px;
      }

      .heatmap-detail {
        display: none;
        margin-top: 0.75rem;
        padding: 0.75rem 1rem;
        background: #1a1a1e;
        border: 1px solid #333;
        border-radius: 8px;
        animation: fadeSlide 0.2s ease;
      }
      .heatmap-detail.visible { display: block; }
      @keyframes fadeSlide {
        from { opacity: 0; transform: translateY(-4px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .heatmap-detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
      }
      .heatmap-detail-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: #bb86fc;
        font-weight: 600;
      }
      .heatmap-detail-close {
        background: none;
        border: none;
        color: #555;
        cursor: pointer;
        font-size: 1rem;
        padding: 0.2rem 0.4rem;
        line-height: 1;
      }
      .heatmap-detail-close:hover { color: #e8e6e1; }
      .heatmap-detail-empty {
        color: #555;
        font-size: 0.75rem;
        font-style: italic;
      }
      .heatmap-detail-session {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 0;
      }
      .heatmap-detail-session + .heatmap-detail-session {
        border-top: 1px solid #222;
      }
      .heatmap-detail-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #bb86fc;
        flex-shrink: 0;
      }
      .heatmap-detail-type {
        font-size: 0.78rem;
        color: #e8e6e1;
        flex: 1;
      }
      .heatmap-detail-min {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: #8a8a8e;
        flex-shrink: 0;
      }
      .heatmap-detail-total {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        color: #c9a84c;
        text-align: right;
        margin-top: 0.4rem;
        padding-top: 0.4rem;
        border-top: 1px solid #333;
      }

      /* Streak bar */
      .streak-bar {
        background: #141416;
        border: 1px solid #222;
        border-radius: 8px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 0.8rem;
      }
      .streak-info { display: flex; align-items: center; gap: 0.8rem; }
      .streak-num { font-family: 'JetBrains Mono', monospace; font-size: 1.6rem; font-weight: 700; color: #bb86fc; }
      .streak-text { font-size: 0.75rem; color: #8a8a8e; }
      .streak-best { font-size: 0.65rem; color: #555; }
      .today-status {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #555;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
      }
      .today-status.active { color: #bb86fc; background: rgba(155,89,182,0.1); border: 1px solid rgba(155,89,182,0.2); }

      /* Quote */
      .meditation-hero {
        background: linear-gradient(135deg, #141416 0%, #1a1520 100%);
        border: 1px solid rgba(155, 89, 182, 0.2);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        text-align: center;
      }
      .meditation-hero .quote { font-size: 1.1rem; font-style: italic; color: #ccc; line-height: 1.6; max-width: 600px; margin: 0 auto 1rem; }
      .meditation-hero .author { font-size: 0.75rem; color: #8a8a8e; }

      /* Focus cards */
      .focus-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
      .focus-card { background: #141416; border: 1px solid #222; border-radius: 8px; padding: 1.2rem; }
      .focus-card:hover { border-color: rgba(155,89,182,0.4); }
      .focus-card .fc-icon { font-size: 1.3rem; margin-bottom: 0.5rem; }
      .focus-card .fc-title { font-size: 0.8rem; color: #bb86fc; font-weight: 600; margin-bottom: 0.3rem; }
      .focus-card .fc-text { font-size: 0.78rem; color: #aaa; line-height: 1.5; }

      /* Timer */
      .timer-section {
        background: #141416;
        border: 1px solid #222;
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        text-align: center;
      }
      .timer-ring-wrap { position: relative; width: 200px; height: 200px; margin: 0 auto; }
      .timer-ring-svg { width: 200px; height: 200px; transform: rotate(-90deg); }
      .timer-ring-bg { fill: none; stroke: #222; stroke-width: 6; }
      .timer-ring-fg { fill: none; stroke: #bb86fc; stroke-width: 6; stroke-linecap: round; transition: stroke-dashoffset 0.5s linear; }
      .timer-ring-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
      }
      .timer-display { font-family: 'JetBrains Mono', monospace; font-size: 2.8rem; color: #e8e6e1; letter-spacing: 0.05em; }
      .timer-label { font-size: 0.7rem; color: #8a8a8e; }
      .breath-label { text-align: center; font-size: 0.85rem; color: #bb86fc; min-height: 1.4em; margin: 0.5rem 0; }

      .active-guide { display: none; background: linear-gradient(135deg, rgba(155,89,182,0.12), rgba(201,168,76,0.08)); border: 1px solid rgba(155,89,182,0.3); border-radius: 12px; padding: 1.2rem; margin: 1rem 0; text-align: center; animation: guideIn 0.5s ease; }
      .active-guide.visible { display: block; }
      .active-guide .guide-step-num { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #c9a84c; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.3rem; }
      .active-guide .guide-title { font-family: 'Staatliches', Impact, sans-serif; font-size: 1.4rem; color: #bb86fc; margin-bottom: 0.5rem; }
      .active-guide .guide-desc { font-size: 1rem; color: #c8c6c1; line-height: 1.6; }
      .active-guide .guide-hint { font-size: 0.8rem; color: #8a8a8e; margin-top: 0.8rem; font-style: italic; }
      @keyframes guideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
      .timer-presets { display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 1.2rem; flex-wrap: wrap; }
      .timer-presets button {
        padding: 0.5rem 0.9rem;
        background: #1a1a1c;
        border: 1px solid #333;
        color: #8a8a8e;
        cursor: pointer;
        border-radius: 4px;
        font-size: 0.8rem;
        transition: all 0.2s;
        min-height: 44px;
      }
      .timer-presets button.active { border-color: #bb86fc; color: #bb86fc; }
      .timer-presets button:hover { border-color: #bb86fc; color: #bb86fc; }
      .timer-controls { display: flex; gap: 0.8rem; justify-content: center; }
      .timer-btn {
        padding: 0.7rem 1.8rem;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 600;
        min-height: 44px;
      }
      .timer-btn.start { background: #bb86fc; color: #0a0a0c; }
      .timer-btn.start:hover { background: #ce9ffc; }
      .timer-btn.pause { background: #f39c12; color: #0a0a0c; }
      .timer-btn.reset { background: #333; color: #8a8a8e; }
      .timer-btn.reset:hover { background: #444; color: #e8e6e1; }
      .timer-btn.voice { background: #333; color: #8a8a8e; font-size: 0.8rem; }
      .timer-btn.voice.active { background: rgba(155,89,182,0.2); color: #bb86fc; border: 1px solid rgba(155,89,182,0.3); }

      /* Session card */
      .session-card {
        background: #141416;
        border: 1px solid #222;
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 1.5rem;
      }
      .session-card h2 { font-family: 'Staatliches', Impact, sans-serif; color: #bb86fc; font-size: 1.1rem; letter-spacing: 0.02em; margin-bottom: 1rem; }
      .session-card .step { display: flex; gap: 1rem; margin-bottom: 1.2rem; align-items: flex-start; }
      .step-num { flex-shrink: 0; width: 28px; height: 28px; line-height: 28px; text-align: center; border-radius: 50%; background: rgba(155, 89, 182, 0.15); color: #bb86fc; font-size: 0.75rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
      .step-content { flex: 1; }
      .step-title { font-weight: 600; color: #e8e6e1; font-size: 0.9rem; margin-bottom: 0.2rem; }
      .step-desc { color: #aaa; font-size: 0.82rem; line-height: 1.5; }
      .step-duration { display: inline-block; background: rgba(155,89,182,0.1); color: #bb86fc; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.65rem; font-family: 'JetBrains Mono', monospace; margin-top: 0.3rem; }

      .loading-msg { text-align: center; color: #555; font-size: 0.8rem; padding: 2rem; }

      /* Journey section */
      .journey-section {
        background: linear-gradient(135deg, #141416 0%, #1a1520 100%);
        border: 1px solid rgba(155, 89, 182, 0.2);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .journey-title {
        font-family: 'Staatliches', Impact, sans-serif;
        color: #c9a84c;
        font-size: 1rem;
        letter-spacing: 0.02em;
        margin-bottom: 0.8rem;
      }
      .journey-phase {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
      }
      .journey-icon {
        font-size: 1.8rem;
        flex-shrink: 0;
        line-height: 1;
      }
      .journey-phase-name {
        font-weight: 700;
        color: #bb86fc;
        font-size: 0.95rem;
        margin-bottom: 0.2rem;
      }
      .journey-phase-desc {
        color: #aaa;
        font-size: 0.85rem;
        line-height: 1.5;
      }
      .journey-progress {
        display: flex;
        gap: 3px;
        margin-top: 1rem;
      }
      .journey-progress-dot {
        height: 4px;
        border-radius: 2px;
        flex: 1;
        background: #222;
        transition: background 0.3s;
      }
      .journey-progress-dot.filled { background: #bb86fc; }
      .journey-progress-dot.current { background: #c9a84c; }
      .journey-month-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.6rem;
        color: #555;
        margin-top: 0.3rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .journey-suggestion {
        background: rgba(155, 89, 182, 0.08);
        border: 1px solid rgba(155, 89, 182, 0.15);
        border-radius: 8px;
        padding: 0.8rem 1rem;
        margin-top: 1rem;
        font-size: 0.82rem;
        color: #ccc;
        line-height: 1.5;
      }
      .journey-suggestion strong { color: #bb86fc; }
      .journey-tip {
        background: rgba(201, 168, 76, 0.08);
        border: 1px solid rgba(201, 168, 76, 0.15);
        border-radius: 8px;
        padding: 0.8rem 1rem;
        margin-top: 0.6rem;
        font-size: 0.8rem;
        color: #c9a84c;
        line-height: 1.5;
      }

      @media (max-width: 700px) {
        .focus-grid { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .timer-display { font-size: 2.2rem; }
        body { padding: 1rem; font-size: 1.05rem; }
        .heatmap-cell { width: 9px; height: 9px; }
        h1 { font-size: 2rem; }
        .subtitle { font-size: 0.95rem; }
        .stat-value { font-size: 1.6rem; }
        .stat-label { font-size: 0.75rem; }
        .streak-num { font-size: 1.8rem; }
        .streak-text { font-size: 0.85rem; }
        .today-status { font-size: 0.85rem; }
        .meditation-hero .quote { font-size: 1.2rem; }
        .meditation-hero .author { font-size: 0.85rem; }
        .focus-card .fc-title { font-size: 0.9rem; }
        .focus-card .fc-text { font-size: 0.88rem; }
        .timer-presets button { font-size: 0.9rem; }
        .timer-btn { font-size: 1rem; padding: 0.8rem 2rem; }
        .session-card h2 { font-size: 1.2rem; }
        .step-title { font-size: 1rem; }
        .step-desc { font-size: 0.92rem; }
        .day-badge { font-size: 0.85rem; }
        .heatmap-title { font-size: 0.8rem; }
        .heatmap-detail-type { font-size: 0.88rem; }
        .heatmap-detail-min { font-size: 0.82rem; }
        .heatmap-detail-date { font-size: 0.9rem; }
        .breath-label { font-size: 0.95rem; }
        .active-guide .guide-title { font-size: 1.3rem; }
        .active-guide .guide-desc { font-size: 1.05rem; }
        .active-guide .guide-hint { font-size: 0.9rem; }
        .journey-phase-name { font-size: 1.05rem; }
        .journey-phase-desc { font-size: 0.95rem; }
        .journey-suggestion { font-size: 0.92rem; }
        .journey-tip { font-size: 0.9rem; }
      }
    </style>
  </head>
  <body>
    <AdminNav currentPage="meditation" token={token} />
    <h1>Meditazione Vipassana</h1>
    <p class="subtitle">Pratica quotidiana di consapevolezza — osserva, non reagire</p>

    <div class="day-badge" id="day-badge"></div>

    <div class="stats-grid" id="stats-grid">
      <div class="stat-box"><div class="stat-value" id="stat-streak">-</div><div class="stat-label">Streak</div></div>
      <div class="stat-box"><div class="stat-value" id="stat-total">-</div><div class="stat-label">Sessioni</div></div>
      <div class="stat-box"><div class="stat-value" id="stat-minutes">-</div><div class="stat-label">Min totali</div></div>
      <div class="stat-box"><div class="stat-value" id="stat-month">-</div><div class="stat-label">Questo mese</div></div>
    </div>

    <div class="journey-section" id="journey-section">
      <div class="journey-title">Il tuo percorso</div>
      <div id="journey-content"><div class="loading-msg">Caricamento percorso...</div></div>
    </div>

    <div class="heatmap-section">
      <div class="heatmap-title">Ultimi 365 giorni</div>
      <div class="heatmap-grid" id="heatmap"></div>
      <div class="heatmap-legend">
        <span>Meno</span>
        <div class="heatmap-legend-cell" style="background:#1a1a1e"></div>
        <div class="heatmap-legend-cell" style="background:rgba(155,89,182,0.25)"></div>
        <div class="heatmap-legend-cell" style="background:rgba(155,89,182,0.45)"></div>
        <div class="heatmap-legend-cell" style="background:rgba(155,89,182,0.7)"></div>
        <div class="heatmap-legend-cell" style="background:#bb86fc"></div>
        <span>Di più</span>
      </div>
      <div class="heatmap-detail" id="heatmap-detail"></div>
    </div>

    <div class="streak-bar">
      <div class="streak-info">
        <div class="streak-num" id="streak-num">0</div>
        <div>
          <div class="streak-text">giorni consecutivi</div>
          <div class="streak-best" id="streak-best"></div>
        </div>
      </div>
      <span class="today-status" id="today-status"></span>
    </div>

    <div class="meditation-hero" id="daily-quote"></div>

    <div class="focus-grid" id="daily-focus"></div>

    <div class="timer-section">
      <h2 style="font-family:'Staatliches',Impact,sans-serif;color:#bb86fc;font-size:1.1rem;letter-spacing:0.02em;margin-bottom:0.5rem;">Timer Meditazione</h2>
      <div class="timer-ring-wrap">
        <svg class="timer-ring-svg" viewBox="0 0 200 200">
          <circle class="timer-ring-bg" cx="100" cy="100" r="90" />
          <circle class="timer-ring-fg" id="timer-ring" cx="100" cy="100" r="90" stroke-dasharray="565.48" stroke-dashoffset="0" />
        </svg>
        <div class="timer-ring-text">
          <div class="timer-display" id="timer-display">10:00</div>
          <div class="timer-label">minuti</div>
        </div>
      </div>
      <div class="breath-label" id="breath-label"></div>
      <div class="active-guide" id="active-guide">
        <div class="guide-step-num" id="guide-step-num"></div>
        <div class="guide-title" id="guide-title"></div>
        <div class="guide-desc" id="guide-desc"></div>
        <div class="guide-hint" id="guide-hint"></div>
      </div>
      <div class="timer-presets" id="timer-presets">
        <button data-min="5">5 min</button>
        <button data-min="10" class="active">10 min</button>
        <button data-min="15">15 min</button>
        <button data-min="20">20 min</button>
        <button data-min="30">30 min</button>
        <button data-min="45">45 min</button>
      </div>
      <div class="timer-controls">
        <button class="timer-btn start" id="timer-start">Inizia</button>
        <button class="timer-btn reset" id="timer-reset">Reset</button>
        <button class="timer-btn voice active" id="voice-toggle">Voce ON</button>
      </div>
    </div>

    <div class="session-card" id="daily-session"></div>

    <script is:inline define:vars={{ token, quotesJson }}>
      var API_URL = '/api/admin/meditation';
      var AUTH_HEADER = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
      var allQuotes = JSON.parse(quotesJson);
      var meditationData = [];

      var now = new Date();
      var dayOfYear = Math.floor((now - new Date(now.getFullYear(), 0, 0)) / 86400000);
      var dayNames = ["Domenica","Lunedì","Martedì","Mercoledì","Giovedì","Venerdì","Sabato"];
      var monthNames = ["Gennaio","Febbraio","Marzo","Aprile","Maggio","Giugno","Luglio","Agosto","Settembre","Ottobre","Novembre","Dicembre"];
      document.getElementById("day-badge").textContent = dayNames[now.getDay()] + " " + now.getDate() + " " + monthNames[now.getMonth()] + " — Giorno " + dayOfYear;

      function todayStr() {
        var d = new Date();
        return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,"0") + "-" + String(d.getDate()).padStart(2,"0");
      }

      function dateStr(d) {
        return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,"0") + "-" + String(d.getDate()).padStart(2,"0");
      }

      function groupByDate(rows) {
        var map = {};
        rows.forEach(function(r) {
          if (!map[r.date]) map[r.date] = { date: r.date, sessions: [], total_min: 0 };
          map[r.date].sessions.push(r);
          map[r.date].total_min += (r.duration_min || 0);
        });
        return map;
