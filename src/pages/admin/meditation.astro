      function getMonthsOfPractice(dates) {
        if (dates.length === 0) return 0;
        var sorted = dates.slice().sort();
        var first = new Date(sorted[0]);
        var now = new Date();
        var months = (now.getFullYear() - first.getFullYear()) * 12 + (now.getMonth() - first.getMonth());
        var consistency = dates.length / Math.max(1, Math.round((now - first) / 86400000));
        if (consistency < 0.3) months = Math.floor(months * consistency / 0.3);
        return Math.max(0, months);
      }

