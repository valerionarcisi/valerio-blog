---
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized =
  token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Radar opportunità · Admin</title>
    <style is:global>
      :root {
        --rd-green: #2e8b57;
        --rd-yellow: #b8860b;
        --rd-red: #c0392b;
        --rd-grey: var(--foglio-ink-mute);
      }
      .foglio body.admin {
        padding: 1rem 0.9rem 3rem;
      }
      .rd-wrap {
        max-width: 900px;
        margin: 0 auto;
      }
      .rd-head {
        margin-bottom: 1.25rem;
      }
      .rd-head h1 {
        margin-bottom: 0.15rem;
      }

      /* Filters — sticky bar */
      .rd-filters {
        position: sticky;
        top: 0;
        z-index: 5;
        background: var(--foglio-bg);
        padding: 0.75rem 0;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--foglio-rule);
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
      }
      .rd-search {
        flex: 1 1 100%;
        min-width: 0;
      }
      .foglio body.admin .rd-chip {
        padding: 0.55rem 0.8rem;
        font-size: 0.7rem;
      }

      /* Grid — 1 col mobile, 2 col >=720px */
      .rd-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 720px) {
        .rd-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .foglio body.admin .rd-card {
        margin-bottom: 0;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }
      .rd-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.6rem;
      }
      .rd-title {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-lg);
        font-weight: 500;
        line-height: 1.2;
        margin: 0;
        color: var(--foglio-ink);
      }
      .rd-source {
        flex: 0 0 auto;
        font-family: var(--foglio-mono);
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--foglio-ink-soft);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-sm);
        padding: 0.2rem 0.45rem;
        white-space: nowrap;
      }

      .rd-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 0.9rem;
        font-family: var(--foglio-mono);
        font-size: 0.72rem;
      }
      .rd-countdown {
        font-weight: 600;
      }
      .cd-green {
        color: var(--rd-green);
      }
      .cd-yellow {
        color: var(--rd-yellow);
      }
      .cd-red {
        color: var(--rd-red);
      }
      .cd-grey {
        color: var(--rd-grey);
      }
      .rd-prob {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        font-weight: 600;
        color: #fff;
      }
      .prob-green {
        background: var(--rd-green);
      }
      .prob-yellow {
        background: var(--rd-yellow);
      }
      .prob-grey {
        background: var(--rd-grey);
      }

      .rd-where {
        font-family: var(--foglio-sans);
        font-size: var(--foglio-fs-sm);
        color: var(--foglio-ink-soft);
      }
      .rd-body p {
        margin: 0 0 0.5rem;
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.5;
        color: var(--foglio-ink);
      }
      .rd-body p .lbl {
        font-family: var(--foglio-mono);
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--foglio-ink-mute);
        display: block;
        margin-bottom: 0.1rem;
      }

      .rd-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }
      .rd-tag {
        font-family: var(--foglio-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.15rem 0.45rem;
        border-radius: var(--foglio-radius-sm);
        border: 1px solid var(--foglio-rule);
        color: var(--foglio-ink-soft);
      }
      .rd-tag.hot {
        border-color: var(--foglio-accent);
        color: var(--foglio-accent);
      }

      .foglio body.admin .rd-open {
        align-self: flex-start;
        text-decoration: none;
        margin-top: 0.2rem;
      }

      .rd-section-title {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--foglio-ink-soft);
        margin: 2rem 0 0.5rem;
        cursor: pointer;
        user-select: none;
      }
      details.rd-expired > summary {
        list-style: none;
      }
      details.rd-expired > summary::-webkit-details-marker {
        display: none;
      }
    </style>
  </head>
  <body class="admin">
    <div class="rd-wrap">
      <header class="rd-head">
        <h1>Radar <em class="acc">opportunità</em></h1>
        <p class="subtitle" id="rd-updated">Caricamento…</p>
      </header>

      <div class="rd-filters">
        <input
          class="rd-search"
          id="rd-search"
          type="search"
          placeholder="Cerca per titolo, descrizione, fonte…"
        />
        <button class="pill rd-chip" data-filter="onlineHybrid">
          Online/Hybrid
        </button>
        <button class="pill rd-chip" data-filter="gratis">Gratis</button>
        <button class="pill rd-chip" data-filter="soon">≤ 30 giorni</button>
        <button class="pill rd-chip" data-filter="prob">Prob ≥ 50%</button>
      </div>

      <div class="rd-grid" id="rd-active"></div>
      <div id="rd-empty" class="empty" hidden>Nessuna opportunità caricata</div>

      <details class="rd-expired" id="rd-expired-wrap" hidden>
        <summary class="rd-section-title" id="rd-expired-summary"></summary>
        <div class="rd-grid" id="rd-expired" style="margin-top:0.75rem"></div>
      </details>
    </div>

    <script>
      type Item = {
        id: string;
        title: string;
        what: string;
        forWho: string;
        deadline: string | null;
        whereWhen: string;
        probability: number | null;
        why: string;
        action: string;
        link: string;
        source: string;
        tags: string[];
        status: string;
      };

      const DAY = 86400000;
      const activeFilters = new Set<string>();
      let query = "";
      let items: Item[] = [];

      const fmtDate = new Intl.DateTimeFormat("it-IT", {
        day: "numeric",
        month: "short",
        year: "numeric",
      });

      function esc(s: string): string {
        const d = document.createElement("div");
        d.textContent = s ?? "";
        return d.innerHTML;
      }

      function startOfToday(): number {
        const n = new Date();
        return new Date(n.getFullYear(), n.getMonth(), n.getDate()).getTime();
      }

      function daysLeft(deadline: string | null): number | null {
        if (!deadline) return null;
        const d = new Date(deadline + "T00:00:00");
        if (Number.isNaN(d.getTime())) return null;
        return Math.round((d.getTime() - startOfToday()) / DAY);
      }

      function countdownHtml(deadline: string | null): string {
        const dl = daysLeft(deadline);
        if (dl === null)
          return '<span class="rd-countdown cd-grey">senza scadenza</span>';
        if (dl < 0) {
          const d = new Date(deadline + "T00:00:00");
          return `<span class="rd-countdown cd-grey">scaduta il ${esc(fmtDate.format(d))}</span>`;
        }
        if (dl === 0) return '<span class="rd-countdown cd-red">oggi</span>';
        const cls = dl > 14 ? "cd-green" : dl >= 4 ? "cd-yellow" : "cd-red";
        return `<span class="rd-countdown ${cls}">tra ${dl} giorn${dl === 1 ? "o" : "i"}</span>`;
      }

      function probHtml(p: number | null): string {
        if (p === null || p === undefined) return "";
        const cls =
          p >= 55 ? "prob-green" : p >= 30 ? "prob-yellow" : "prob-grey";
        return `<span class="rd-prob ${cls}">${p}%</span>`;
      }

      function tagsHtml(tags: string[]): string {
        const hot = new Set(["online", "hybrid", "gratis"]);
        return (tags || [])
          .map(
            (t) =>
              `<span class="rd-tag${hot.has(t) ? " hot" : ""}">${esc(t)}</span>`,
          )
          .join("");
      }

      function cardHtml(it: Item): string {
        return `
        <article class="card rd-card">
          <div class="rd-card-top">
            <h2 class="rd-title">${esc(it.title)}</h2>
            <span class="rd-source">${esc(it.source)}</span>
          </div>
          <div class="rd-meta">
            ${countdownHtml(it.deadline)}
            ${probHtml(it.probability)}
          </div>
          ${it.whereWhen ? `<div class="rd-where">${esc(it.whereWhen)}</div>` : ""}
          <div class="rd-body">
            ${it.what ? `<p><span class="lbl">Cos'è</span>${esc(it.what)}</p>` : ""}
            ${it.why ? `<p><span class="lbl">Perché</span>${esc(it.why)}</p>` : ""}
            ${it.action ? `<p><span class="lbl">Azione</span>${esc(it.action)}</p>` : ""}
          </div>
          <div class="rd-tags">${tagsHtml(it.tags)}</div>
          ${
            it.link
              ? `<a class="btn rd-open" href="${esc(it.link)}" target="_blank" rel="noopener">Apri ↗</a>`
              : ""
          }
        </article>`;
      }

      function matchesFilters(it: Item): boolean {
        if (activeFilters.has("onlineHybrid")) {
          if (!(it.tags || []).some((t) => t === "online" || t === "hybrid"))
            return false;
        }
        if (activeFilters.has("gratis") && !(it.tags || []).includes("gratis"))
          return false;
        if (activeFilters.has("soon")) {
          const dl = daysLeft(it.deadline);
          if (dl === null || dl < 0 || dl > 30) return false;
        }
        if (activeFilters.has("prob")) {
          if (it.probability === null || it.probability < 50) return false;
        }
        if (query) {
          const hay = `${it.title} ${it.what} ${it.source}`.toLowerCase();
          if (!hay.includes(query)) return false;
        }
        return true;
      }

      function sortByDeadline(a: Item, b: Item): number {
        const da = daysLeft(a.deadline);
        const db = daysLeft(b.deadline);
        if (da === null && db === null) return 0;
        if (da === null) return 1;
        if (db === null) return -1;
        return da - db;
      }

      function render(): void {
        const today = startOfToday();
        const visible = items.filter(matchesFilters);
        const isExpired = (it: Item) => {
          const d = it.deadline
            ? new Date(it.deadline + "T00:00:00").getTime()
            : NaN;
          return !Number.isNaN(d) && d < today;
        };

        const active = visible
          .filter((it) => !isExpired(it))
          .sort(sortByDeadline);
        const expired = visible.filter(isExpired).sort(sortByDeadline);

        const activeEl = document.getElementById("rd-active")!;
        const emptyEl = document.getElementById("rd-empty")!;
        activeEl.innerHTML = active.map(cardHtml).join("");
        emptyEl.hidden = active.length > 0 || expired.length > 0;

        const wrap = document.getElementById(
          "rd-expired-wrap",
        ) as HTMLDetailsElement;
        const expiredEl = document.getElementById("rd-expired")!;
        const summaryEl = document.getElementById("rd-expired-summary")!;
        if (expired.length > 0) {
          wrap.hidden = false;
          expiredEl.innerHTML = expired.map(cardHtml).join("");
          summaryEl.textContent = `▸ Scadute (${expired.length})`;
        } else {
          wrap.hidden = true;
        }
      }

      function wireControls(): void {
        document
          .querySelectorAll<HTMLButtonElement>(".rd-chip")
          .forEach((btn) => {
            btn.addEventListener("click", () => {
              const key = btn.dataset.filter!;
              if (activeFilters.has(key)) {
                activeFilters.delete(key);
                btn.classList.remove("active");
              } else {
                activeFilters.add(key);
                btn.classList.add("active");
              }
              render();
            });
          });
        const search = document.getElementById("rd-search") as HTMLInputElement;
        search.addEventListener("input", () => {
          query = search.value.trim().toLowerCase();
          render();
        });
      }

      async function init(): Promise<void> {
        wireControls();
        try {
          const res = await fetch("/radar.json", { cache: "no-store" });
          if (!res.ok) throw new Error(String(res.status));
          const data = await res.json();
          items = Array.isArray(data.items) ? data.items : [];
          const updated = document.getElementById("rd-updated")!;
          updated.textContent = data.updatedAt
            ? `Aggiornato il ${fmtDate.format(new Date(data.updatedAt))}`
            : "";
          render();
        } catch {
          items = [];
          document.getElementById("rd-updated")!.textContent = "";
          render();
        }
      }

      init();
    </script>
  </body>
</html>
