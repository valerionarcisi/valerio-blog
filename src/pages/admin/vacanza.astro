---
import { Icon } from "astro-icon/components";
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

function mapsSearch(query: string): string {
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
}
function mapsDirections(from: string, to: string): string {
  return `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(from)}&destination=${encodeURIComponent(to)}`;
}
function commons(file: string, w = 1000): string {
  return `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(file)}?width=${w}`;
}

const heroPhoto = commons("Lake bled 2021.jpg", 1400);

const crew = [
  { name: "Valerio", role: "Pilota", icon: "ph:steering-wheel" },
  { name: "Adriana", role: "Co-pilota", icon: "ph:user" },
  { name: "Bianca", role: "7 anni", icon: "ph:user-circle" },
  { name: "Lea", role: "4 anni", icon: "ph:baby" },
];

const stops = [
  { city: "Lubiana", nights: "6 notti · base unica", drive: "Da casa · ~600 km · 6h", icon: "ph:castle-turret", photo: commons("Downtown Ljubljana.JPG", 900) },
  { city: "Postojna + Predjama", nights: "gita in giornata", drive: "Da Lubiana · ~45 min", icon: "ph:train", photo: commons("Postojna Cave - Slovenia.jpg", 900) },
  { city: "Lago di Bled", nights: "gita in giornata", drive: "Da Lubiana · ~45 min", icon: "ph:boat", photo: commons("Lake bled 2021.jpg", 900) },
  { city: "Bohinj + Vintgar", nights: "gita in giornata", drive: "Da Lubiana · ~1h", icon: "ph:mountains", photo: commons("Church of st. John the Baptist at Lake Bohinj, next to the bridge.jpg", 900) },
];

const timeline = [
  {
    day: "Mer 5/8",
    title: "Casa → Lubiana",
    desc: "Dopo due giorni per fare le valigie con calma (il 3 e 4), si parte. Tratta più lunga (~6h) con sosta pranzo verso Trieste. Arrivo a Lubiana nel pomeriggio: check-in nella base unica e prima passeggiata in centro, gelato sul fiume.",
    icon: "ph:car",
    places: [
      { label: "Rotta casa → Lubiana", url: mapsDirections("Porto Sant'Elpidio, FM", "Ljubljana") },
      { label: "Centro di Lubiana", url: mapsSearch("Ljubljana old town") },
    ],
  },
  {
    day: "Gio 6/8",
    title: "Lubiana · castello, centro e Tivoli",
    desc: "Città piccola e tutta a piedi, perfetta col ritmo dei bambini. Mattina: funicolare per il Castello, centro pedonale, Ponte dei Draghi e giro in barca sul fiume. Pomeriggio senza fretta al parco Tivoli e allo zoo, con prati e parchi gioco.",
    icon: "ph:buildings",
    places: [
      { label: "Funicolare Castello", url: mapsSearch("Ljubljana Castle funicular") },
      { label: "Parco Tivoli e Zoo", url: mapsSearch("Tivoli Park Ljubljana Zoo") },
    ],
  },
  {
    day: "Ven 7/8",
    title: "Gita · Postojna + Castello di Predjama",
    desc: "45 minuti da Lubiana e siamo alla tappa clou per le bimbe: Grotte di Postojna, si entra con un trenino dentro la grotta. A pochi minuti il Castello di Predjama incastonato nella roccia. Biglietto combinato, meglio online il giorno prima. In grotta ci sono ~10°C: portate una felpa anche d'estate.",
    icon: "ph:train",
    places: [
      { label: "Grotte di Postojna", url: mapsSearch("Postojna Cave") },
      { label: "Castello di Predjama", url: mapsSearch("Predjama Castle") },
    ],
  },
  {
    day: "Sab 8/8",
    title: "Gita · Lago di Bled",
    desc: "Una delle cartoline più belle d'Europa, a 45 minuti. Giro in pletna (barca a remi) fino all'isola con la chiesetta, Castello di Bled a picco sul lago e la celebre millefoglie alla crema. Rientro serale a Lubiana.",
    icon: "ph:boat",
    places: [
      { label: "Lago di Bled", url: mapsSearch("Lake Bled") },
      { label: "Castello di Bled", url: mapsSearch("Bled Castle") },
    ],
  },
  {
    day: "Dom 9/8",
    title: "Gita · Lago di Bohinj e Gola di Vintgar",
    desc: "Giornata natura da dosare a piacere: bagno nell'acqua limpida del più selvaggio lago di Bohinj, e/o la Gola di Vintgar con le passerelle di legno sull'acqua smeraldo (per Lea meglio il marsupio). Ritmo lento, tanto verde.",
    icon: "ph:mountains",
    places: [
      { label: "Lago di Bohinj", url: mapsSearch("Lake Bohinj") },
      { label: "Gola di Vintgar", url: mapsSearch("Vintgar Gorge") },
    ],
  },
  {
    day: "Lun 10/8",
    title: "Lubiana · giornata libera e riposo",
    desc: "Giorno di puro relax nella base: mercato centrale, gelato lungo la Ljubljanica, un altro giro al Tivoli o shopping tranquillo. Nessun programma, per ricaricarsi prima del rientro.",
    icon: "ph:sun-horizon",
    places: [
      { label: "Mercato Centrale", url: mapsSearch("Ljubljana Central Market") },
    ],
  },
  {
    day: "Mar 11/8",
    title: "Lubiana → casa",
    desc: "Rientro con calma (~6h) ben prima dell'esodo di Ferragosto. Arrivo a Porto Sant'Elpidio nel pomeriggio. Restano il 12, 13, 14, 15 e 16 liberi a casa come margine, senza traffico.",
    icon: "ph:house",
    places: [
      { label: "Rotta → casa", url: mapsDirections("Ljubljana", "Porto Sant'Elpidio, FM") },
    ],
  },
];

const stays = [
  {
    city: "Lubiana — base unica",
    zona: "Centro / Città Vecchia (tutto a piedi)",
    icon: "ph:castle-turret",
    picks: [
      { name: "Hotel Cubo", note: "camere comunicanti, babysitting, ottimo per famiglie", rec: true },
      { name: "Grand Hotel Union", note: "camere triple e suite a 2 camere" },
      { name: "Bloom Hotel (appartamenti)", note: "sotto il castello, sul fiume, con cucina" },
    ],
  },
  {
    city: "In alternativa: base sul lago",
    zona: "Bled, se preferite dormire in riva",
    icon: "ph:mountains",
    picks: [
      { name: "Hotel Kompas Bled", note: "kids club, piscine, sul lago", rec: true },
      { name: "Hotel Lovec", note: "family suite con 2 camere" },
      { name: "Bohinj ECO Hotel", note: "con aquapark, per la quiete di Bohinj" },
    ],
  },
];

const practical = [
  { icon: "ph:sticker", title: "Vignetta Slovenia", text: "E-vignetta settimanale ~16 € (copre 7 giorni): è l'unica che serve. Si compra online su evinjeta.dars.si o al confine." },
  { icon: "ph:road-horizon", title: "Pedaggi Italia", text: "A14/A4 Porto Sant'Elpidio verso il confine: ~35–40 € a tratta." },
  { icon: "ph:warning-circle", title: "Traffico Ferragosto", text: "Rientro fissato a martedì 11, molto prima del grande esodo del 14–15 agosto. Dal 12 al 16 restate a casa con calma, senza code." },
  { icon: "ph:thermometer-cold", title: "Grotte fresche", text: "A Postojna ci sono ~10 °C tutto l'anno: felpa e scarpe chiuse per tutti, anche in piena estate." },
  { icon: "ph:identification-card", title: "Documenti bimbe", text: "Slovenia e Italia sono UE/Schengen: basta carta d'identità valida per l'espatrio (anche Bianca e Lea). Verificate le scadenze + tessera sanitaria/TEAM." },
  { icon: "ph:baby-carriage", title: "Seggiolini", text: "Obbligatori in Slovenia come in Italia: seggiolino per Lea (4) e rialzo per Bianca (7)." },
];

const budget = [
  { voce: "Carburante (~1.500 km)", costo: "~220–270 €", total: false },
  { voce: "Pedaggi Italia (A/R)", costo: "~75–90 €", total: false },
  { voce: "Vignetta Slovenia (settimanale)", costo: "~16 €", total: false },
  { voce: "Alloggio Lubiana (6 notti, fascia media)", costo: "~800–1.050 €", total: false },
  { voce: "Ingressi e attività", costo: "~300–400 €", total: false },
  { voce: "Vitto (~90 €/giorno × 7)", costo: "~650–800 €", total: false },
  { voce: "Totale indicativo", costo: "~2.100–2.650 €", total: true },
];
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Vacanza · Slovenia · Agosto 2026</title>
    <style is:global>
      .foglio body.admin .container { max-width: 1100px; margin: 0 auto; }

      .foglio body.admin .page-header { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--foglio-rule); }
      .foglio body.admin .page-kicker { color: var(--foglio-ink-soft); font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 0.5rem; }
      .foglio body.admin .page-header h1 { font-family: var(--foglio-serif); color: var(--foglio-ink); font-size: var(--foglio-fs-4xl); font-weight: 500; letter-spacing: -0.015em; line-height: 1.05; margin-bottom: 0.5rem; }
      .foglio body.admin .page-subtitle { color: var(--foglio-ink-soft); font-family: var(--foglio-serif); font-style: italic; font-size: var(--foglio-fs-sm); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
      .foglio body.admin .page-subtitle .icon-inline { width: 1rem; height: 1rem; color: var(--foglio-accent); }
      .foglio body.admin .booking-ref { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-accent); text-transform: uppercase; letter-spacing: 0.1em; font-style: normal; }

      /* Foto */
      .foglio body.admin .hero-photo { width: 100%; height: 300px; object-fit: cover; border-radius: var(--foglio-radius-md); margin: 0 0 0.4rem; display: block; background: var(--foglio-paper-2); }
      .foglio body.admin .photo-credit { font-family: var(--foglio-mono); font-size: 0.62rem; color: var(--foglio-ink-mute); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1.6rem; }

      .foglio body.admin .card-title { font-family: var(--foglio-mono); color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.55rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--foglio-rule); }
      .foglio body.admin .card-title-icon { width: 1.15rem; height: 1.15rem; color: var(--foglio-accent); }

      /* Equipaggio */
      .foglio body.admin .tickets-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
      .foglio body.admin .ticket { background: var(--foglio-paper-2); border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-md); padding: 1.15rem; position: relative; overflow: hidden; }
      .foglio body.admin .ticket::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--foglio-accent); }
      .foglio body.admin .ticket-head { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem; }
      .foglio body.admin .ticket-avatar { width: 2rem; height: 2rem; border-radius: 50%; background: var(--foglio-paper); border: 1px solid var(--foglio-accent); display: flex; align-items: center; justify-content: center; color: var(--foglio-accent); flex-shrink: 0; }
      .foglio body.admin .ticket-avatar svg { width: 1.1rem; height: 1.1rem; }
      .foglio body.admin .ticket-name { font-family: var(--foglio-serif); font-weight: 500; font-size: var(--foglio-fs-md); color: var(--foglio-ink); }
      .foglio body.admin .ticket-type { color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-family: var(--foglio-mono); text-transform: uppercase; letter-spacing: 0.1em; }

      /* Tappe con foto */
      .foglio body.admin .stops-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 1rem; }
      .foglio body.admin .stop { background: var(--foglio-paper-2); border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-md); overflow: hidden; }
      .foglio body.admin .stop-photo { width: 100%; height: 140px; object-fit: cover; display: block; background: var(--foglio-paper); }
      .foglio body.admin .stop-body { padding: 1rem 1.1rem 1.15rem; }
      .foglio body.admin .stop-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.5rem; }
      .foglio body.admin .stop-icon { width: 1.2rem; height: 1.2rem; color: var(--foglio-accent); flex-shrink: 0; }
      .foglio body.admin .stop-city { font-family: var(--foglio-serif); font-size: var(--foglio-fs-md); font-weight: 500; color: var(--foglio-ink); }
      .foglio body.admin .stop-nights { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
      .foglio body.admin .stop-drive { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); line-height: 1.5; }

      /* Dove dormire */
      .foglio body.admin .stays-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
      .foglio body.admin .stay { background: var(--foglio-paper-2); border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-md); padding: 1.15rem; }
      .foglio body.admin .stay-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.15rem; }
      .foglio body.admin .stay-icon { width: 1.15rem; height: 1.15rem; color: var(--foglio-accent); flex-shrink: 0; }
      .foglio body.admin .stay-city { font-family: var(--foglio-serif); font-size: var(--foglio-fs-md); font-weight: 500; color: var(--foglio-ink); }
      .foglio body.admin .stay-zona { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-ink-soft); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
      .foglio body.admin .stay-list { list-style: none; }
      .foglio body.admin .stay-list li { padding: 0.45rem 0; border-bottom: 1px solid var(--foglio-rule); }
      .foglio body.admin .stay-list li:last-child { border-bottom: none; }
      .foglio body.admin .stay-name { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink); font-weight: 500; display: flex; align-items: center; gap: 0.4rem; }
      .foglio body.admin .stay-name .rec-dot { display: inline-flex; align-items: center; justify-content: center; background: var(--foglio-accent); color: var(--foglio-paper); font-family: var(--foglio-mono); font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.1rem 0.4rem; border-radius: var(--foglio-radius-sm); }
      .foglio body.admin .stay-note { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); line-height: 1.45; }

      /* Regole / pratiche */
      .foglio body.admin .rules-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
      .foglio body.admin .rule { background: var(--foglio-paper-2); border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-md); padding: 1.1rem; }
      .foglio body.admin .rule-head { display: flex; align-items: center; gap: 0.55rem; margin-bottom: 0.55rem; }
      .foglio body.admin .rule-icon { width: 1.15rem; height: 1.15rem; color: var(--foglio-accent); flex-shrink: 0; }
      .foglio body.admin .rule-title { font-family: var(--foglio-serif); font-size: var(--foglio-fs-md); font-weight: 500; color: var(--foglio-ink); }
      .foglio body.admin .rule-text { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); line-height: 1.6; }

      /* Timeline */
      .foglio body.admin .timeline { position: relative; padding-left: 2.5rem; }
      .foglio body.admin .timeline::before { content: ''; position: absolute; left: 0.95rem; top: 0.5rem; bottom: 0.5rem; width: 1px; background: var(--foglio-rule-strong); }
      .foglio body.admin .step { position: relative; padding-bottom: 1.6rem; }
      .foglio body.admin .step:last-child { padding-bottom: 0; }
      .foglio body.admin .step-dot { position: absolute; left: -2.5rem; top: 0.15rem; width: 2rem; height: 2rem; border-radius: 50%; background: var(--foglio-paper); border: 1px solid var(--foglio-accent); display: flex; align-items: center; justify-content: center; color: var(--foglio-accent); }
      .foglio body.admin .step-dot svg { width: 1rem; height: 1rem; }
      .foglio body.admin .step-time { font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); color: var(--foglio-accent); font-weight: 700; letter-spacing: 0.1em; }
      .foglio body.admin .step-title { font-family: var(--foglio-serif); font-size: var(--foglio-fs-md); font-weight: 500; color: var(--foglio-ink); margin: 0.1rem 0 0.35rem; }
      .foglio body.admin .step-desc { font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); max-width: 700px; line-height: 1.6; }
      .foglio body.admin .step-places { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.65rem; }
      .foglio body.admin .map-link { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.3rem 0.7rem; border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-sm); background: var(--foglio-paper-2); color: var(--foglio-ink); font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
      .foglio body.admin .map-link:hover { border-color: var(--foglio-accent); color: var(--foglio-accent); }
      .foglio body.admin .map-link svg { color: inherit; }

      /* Budget */
      .foglio body.admin .budget-list { list-style: none; }
      .foglio body.admin .budget-list li { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid var(--foglio-rule); font-family: var(--foglio-serif); font-size: var(--foglio-fs-sm); color: var(--foglio-ink-soft); }
      .foglio body.admin .budget-list li .b-cost { font-family: var(--foglio-mono); color: var(--foglio-ink); font-variant-numeric: tabular-nums; white-space: nowrap; }
      .foglio body.admin .budget-list li.b-total { border-bottom: none; border-top: 2px solid var(--foglio-rule-strong); margin-top: 0.3rem; padding-top: 0.8rem; }
      .foglio body.admin .budget-list li.b-total .b-voce { font-family: var(--foglio-mono); text-transform: uppercase; letter-spacing: 0.1em; color: var(--foglio-ink); font-weight: 700; }
      .foglio body.admin .budget-list li.b-total .b-cost { color: var(--foglio-accent); font-weight: 700; font-size: var(--foglio-fs-md); }

      @media (max-width: 720px) {
        .foglio body.admin .card { padding: 1.15rem; }
        .foglio body.admin .hero-photo { height: 200px; }
        .foglio body.admin .timeline { padding-left: 2rem; }
        .foglio body.admin .step-dot { left: -2rem; width: 1.7rem; height: 1.7rem; }
        .foglio body.admin .timeline::before { left: 0.8rem; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="vacanza" token={token} />
    <div class="container">
      <header class="page-header">
        <div class="page-kicker">Trip · Famiglia Narcisi · tutta Slovenia</div>
        <h1><em class="acc">Vacanza.</em> Slovenia · base a Lubiana</h1>
        <p class="page-subtitle">
          <Icon name="ph:calendar-blank" class="icon-inline" size={16} is:inline />
          <span>5 – 11 agosto 2026 · 7 giorni / 6 notti · base unica, gite in giornata</span>
          <span>·</span>
          <span class="booking-ref">Rientro l'11, prima dell'esodo di Ferragosto</span>
        </p>
      </header>

      <img class="hero-photo" src={heroPhoto} alt="Lago di Bled con l'isola e la chiesetta" loading="lazy" />
      <div class="photo-credit">Foto: Wikimedia Commons</div>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:users-three" class="card-title-icon" size={18} is:inline />
          Equipaggio
        </h2>
        <div class="tickets-grid">
          {crew.map((c) => (
            <div class="ticket">
              <div class="ticket-head">
                <div class="ticket-avatar"><Icon name={c.icon} size={18} is:inline /></div>
                <div class="ticket-name">{c.name}</div>
              </div>
              <div class="ticket-type">{c.role}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:map-pin-line" class="card-title-icon" size={18} is:inline />
          Base e gite
        </h2>
        <div class="stops-grid">
          {stops.map((s) => (
            <div class="stop">
              <img class="stop-photo" src={s.photo} alt={s.city} loading="lazy" />
              <div class="stop-body">
                <div class="stop-head">
                  <span class="stop-icon"><Icon name={s.icon} size={18} is:inline /></span>
                  <span class="stop-city">{s.city}</span>
                </div>
                <div class="stop-nights">{s.nights}</div>
                <div class="stop-drive">{s.drive}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:path" class="card-title-icon" size={18} is:inline />
          Itinerario giorno per giorno
        </h2>
        <div class="timeline">
          {timeline.map((step) => (
            <div class="step">
              <div class="step-dot"><Icon name={step.icon} is:inline /></div>
              <div class="step-time">{step.day}</div>
              <div class="step-title">{step.title}</div>
              <div class="step-desc">{step.desc}</div>
              {step.places && step.places.length > 0 && (
                <div class="step-places">
                  {step.places.map((p) => (
                    <a class="map-link" href={p.url} target="_blank" rel="noopener noreferrer">
                      <Icon name="ph:map-trifold" size={14} is:inline />
                      <span>{p.label}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:bed" class="card-title-icon" size={18} is:inline />
          Dove dormire
        </h2>
        <div class="stays-grid">
          {stays.map((s) => (
            <div class="stay">
              <div class="stay-head">
                <span class="stay-icon"><Icon name={s.icon} size={18} is:inline /></span>
                <span class="stay-city">{s.city}</span>
              </div>
              <div class="stay-zona">{s.zona}</div>
              <ul class="stay-list">
                {s.picks.map((p) => (
                  <li>
                    <div class="stay-name">
                      {p.name}
                      {"rec" in p && p.rec && <span class="rec-dot">Top</span>}
                    </div>
                    <div class="stay-note">{p.note}</div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:info" class="card-title-icon" size={18} is:inline />
          Info pratiche di guida
        </h2>
        <div class="rules-grid">
          {practical.map((r) => (
            <div class="rule">
              <div class="rule-head">
                <span class="rule-icon"><Icon name={r.icon} size={18} is:inline /></span>
                <span class="rule-title">{r.title}</span>
              </div>
              <p class="rule-text">{r.text}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="card">
        <h2 class="card-title">
          <Icon name="ph:wallet" class="card-title-icon" size={18} is:inline />
          Budget indicativo
        </h2>
        <ul class="budget-list">
          {budget.map((b) => (
            <li class={b.total ? "b-total" : ""}>
              <span class="b-voce">{b.voce}</span>
              <span class="b-cost">{b.costo}</span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </body>
</html>
