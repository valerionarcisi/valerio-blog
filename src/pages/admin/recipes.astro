---
import { Icon } from "astro-icon/components";
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}

const recipes = [
  {
    name: "Pollo al Curry",
    day: "Giovedì — Cena",
    time: "40 min",
    icon: "ph:cooking-pot",
    oil: "3 cucchiaini olio EVO (già nella marinata)",
    ingredients: [
      "200g petto di pollo",
      "3 cucchiaini olio EVO",
      "1 cucchiaio colmo di curry",
      "Succo di mezzo limone",
      "Pepe e sale",
      "Vino bianco secco (per sfumare)",
      "Yogurt greco 0% bianco",
      "1 cucchiaio di curry (per la salsa)",
    ],
    steps: [
      "Tagliare il petto di pollo a cubetti",
      "Versare il tutto in una ciotola, aggiungendo 3 cucchiaini di olio, 1 cucchiaio colmo di curry, il succo di mezzo limone, pepe e sale",
      "Lasciare il pollo in macera almeno un'ora per farlo insaporire",
      "Scaldare una padella e rosolare i bocconcini di pollo",
      "Dopo aver rosolato il pollo, sfumare con il vino bianco secco e proseguire la cottura a fuoco dolce per circa 10-15 minuti",
      "Nel frattempo, preparare la salsa di accompagnamento: mescolare lo yogurt greco 0% bianco con un cucchiaio di curry",
      "Una volta pronto, rimuovere il coperchio dalla padella e far asciugare eventuale liquido in eccesso",
      "Togliere la padella dal fuoco e distribuire la salsina di yogurt al curry direttamente sopra ai bocconcini di pollo",
      "Chiudere con il coperchio per far scaldare la salsina ed insaporire i bocconcini",
      "Servire subito",
    ],
    serve: "2 fette pane integrale o ai cereali (60g) / 4 gallette di riso / 4 fette wasa",
  },
  {
    name: "Millefoglie di Zucchine",
    day: "Martedì — Cena (opzione 2)",
    time: "45 min",
    icon: "ph:plant",
    oil: "2 cucchiaini olio EVO a crudo",
    ingredients: [
      "Zucchine q.b.",
      "100g mozzarella light (Galbani Santa Lucia o Granarolo da 100g) / 100g ricotta (Vallelata ricottina da 100g)",
      "100g prosciutto cotto magro o fesa di tacchino",
      "1 cucchiaio di parmigiano grattugiato",
      "2 cucchiaini olio EVO a crudo",
      "Sale e pepe q.b.",
    ],
    steps: [
      "Lavare accuratamente le zucchine, asciugarle e spuntarle",
      "Tagliare a fettine sottilissime (2 mm di spessore) nel senso della lunghezza e affettare la mozzarella",
      "In una teglia da forno formare uno strato con le fette di zucchina, accavallandole leggermente una di fianco all'altra",
      "Sistemarvi sopra le fette di mozzarella light ed il prosciutto cotto magro",
      "Ripetere questa sequenza per altre due volte, ripartendo sempre dalle zucchine, poi mozzarella, poi cotto magro",
      "Terminare con uno strato finale di zucchine",
      "Condire con 2 cucchiaini di olio EVO a crudo, sale, pepe e una manciata di parmigiano grattugiato",
      "Infornare a 220°C per circa 30 minuti, fino a quando in superficie si formerà una leggera crosticina",
    ],
    serve: "2 fette pane integrale o ai cereali (60g) / 4 gallette di riso / 4 fette wasa",
  },
  {
    name: "Caesar Salad con Pollo",
    day: "Venerdì — Cena (opzione 2)",
    time: "20 min",
    icon: "ph:bowl-food",
    oil: "3 cucchiaini olio EVO a crudo (nella salsa, senza sforare la dose del piano)",
    ingredients: [
      "200g petto di pollo",
      "Zucchine q.b.",
      "100g yogurt greco 0% bianco (circa 2 cucchiai colmi)",
      "Erba cipollina (o altra spezia a piacere)",
      "Succo di limone q.b.",
      "3 cucchiaini olio EVO",
      "1 cucchiaio di semi di lino/zucca/girasole",
      "Sale e pepe q.b.",
    ],
    steps: [
      "Cuocere il petto di pollo alla piastra (senza olio sulla piastra) con sale e pepe",
      "Tagliarlo a striscioline una volta cotto",
      "Cuocere le zucchine alla piastra o saltarle in padella",
      "Preparare la salsa yogurt: mescolare lo yogurt greco con l'olio, il succo di limone, l'erba cipollina e un pizzico di sale",
      "Disporre il pollo e le zucchine in una ciotola, aggiungere i semi e versare la salsa yogurt sopra",
    ],
    serve: "2 fette pane integrale o ai cereali (60g) / 4 gallette di riso / 4 fette wasa",
  },
  {
    name: "Piadina Integrale Fatta in Casa",
    day: "Venerdì — Pranzo (opzione 2)",
    time: "50 min",
    icon: "ph:bread",
    oil: "3 cucchiaini olio EVO (nell'impasto)",
    ingredients: [
      "100g farina di avena o tipo 1 o tipo 2 o integrale (o mix)",
      "Acqua q.b. (meno di 100ml)",
      "3 cucchiaini olio EVO",
      "1 cucchiaino di sale",
    ],
    steps: [
      "Mettere la farina in una bacinella ed aggiungere pian piano l'acqua fino a che il composto diventa perfettamente modellabile",
      "Aggiungere i 3 cucchiaini di olio EVO e continuare a mescolare bene",
      "Continuare a lavorare il composto con le mani, versandolo su un piano ben infarinato",
      "Bisogna ottenere un panetto compatto e non troppo appiccicoso",
      "Mettere il composto a riposo in frigorifero circa 30 minuti",
      "Stendere l'impasto con un matterello sul piano ben infarinato dando il più possibile una forma circolare sottile",
      "Scaldare la padella antiaderente unta con un filo d'olio ed adagiare delicatamente i dischi ottenuti dall'impasto",
      "Cuocere circa 3 minuti per lato e disporre le piadine una sull'altra",
    ],
    serve: "Farcire con 100g fonte proteica (affettato magro, gamberetti, tonno al naturale) o crema di legumi con 80g legumi in scatola + spezie/aromi + verdure di stagione, oppure mezzo avocado + yogurt greco 0%. Accompagnare con 1 fetta pane integrale (30g) / 2 gallette / 2 fette wasa + formaggio magro spalmabile (Exquisa Fitline / Philadelphia Protein)",
  },
  {
    name: "Hamburger di Carne Magra",
    day: "Mercoledì — Cena (opzione 1)",
    time: "20 min",
    icon: "ph:hamburger",
    oil: "3 cucchiaini olio EVO a crudo",
    ingredients: [
      "180g macinata magra o bianca magra",
      "Albume d'uovo (come amalgama, opzionale)",
      "3 cucchiaini olio EVO a crudo",
      "Sale e pepe q.b.",
    ],
    steps: [
      "Lavorare la macinata in una ciotola con sale, pepe e un filo di albume se necessario come amalgama",
      "Formare 1-2 hamburger compatti dello spessore desiderato",
      "Scaldare una padella antiaderente o griglia",
      "Cuocere gli hamburger circa 4-5 minuti per lato fino a doratura",
      "In alternativa, acquistare dal macellaio 200g hamburger di carne magra già pronti (meglio senza parmigiano o uovo, ok con verdure/spezie/aromi)",
    ],
    serve: "2 fette pane integrale o ai cereali (60g) / 4 gallette di riso / 4 fette wasa + verdure a sazietà (es. zucchine alla piastra)",
  },
];
---

<!doctype html>
<html lang="it" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Ricette</title>
    <style is:global>
      .foglio body.admin .recipes-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .foglio body.admin .recipe-card {
        background: var(--foglio-paper);
        border: 1px solid var(--foglio-rule);
        border-radius: var(--foglio-radius-md);
        overflow: hidden;
      }

      .foglio body.admin .recipe-header {
        padding: 0.8rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        cursor: pointer;
        list-style: none;
      }
      .foglio body.admin .recipe-header::-webkit-details-marker { display: none; }

      .foglio body.admin .recipe-icon {
        width: 1.4rem;
        height: 1.4rem;
        color: var(--foglio-accent);
        flex-shrink: 0;
      }

      .foglio body.admin .recipe-title {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-md);
        font-weight: 500;
        color: var(--foglio-ink);
        flex: 1;
      }

      .foglio body.admin .recipe-meta {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }

      .foglio body.admin .recipe-day {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        color: var(--foglio-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .foglio body.admin .recipe-time {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        color: var(--foglio-accent);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .foglio body.admin .recipe-arrow {
        color: var(--foglio-ink-mute);
        font-size: 0.82rem;
        transition: transform 0.2s;
      }

      .foglio body.admin details[open] .recipe-arrow { transform: rotate(90deg); }
      .foglio body.admin details[open] .recipe-header { border-bottom: 1px solid var(--foglio-rule); }

      .foglio body.admin .recipe-body {
        padding: 1rem;
      }

      .foglio body.admin .recipe-section-title {
        font-family: var(--foglio-mono);
        font-size: var(--foglio-fs-mono);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--foglio-ink-soft);
        margin: 0.8rem 0 0.4rem;
      }

      .foglio body.admin .recipe-ingredients {
        list-style: none;
        margin-bottom: 1rem;
        columns: 2;
        column-gap: 1.5rem;
      }
      .foglio body.admin .recipe-ingredients li {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.55;
        padding: 0.15rem 0 0.15rem 0.8rem;
        position: relative;
        color: var(--foglio-ink-soft);
        break-inside: avoid;
      }
      .foglio body.admin .recipe-ingredients li::before {
        content: "·";
        position: absolute;
        left: 0;
        color: var(--foglio-accent);
        font-weight: 700;
      }

      .foglio body.admin .recipe-steps {
        list-style: none;
        counter-reset: step;
        margin-bottom: 1rem;
      }
      .foglio body.admin .recipe-steps li {
        counter-increment: step;
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        line-height: 1.55;
        padding: 0.4rem 0 0.4rem 2rem;
        position: relative;
        color: var(--foglio-ink-soft);
        border-bottom: 1px solid var(--foglio-rule);
      }
      .foglio body.admin .recipe-steps li:last-child { border-bottom: none; }
      .foglio body.admin .recipe-steps li::before {
        content: counter(step);
        position: absolute;
        left: 0;
        top: 0.4rem;
        width: 1.3rem;
        height: 1.3rem;
        background: var(--foglio-accent);
        color: var(--foglio-paper);
        border-radius: 50%;
        font-family: var(--foglio-mono);
        font-size: 0.72rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .foglio body.admin .recipe-serve {
        font-family: var(--foglio-serif);
        font-size: var(--foglio-fs-sm);
        font-style: italic;
        color: var(--foglio-ink);
        padding: 0.7rem 0.9rem;
        background: var(--foglio-paper-2);
        border-radius: var(--foglio-radius-sm);
        border-left: 3px solid var(--foglio-accent);
      }
      .foglio body.admin .recipe-serve strong { color: var(--foglio-accent); font-style: normal; font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); text-transform: uppercase; letter-spacing: 0.1em; }

      .foglio body.admin .recipe-oil {
        display: inline-block;
        font-family: var(--foglio-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border: 1px solid rgba(46, 139, 87, 0.5);
        color: #2e8b57;
        padding: 0.1rem 0.5rem;
        border-radius: 2px;
        margin-bottom: 0.5rem;
      }

      @media (max-width: 500px) {
        .foglio body.admin .recipe-ingredients { columns: 1; }
        .foglio body.admin .recipe-meta { flex-direction: column; gap: 0.2rem; align-items: flex-end; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="recipes" token={token} />

    <h1><em class="acc">Ricette.</em></h1>
    <p class="subtitle">del piano alimentare</p>

    <div class="recipes-grid">
      {recipes.map((recipe) => (
        <details class="recipe-card">
          <summary class="recipe-header">
            <Icon name={recipe.icon} class="recipe-icon" size={20} is:inline />
            <span class="recipe-title">{recipe.name}</span>
            <div class="recipe-meta">
              <span class="recipe-day">{recipe.day}</span>
              <span class="recipe-time">{recipe.time}</span>
            </div>
            <span class="recipe-arrow">▸</span>
          </summary>
          <div class="recipe-body">
            {"oil" in recipe && recipe.oil && (
              <span class="recipe-oil">🫒 {recipe.oil}</span>
            )}
            <div class="recipe-section-title">Ingredienti</div>
            <ul class="recipe-ingredients">
              {recipe.ingredients.map((ing) => (
                <li>{ing}</li>
              ))}
            </ul>

            <div class="recipe-section-title">Preparazione</div>
            <ol class="recipe-steps">
              {recipe.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>

            <div class="recipe-serve">
              <strong>Accompagna con:</strong> {recipe.serve}
            </div>
          </div>
        </details>
      ))}
    </div>
  </body>
</html>
