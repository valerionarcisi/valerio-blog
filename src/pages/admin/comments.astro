---
import { Icon } from "astro-icon/components";
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Comments Admin</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #0a0a0c; color: #e8e6e1; padding: 2rem; font-size: 1rem; }
      .container { max-width: 1200px; margin: 0 auto; }
      .page-header { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
      h1 { color: #c9a84c; font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; }
      .page-sub { color: #8a8a8e; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace; }

      .card { background: #121214; border: 1px solid #222; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }
      .card-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
      .card-title { color: #c9a84c; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; display: flex; align-items: center; gap: 0.5rem; }
      .card-title-icon { width: 1.1rem; height: 1.1rem; color: #c9a84c; }
      .card-title-icon svg { display: block; width: 100%; height: 100%; }

      .tabs { display: inline-flex; gap: 0; background: #0a0a0c; border: 1px solid #2a2a2e; border-radius: 8px; padding: 3px; }
      .tabs button { padding: 0.45rem 1rem; background: transparent; border: none; color: #8a8a8e; cursor: pointer; border-radius: 6px; font-size: 0.85rem; font-weight: 600; transition: all 0.15s; }
      .tabs button:hover { color: #e8e6e1; }
      .tabs button.active { background: rgba(201, 168, 76, 0.12); color: #c9a84c; }

      table { width: 100%; border-collapse: collapse; }
      th, td { padding: 0.85rem 0.75rem; text-align: left; vertical-align: top; }
      thead th { color: #8a8a8e; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.08em; font-weight: 600; border-bottom: 1px solid #2a2a2e; }
      tbody tr { transition: background 0.15s; }
      tbody tr:hover { background: rgba(255, 255, 255, 0.02); }
      tbody tr + tr td { border-top: 1px solid #1c1c20; }
      td { font-size: 0.85rem; }

      .page-id { font-family: 'JetBrains Mono', monospace; color: #4ecdc4; font-size: 0.78rem; }
      .text-cell { max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .email { color: #8a8a8e; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; }
      .actions { display: flex; gap: 0.4rem; flex-wrap: nowrap; }
      .btn { padding: 0.35rem 0.75rem; border: 1px solid; border-radius: 5px; cursor: pointer; font-size: 0.78rem; font-weight: 600; background: transparent; transition: all 0.15s; white-space: nowrap; }
      .btn-approve { color: #4ecdc4; border-color: rgba(78, 205, 196, 0.4); }
      .btn-approve:hover { background: rgba(78, 205, 196, 0.12); border-color: #4ecdc4; }
      .btn-delete { color: #e74c3c; border-color: rgba(231, 76, 60, 0.4); }
      .btn-delete:hover { background: rgba(231, 76, 60, 0.12); border-color: #e74c3c; }

      .empty { color: #8a8a8e; font-style: italic; padding: 2rem; text-align: center; }
      .count { color: #8a8a8e; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; }

      .reply-indicator { color: #c9a84c; font-size: 0.7rem; font-family: 'JetBrains Mono', monospace; display: block; margin-top: 0.25rem; opacity: 0.85; }
      .likes-cell { color: #c9a84c; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.3rem; }
      .likes-icon { width: 0.9rem; height: 0.9rem; color: #c9a84c; display: inline-block; }
      .likes-icon svg { display: block; width: 100%; height: 100%; }
      .has-children { color: #e74c3c; font-size: 0.65rem; margin-left: 0.4rem; padding: 0.05rem 0.35rem; border: 1px solid rgba(231, 76, 60, 0.4); border-radius: 3px; }
      .author-badge { display: inline-block; background: #c9a84c; color: #0a0a0c; padding: 0.05rem 0.4rem; border-radius: 3px; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; margin-left: 0.4rem; vertical-align: middle; letter-spacing: 0.05em; }

      .claps-totals { color: #8a8a8e; font-size: 0.85rem; margin-bottom: 1.2rem; font-family: 'JetBrains Mono', monospace; }
      .claps-totals strong { color: #c9a84c; font-size: 1.05rem; font-weight: 700; }
      .claps-table .clap-count { color: #c9a84c; font-family: 'JetBrains Mono', monospace; font-weight: 700; text-align: right; white-space: nowrap; font-size: 0.95rem; }
      .claps-table .unique-count { color: #8a8a8e; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; text-align: right; white-space: nowrap; }
      .claps-table th.clap-count, .claps-table th.unique-count { text-align: right; }

      @media (max-width: 720px) {
        body { padding: 1rem; }
        h1 { font-size: 1.5rem; }
        .card { padding: 1rem; }
        .text-cell { max-width: 180px; }
      }
    </style>
  </head>
  <body>
    <AdminNav currentPage="comments" token={token} />
    <div class="container">
      <header class="page-header">
        <h1>Comments</h1>
        <span class="page-sub">moderation · likes · claps</span>
      </header>

      <section class="card">
        <div class="card-header">
          <h2 class="card-title">Moderation</h2>
          <div class="tabs">
            <button class="active" data-status="pending">Pending</button>
            <button data-status="approved">Approved</button>
          </div>
        </div>
        <p class="count"></p>
        <table>
          <thead>
            <tr>
              <th>Page</th>
              <th>Name</th>
              <th>Email</th>
              <th>Comment</th>
              <th><span class="likes-icon" aria-label="likes"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.687-4.5c-1.936 0-3.598 1.126-4.313 2.733c-.715-1.607-2.377-2.733-4.312-2.733C5.098 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12"/></svg></span></th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="comments-body"></tbody>
        </table>
        <p class="empty" id="empty-msg" style="display:none">No comments found.</p>
      </section>

      <section class="card">
        <div class="card-header">
          <h2 class="card-title">
            <span class="card-title-icon"><Icon name="ph:hands-clapping" size={20} is:inline /></span>
            Claps recap
          </h2>
          <p class="claps-totals" id="claps-totals">Loading…</p>
        </div>
        <table class="claps-table">
          <thead>
            <tr>
              <th>Post</th>
              <th class="clap-count">Claps</th>
              <th class="unique-count">Visitors</th>
              <th>Last clap</th>
            </tr>
          </thead>
          <tbody id="claps-body"></tbody>
        </table>
        <p class="empty" id="claps-empty" style="display:none">No claps yet.</p>
      </section>
    </div>

    <script is:inline define:vars={{ token }}>
      var ADMIN_TOKEN = token;
      try { localStorage.setItem("vbAdminToken", token); } catch (e) {}
      var currentStatus = "pending";

      function loadComments(status) {
        currentStatus = status;
        document.querySelectorAll(".tabs button").forEach(function (btn) {
          btn.classList.toggle("active", btn.dataset.status === status);
        });

        fetch("/api/admin/comments?status=" + status, { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (comments) {
            var tbody = document.getElementById("comments-body");
            var emptyMsg = document.getElementById("empty-msg");
            document.querySelector(".count").textContent = comments.length + " comment(s)";

            if (!comments.length) {
              tbody.innerHTML = "";
              emptyMsg.style.display = "block";
              return;
            }
            emptyMsg.style.display = "none";
            tbody.innerHTML = comments.map(function (c) {
              var d = new Date(c.created_at).toLocaleDateString("en-US");
              var hasChildren = Number(c.children_count || 0) > 0;
              var deleteHandler = hasChildren
                ? 'doActionConfirm(' + c.id + ',\'delete\',' + Number(c.children_count) + ')'
                : 'doAction(' + c.id + ',\'delete\')';
              var actions = status === "pending"
                ? '<button class="btn btn-approve" onclick="doAction(' + c.id + ',\'approve\')">Approve</button>'
                : "";
              actions += '<button class="btn btn-delete" onclick="' + deleteHandler + '">Delete</button>';
              var replyIndicator = c.parent_id != null
                ? '<span class="reply-indicator">↳ in risposta a #' + c.parent_id + ' (' + escapeHtml(c.parent_name || "?") + ')</span>'
                : '';
              var childrenBadge = hasChildren
                ? '<span class="has-children">+' + Number(c.children_count) + ' replies</span>'
                : '';
              var authorBadge = c.is_author
                ? '<span class="author-badge">Author</span>'
                : '';
              return '<tr>' +
                '<td class="page-id">' + escapeHtml(c.page_id) + replyIndicator + '</td>' +
                '<td>' + escapeHtml(c.name) + authorBadge + childrenBadge + '</td>' +
                '<td class="email">' + escapeHtml(c.email) + '</td>' +
                '<td class="text-cell" title="' + escapeHtml(c.text) + '">' + escapeHtml(c.text) + '</td>' +
                '<td><span class="likes-cell"><span class="likes-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.687-4.5c-1.936 0-3.598 1.126-4.313 2.733c-.715-1.607-2.377-2.733-4.312-2.733C5.098 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12"/></svg></span>' + Number(c.likes_count || 0) + '</span></td>' +
                '<td>' + d + '</td>' +
                '<td class="actions">' + actions + '</td>' +
                '</tr>';
            }).join("");
          });
      }

      window.doAction = function (id, action) {
        fetch("/api/admin/comments", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + ADMIN_TOKEN,
          },
          body: JSON.stringify({ id: id, action: action }),
        }).then(function () {
          loadComments(currentStatus);
        });
      };

      window.doActionConfirm = function (id, action, childrenCount) {
        var msg = "This comment has " + childrenCount + " replies. Deleting it will also delete all replies. Continue?";
        if (confirm(msg)) {
          window.doAction(id, action);
        }
      };

      function escapeHtml(str) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
      }

      document.querySelectorAll(".tabs button").forEach(function (btn) {
        btn.addEventListener("click", function () {
          loadComments(btn.dataset.status);
        });
      });

      function loadClaps() {
        fetch("/api/admin/claps", { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var totalsEl = document.getElementById("claps-totals");
            var tbody = document.getElementById("claps-body");
            var emptyEl = document.getElementById("claps-empty");
            var totals = data.totals || {};
            var total = Number(totals.total || 0);
            var posts = Number(totals.posts || 0);
            var uniques = Number(totals.unique_clappers || 0);
            totalsEl.innerHTML =
              "<strong>" + total + "</strong> total claps · " +
              "<strong>" + posts + "</strong> posts · " +
              "<strong>" + uniques + "</strong> unique visitors";
            var rows = data.per_post || [];
            if (!rows.length) {
              tbody.innerHTML = "";
              emptyEl.style.display = "block";
              return;
            }
            emptyEl.style.display = "none";
            tbody.innerHTML = rows.map(function (r) {
              var last = r.last_clap_at ? new Date(r.last_clap_at).toLocaleString("en-US") : "—";
              return '<tr>' +
                '<td class="page-id">' + escapeHtml(r.post_id) + '</td>' +
                '<td class="clap-count">' + Number(r.total_claps) + '</td>' +
                '<td class="unique-count">' + Number(r.unique_clappers) + '</td>' +
                '<td>' + escapeHtml(last) + '</td>' +
                '</tr>';
            }).join("");
          })
          .catch(function () {
            document.getElementById("claps-totals").textContent = "Failed to load claps.";
          });
      }

      loadComments("pending");
      loadClaps();
    </script>
  </body>
</html>
