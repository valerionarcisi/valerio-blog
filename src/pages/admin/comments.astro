---
import { Icon } from "astro-icon/components";
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Comments Admin</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #0a0a0c; color: #e8e6e1; padding: 2rem; font-size: 1.05rem; }
      h1 { color: #c9a84c; margin-bottom: 1rem; }
      .tabs { display: flex; gap: 1rem; margin-bottom: 2rem; }
      .tabs button { padding: 0.5rem 1rem; background: #141416; border: 1px solid #333; color: #e8e6e1; cursor: pointer; border-radius: 4px; font-size: 0.9rem; }
      .tabs button.active { border-color: #c9a84c; color: #c9a84c; }
      table { width: 100%; border-collapse: collapse; }
      th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid #222; font-size: 0.85rem; }
      th { color: #8a8a8e; text-transform: uppercase; font-size: 0.88rem; letter-spacing: 0.05em; }
      .page-id { font-family: monospace; color: #4ecdc4; font-size: 0.9rem; }
      .text-cell { max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .email { color: #8a8a8e; font-size: 0.9rem; }
      .actions { display: flex; gap: 0.5rem; }
      .btn { padding: 0.3rem 0.8rem; border: 1px solid; border-radius: 4px; cursor: pointer; font-size: 0.9rem; background: transparent; }
      .btn-approve { color: #4ecdc4; border-color: #4ecdc4; }
      .btn-approve:hover { background: rgba(78, 205, 196, 0.15); }
      .btn-delete { color: #e74c3c; border-color: #e74c3c; }
      .btn-delete:hover { background: rgba(231, 76, 60, 0.15); }
      .empty { color: #8a8a8e; font-style: italic; padding: 2rem 0; }
      .count { color: #8a8a8e; font-size: 0.85rem; margin-bottom: 1rem; }
      .reply-indicator { color: #c9a84c; font-size: 0.78rem; font-family: monospace; display: block; margin-bottom: 0.25rem; }
      .likes { color: #c9a84c; font-family: monospace; font-size: 0.85rem; white-space: nowrap; }
      .has-children { color: #e74c3c; font-size: 0.75rem; margin-left: 0.4rem; }
      .author-badge { display: inline-block; background: #c9a84c; color: #0a0a0c; padding: 0.05rem 0.4rem; border-radius: 3px; font-size: 0.7em; font-weight: 600; text-transform: uppercase; margin-left: 0.4rem; vertical-align: middle; }
      .claps-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #222; }
      .claps-section h2 { color: #c9a84c; font-size: 1.3rem; margin-bottom: 0.5rem; }
      .claps-totals { color: #8a8a8e; font-size: 0.9rem; margin-bottom: 1.2rem; font-family: monospace; }
      .claps-totals strong { color: #c9a84c; font-size: 1.1rem; }
      .claps-table { width: 100%; }
      .claps-table .clap-count { color: #c9a84c; font-family: monospace; font-weight: 700; text-align: right; white-space: nowrap; }
      .claps-table .unique-count { color: #8a8a8e; font-family: monospace; font-size: 0.8rem; text-align: right; white-space: nowrap; }
      .claps-icon { display: inline-block; width: 1.4rem; height: 1.4rem; vertical-align: middle; margin-right: 0.4rem; color: #c9a84c; }
      .claps-icon svg { display: block; width: 100%; height: 100%; }
    </style>
  </head>
  <body>
    <AdminNav currentPage="comments" token={token} />
    <h1>Comments</h1>
    <div class="tabs">
      <button class="active" data-status="pending">Pending</button>
      <button data-status="approved">Approved</button>
    </div>
    <p class="count"></p>
    <table>
      <thead>
        <tr>
          <th>Page</th>
          <th>Name</th>
          <th>Email</th>
          <th>Comment</th>
          <th>♥</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="comments-body"></tbody>
    </table>
    <p class="empty" id="empty-msg" style="display:none">No comments found.</p>

    <section class="claps-section">
      <h2><Icon name="ph:hands-clapping" class="claps-icon" size={22} is:inline />Claps recap</h2>
      <p class="claps-totals" id="claps-totals">Loading…</p>
      <table class="claps-table">
        <thead>
          <tr>
            <th>Post</th>
            <th class="clap-count">Claps</th>
            <th class="unique-count">Visitors</th>
            <th>Last clap</th>
          </tr>
        </thead>
        <tbody id="claps-body"></tbody>
      </table>
      <p class="empty" id="claps-empty" style="display:none">No claps yet.</p>
    </section>

    <script is:inline define:vars={{ token }}>
      var ADMIN_TOKEN = token;
      try { localStorage.setItem("vbAdminToken", token); } catch (e) {}
      var currentStatus = "pending";

      function loadComments(status) {
        currentStatus = status;
        document.querySelectorAll(".tabs button").forEach(function (btn) {
          btn.classList.toggle("active", btn.dataset.status === status);
        });

        fetch("/api/admin/comments?status=" + status, { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (comments) {
            var tbody = document.getElementById("comments-body");
            var emptyMsg = document.getElementById("empty-msg");
            document.querySelector(".count").textContent = comments.length + " comment(s)";

            if (!comments.length) {
              tbody.innerHTML = "";
              emptyMsg.style.display = "block";
              return;
            }
            emptyMsg.style.display = "none";
            tbody.innerHTML = comments.map(function (c) {
              var d = new Date(c.created_at).toLocaleDateString("en-US");
              var hasChildren = Number(c.children_count || 0) > 0;
              var deleteHandler = hasChildren
                ? 'doActionConfirm(' + c.id + ',\'delete\',' + Number(c.children_count) + ')'
                : 'doAction(' + c.id + ',\'delete\')';
              var actions = status === "pending"
                ? '<button class="btn btn-approve" onclick="doAction(' + c.id + ',\'approve\')">Approve</button>'
                : "";
              actions += '<button class="btn btn-delete" onclick="' + deleteHandler + '">Delete</button>';
              var replyIndicator = c.parent_id != null
                ? '<span class="reply-indicator">↳ in risposta a #' + c.parent_id + ' (' + escapeHtml(c.parent_name || "?") + ')</span>'
                : '';
              var childrenBadge = hasChildren
                ? '<span class="has-children">+' + Number(c.children_count) + ' replies</span>'
                : '';
              var authorBadge = c.is_author
                ? '<span class="author-badge">Author</span>'
                : '';
              return '<tr>' +
                '<td class="page-id">' + escapeHtml(c.page_id) + replyIndicator + '</td>' +
                '<td>' + escapeHtml(c.name) + authorBadge + childrenBadge + '</td>' +
                '<td class="email">' + escapeHtml(c.email) + '</td>' +
                '<td class="text-cell" title="' + escapeHtml(c.text) + '">' + escapeHtml(c.text) + '</td>' +
                '<td class="likes">♥ ' + Number(c.likes_count || 0) + '</td>' +
                '<td>' + d + '</td>' +
                '<td class="actions">' + actions + '</td>' +
                '</tr>';
            }).join("");
          });
      }

      window.doAction = function (id, action) {
        fetch("/api/admin/comments", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + ADMIN_TOKEN,
          },
          body: JSON.stringify({ id: id, action: action }),
        }).then(function () {
          loadComments(currentStatus);
        });
      };

      window.doActionConfirm = function (id, action, childrenCount) {
        var msg = "This comment has " + childrenCount + " replies. Deleting it will also delete all replies. Continue?";
        if (confirm(msg)) {
          window.doAction(id, action);
        }
      };

      function escapeHtml(str) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
      }

      document.querySelectorAll(".tabs button").forEach(function (btn) {
        btn.addEventListener("click", function () {
          loadComments(btn.dataset.status);
        });
      });

      function loadClaps() {
        fetch("/api/admin/claps", { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var totalsEl = document.getElementById("claps-totals");
            var tbody = document.getElementById("claps-body");
            var emptyEl = document.getElementById("claps-empty");
            var totals = data.totals || {};
            var total = Number(totals.total || 0);
            var posts = Number(totals.posts || 0);
            var uniques = Number(totals.unique_clappers || 0);
            totalsEl.innerHTML =
              "<strong>" + total + "</strong> total claps · " +
              "<strong>" + posts + "</strong> posts · " +
              "<strong>" + uniques + "</strong> unique visitors";
            var rows = data.per_post || [];
            if (!rows.length) {
              tbody.innerHTML = "";
              emptyEl.style.display = "block";
              return;
            }
            emptyEl.style.display = "none";
            tbody.innerHTML = rows.map(function (r) {
              var last = r.last_clap_at ? new Date(r.last_clap_at).toLocaleString("en-US") : "—";
              return '<tr>' +
                '<td class="page-id">' + escapeHtml(r.post_id) + '</td>' +
                '<td class="clap-count">' + Number(r.total_claps) + '</td>' +
                '<td class="unique-count">' + Number(r.unique_clappers) + '</td>' +
                '<td>' + escapeHtml(last) + '</td>' +
                '</tr>';
            }).join("");
          })
          .catch(function () {
            document.getElementById("claps-totals").textContent = "Failed to load claps.";
          });
      }

      loadComments("pending");
      loadClaps();
    </script>
  </body>
</html>
