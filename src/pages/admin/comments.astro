---
import { Icon } from "astro-icon/components";
import { timeSafeEqual } from "~/lib/auth";
import { env } from "~/lib/env";
import AdminNav from "~/components/AdminNav.astro";
import "~/styles/foglio.css";
import "~/styles/admin-foglio.css";

export const prerender = false;

const token = Astro.url.searchParams.get("token") ?? "";
const isAuthorized = token.length > 0 && timeSafeEqual(token, env("ADMIN_TOKEN"));

if (!isAuthorized) {
  return new Response("Unauthorized", { status: 401 });
}
---

<!doctype html>
<html lang="en" class="foglio">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <title>Comments Admin</title>
    <style is:global>
      .foglio body.admin .container { max-width: 1200px; margin: 0 auto; }
      .foglio body.admin .page-header { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
      .foglio body.admin .page-sub { color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-family: var(--foglio-mono); text-transform: uppercase; letter-spacing: 0.12em; }

      .foglio body.admin .card-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
      .foglio body.admin .card-title { font-family: var(--foglio-mono); color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em; display: flex; align-items: center; gap: 0.5rem; border: none; padding: 0; margin: 0; }
      .foglio body.admin .card-title-icon { width: 1.1rem; height: 1.1rem; color: var(--foglio-accent); }
      .foglio body.admin .card-title-icon svg { display: block; width: 100%; height: 100%; }

      .foglio body.admin .tabs { display: inline-flex; gap: 0; border: 1px solid var(--foglio-rule); border-radius: var(--foglio-radius-sm); padding: 3px; background: var(--foglio-bg); }
      .foglio body.admin .tabs button { padding: 0.4rem 0.9rem; background: transparent; border: none; color: var(--foglio-ink-soft); cursor: pointer; border-radius: var(--foglio-radius-sm); font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; transition: color 0.15s, background 0.15s; }
      .foglio body.admin .tabs button:hover { color: var(--foglio-ink); }
      .foglio body.admin .tabs button.active { background: var(--foglio-accent); color: var(--foglio-paper); }

      .foglio body.admin .page-id { font-family: var(--foglio-mono); color: var(--foglio-accent); font-size: var(--foglio-fs-mono); }
      .foglio body.admin .post-link {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.15s, opacity 0.15s;
      }
      .foglio body.admin .post-link:hover {
        border-bottom-color: var(--foglio-accent);
        opacity: 0.85;
      }
      .foglio body.admin .text-cell { max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--foglio-serif); }
      .foglio body.admin .email { color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-family: var(--foglio-mono); }
      .foglio body.admin .actions { display: flex; gap: 0.4rem; flex-wrap: nowrap; }
      .foglio body.admin .btn-approve { color: #2e8b57; border-color: rgba(46, 139, 87, 0.4); }
      .foglio body.admin .btn-approve:hover { border-color: #2e8b57; color: #2e8b57; }
      .foglio body.admin .btn-delete { color: #c0392b; border-color: rgba(192, 57, 43, 0.4); }
      .foglio body.admin .btn-delete:hover { border-color: #c0392b; color: #c0392b; }

      .foglio body.admin .count { color: var(--foglio-ink-soft); font-size: var(--foglio-fs-mono); font-family: var(--foglio-mono); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; }

      .foglio body.admin .reply-indicator { color: var(--foglio-accent); font-size: 0.7rem; font-family: var(--foglio-mono); display: block; margin-top: 0.25rem; }
      .foglio body.admin .likes-cell { color: var(--foglio-accent); font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); white-space: nowrap; display: inline-flex; align-items: center; gap: 0.3rem; }
      .foglio body.admin .likes-icon { width: 0.9rem; height: 0.9rem; color: var(--foglio-accent); display: inline-block; }
      .foglio body.admin .likes-icon svg { display: block; width: 100%; height: 100%; }
      .foglio body.admin .has-children { color: #c0392b; font-size: 0.65rem; margin-left: 0.4rem; padding: 0.05rem 0.35rem; border: 1px solid rgba(192, 57, 43, 0.4); border-radius: 3px; font-family: var(--foglio-mono); }
      .foglio body.admin .author-badge { display: inline-block; background: var(--foglio-accent); color: var(--foglio-paper); padding: 0.05rem 0.4rem; border-radius: 2px; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; margin-left: 0.4rem; vertical-align: middle; letter-spacing: 0.08em; font-family: var(--foglio-mono); }

      .foglio body.admin .claps-totals { color: var(--foglio-ink-soft); font-size: var(--foglio-fs-sm); margin-bottom: 1.2rem; font-family: var(--foglio-mono); }
      .foglio body.admin .claps-totals strong { color: var(--foglio-accent); font-size: var(--foglio-fs-md); font-weight: 700; }
      .foglio body.admin .claps-table .clap-count { color: var(--foglio-accent); font-family: var(--foglio-mono); font-weight: 700; text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
      .foglio body.admin .claps-table .unique-count { color: var(--foglio-ink-soft); font-family: var(--foglio-mono); font-size: var(--foglio-fs-mono); text-align: right; white-space: nowrap; }
      .foglio body.admin .claps-table th.clap-count, .foglio body.admin .claps-table th.unique-count { text-align: right; }

      @media (max-width: 720px) {
        .foglio body.admin .card { padding: 1rem; }
        .foglio body.admin .text-cell { max-width: 180px; }
      }

      @media (max-width: 600px) {
        .foglio body.admin table,
        .foglio body.admin tbody,
        .foglio body.admin tr,
        .foglio body.admin td { display: block; width: 100%; }
        .foglio body.admin thead { display: none; }
        .foglio body.admin tr {
          border: 1px solid var(--foglio-rule);
          border-radius: var(--foglio-radius-sm);
          padding: 0.85rem 0.9rem;
          margin-bottom: 0.75rem;
          background: var(--foglio-bg);
        }
        .foglio body.admin td {
          padding: 0.2rem 0;
          border: none;
          word-break: break-word;
        }
        .foglio body.admin .text-cell {
          max-width: 100%;
          white-space: normal;
          font-size: var(--foglio-fs-md);
          margin: 0.4rem 0 0.6rem;
          color: var(--foglio-ink);
        }
        .foglio body.admin .email { word-break: break-all; }
        .foglio body.admin .actions {
          display: flex;
          gap: 0.5rem;
          margin-top: 0.6rem;
          padding-top: 0.6rem;
          border-top: 1px dashed var(--foglio-rule);
        }
        .foglio body.admin .actions .btn {
          flex: 1;
          padding: 0.75rem 0.5rem;
          min-height: 44px;
          font-size: var(--foglio-fs-mono);
        }
        .foglio body.admin .claps-table .clap-count,
        .foglio body.admin .claps-table .unique-count { text-align: left; }
      }
    </style>
  </head>
  <body class="admin">
    <AdminNav currentPage="comments" token={token} />
    <div class="container">
      <header class="page-header">
        <h1><em class="acc">Comments.</em></h1>
        <span class="page-sub">moderation · likes · claps</span>
      </header>

      <section class="card">
        <div class="card-header">
          <h2 class="card-title">Moderation</h2>
          <div class="tabs">
            <button class="active" data-status="pending">Pending</button>
            <button data-status="approved">Approved</button>
          </div>
        </div>
        <p class="count"></p>
        <table>
          <thead>
            <tr>
              <th>Page</th>
              <th>Name</th>
              <th>Email</th>
              <th>Comment</th>
              <th><span class="likes-icon" aria-label="likes"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.687-4.5c-1.936 0-3.598 1.126-4.313 2.733c-.715-1.607-2.377-2.733-4.312-2.733C5.098 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12"/></svg></span></th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="comments-body"></tbody>
        </table>
        <p class="empty" id="empty-msg" style="display:none">No comments found.</p>
      </section>

      <section class="card">
        <div class="card-header">
          <h2 class="card-title">
            <span class="card-title-icon"><Icon name="ph:hands-clapping" size={20} is:inline /></span>
            Claps recap
          </h2>
          <p class="claps-totals" id="claps-totals">Loading…</p>
        </div>
        <table class="claps-table">
          <thead>
            <tr>
              <th>Post</th>
              <th class="clap-count">Claps</th>
              <th class="unique-count">Visitors</th>
              <th>Last clap</th>
            </tr>
          </thead>
          <tbody id="claps-body"></tbody>
        </table>
        <p class="empty" id="claps-empty" style="display:none">No claps yet.</p>
      </section>
    </div>

    <script is:inline define:vars={{ token }}>
      var ADMIN_TOKEN = token;
      try { localStorage.setItem("vbAdminToken", token); } catch (e) {}
      var currentStatus = "pending";

      function loadComments(status) {
        currentStatus = status;
        document.querySelectorAll(".tabs button").forEach(function (btn) {
          btn.classList.toggle("active", btn.dataset.status === status);
        });

        fetch("/api/admin/comments?status=" + status, { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (comments) {
            var tbody = document.getElementById("comments-body");
            var emptyMsg = document.getElementById("empty-msg");
            document.querySelector(".count").textContent = comments.length + " comment(s)";

            if (!comments.length) {
              tbody.innerHTML = "";
              emptyMsg.style.display = "block";
              return;
            }
            emptyMsg.style.display = "none";
            tbody.innerHTML = comments.map(function (c) {
              var d = new Date(c.created_at).toLocaleDateString("en-US");
              var hasChildren = Number(c.children_count || 0) > 0;
              var deleteHandler = hasChildren
                ? 'doActionConfirm(' + c.id + ',\'delete\',' + Number(c.children_count) + ')'
                : 'doAction(' + c.id + ',\'delete\')';
              var actions = status === "pending"
                ? '<button class="btn btn-approve" onclick="doAction(' + c.id + ',\'approve\')">Approve</button>'
                : "";
              actions += '<button class="btn btn-delete" onclick="' + deleteHandler + '">Delete</button>';
              var replyIndicator = c.parent_id != null
                ? '<span class="reply-indicator">↳ in risposta a #' + c.parent_id + ' (' + escapeHtml(c.parent_name || "?") + ')</span>'
                : '';
              var childrenBadge = hasChildren
                ? '<span class="has-children">+' + Number(c.children_count) + ' replies</span>'
                : '';
              var authorBadge = c.is_author
                ? '<span class="author-badge">Author</span>'
                : '';
              var commentUrl = '/' + String(c.page_id || '').replace(/^\/+/, '').replace(/\/+$/, '') + '/';
              return '<tr>' +
                '<td class="page-id"><a href="' + commentUrl + '" target="_blank" rel="noopener" class="post-link">' + escapeHtml(c.page_id) + '</a>' + replyIndicator + '</td>' +
                '<td>' + escapeHtml(c.name) + authorBadge + childrenBadge + '</td>' +
                '<td class="email">' + escapeHtml(c.email) + '</td>' +
                '<td class="text-cell" title="' + escapeHtml(c.text) + '">' + escapeHtml(c.text) + '</td>' +
                '<td><span class="likes-cell"><span class="likes-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.687-4.5c-1.936 0-3.598 1.126-4.313 2.733c-.715-1.607-2.377-2.733-4.312-2.733C5.098 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12"/></svg></span>' + Number(c.likes_count || 0) + '</span></td>' +
                '<td>' + d + '</td>' +
                '<td class="actions">' + actions + '</td>' +
                '</tr>';
            }).join("");
          });
      }

      window.doAction = function (id, action) {
        fetch("/api/admin/comments", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + ADMIN_TOKEN,
          },
          body: JSON.stringify({ id: id, action: action }),
        }).then(function () {
          loadComments(currentStatus);
        });
      };

      window.doActionConfirm = function (id, action, childrenCount) {
        var msg = "This comment has " + childrenCount + " replies. Deleting it will also delete all replies. Continue?";
        if (confirm(msg)) {
          window.doAction(id, action);
        }
      };

      function escapeHtml(str) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
      }

      document.querySelectorAll(".tabs button").forEach(function (btn) {
        btn.addEventListener("click", function () {
          loadComments(btn.dataset.status);
        });
      });

      function loadClaps() {
        fetch("/api/admin/claps", { headers: { "Authorization": "Bearer " + ADMIN_TOKEN } })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var totalsEl = document.getElementById("claps-totals");
            var tbody = document.getElementById("claps-body");
            var emptyEl = document.getElementById("claps-empty");
            var totals = data.totals || {};
            var total = Number(totals.total || 0);
            var posts = Number(totals.posts || 0);
            var uniques = Number(totals.unique_clappers || 0);
            totalsEl.innerHTML =
              "<strong>" + total + "</strong> total claps · " +
              "<strong>" + posts + "</strong> posts · " +
              "<strong>" + uniques + "</strong> unique visitors";
            var rows = data.per_post || [];
            if (!rows.length) {
              tbody.innerHTML = "";
              emptyEl.style.display = "block";
              return;
            }
            emptyEl.style.display = "none";
            tbody.innerHTML = rows.map(function (r) {
              var last = r.last_clap_at ? new Date(r.last_clap_at).toLocaleString("en-US") : "—";
              var url = '/' + r.post_id.replace(/^\/+/, '').replace(/\/+$/, '') + '/';
              return '<tr>' +
                '<td class="page-id"><a href="' + url + '" target="_blank" rel="noopener" class="post-link">' + escapeHtml(r.post_id) + '</a></td>' +
                '<td class="clap-count">' + Number(r.total_claps) + '</td>' +
                '<td class="unique-count">' + Number(r.unique_clappers) + '</td>' +
                '<td>' + escapeHtml(last) + '</td>' +
                '</tr>';
            }).join("");
          })
          .catch(function () {
            document.getElementById("claps-totals").textContent = "Failed to load claps.";
          });
      }

      loadComments("pending");
      loadClaps();
    </script>
  </body>
</html>
