---
import FoglioLayout from "~/layouts/FoglioLayout.astro";
import { SITE_TITLE } from "~/consts";
---

<FoglioLayout
  title={`Contatti · ${SITE_TITLE}`}
  description="Scrivimi per collaborazioni, sceneggiature, idee o qualsiasi altra cosa. Rispondo a tutti."
  lang="it"
  pageId="contact"
>
  <div class="ct-page">
    <header class="ct-head">
      <p class="ct-eyebrow">Contatti</p>
      <h1><em class="acc">Scrivimi.</em></h1>
      <p class="ct-lede">
        Per collaborazioni, sceneggiature, idee — o solo per dire qualcosa.<br />
        Rispondo a tutti, in giornata.
      </p>
    </header>

    <section class="ct-body">
      <div class="ct-block">
        <h2 class="ct-block-label">Email</h2>
        <a href="mailto:valerio.narcisi@gmail.com" class="ct-primary-link">
          valerio.narcisi@gmail.com
        </a>
      </div>

      <div class="ct-block">
        <h2 class="ct-block-label">Altrove</h2>
        <ul class="ct-links">
          <li>
            <span class="ct-link-role">GitHub</span>
            <a href="https://github.com/valerionarcisi" class="ct-link" target="_blank" rel="noopener noreferrer">
              github.com/valerionarcisi
            </a>
          </li>
          <li>
            <span class="ct-link-role">LinkedIn</span>
            <a href="https://www.linkedin.com/in/valerionarcisi/" class="ct-link" target="_blank" rel="noopener noreferrer">
              linkedin.com/in/valerionarcisi
            </a>
          </li>
          <li>
            <span class="ct-link-role">Letterboxd</span>
            <a href="https://letterboxd.com/valerionarcisi/" class="ct-link" target="_blank" rel="noopener noreferrer">
              letterboxd.com/valerionarcisi
            </a>
          </li>
        </ul>
      </div>

      <div class="ct-block">
        <h2 class="ct-block-label">Per i film</h2>
        <p class="ct-note">
          Se hai un progetto cinematografico, una sceneggiatura da leggere o un'idea in testa —
          anche abbozzata — scrivimi. Non ho nessun filtro.
        </p>
      </div>
    </section>
  </div>
</FoglioLayout>

<style is:global>
  .ct-page {
    max-width: var(--foglio-maxw);
    margin: 0 auto;
    padding: 5rem 3rem 8rem;
  }

  .ct-head {
    max-width: 600px;
    margin-bottom: 5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--foglio-rule);
  }

  .ct-eyebrow {
    font-family: var(--foglio-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--foglio-ink-soft);
    margin: 0 0 1.2rem;
  }

  .ct-head h1 {
    font-family: var(--foglio-serif);
    font-weight: 500;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 1.5rem;
  }

  .ct-lede {
    font-family: var(--foglio-serif);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--foglio-ink-soft);
    margin: 0;
  }

  .ct-body {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem;
    align-items: start;
  }

  .ct-block-label {
    font-family: var(--foglio-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--foglio-ink-soft);
    font-weight: 400;
    margin: 0 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--foglio-rule);
  }

  .ct-primary-link {
    font-family: var(--foglio-mono);
    font-size: 0.9rem;
    color: var(--foglio-accent);
    border-bottom: 1px solid var(--foglio-accent-soft);
    padding-bottom: 2px;
    transition: opacity 0.15s;
  }

  .ct-primary-link:hover {
    opacity: 0.75;
  }

  .ct-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ct-links li {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--foglio-rule);
    align-items: baseline;
  }

  .ct-links li:last-child {
    border-bottom: none;
  }

  .ct-link-role {
    font-family: var(--foglio-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--foglio-ink-soft);
  }

  .ct-link {
    font-family: var(--foglio-serif);
    font-size: 0.95rem;
    color: var(--foglio-ink);
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    word-break: break-all;
  }

  .ct-link:hover {
    color: var(--foglio-accent);
    border-bottom-color: var(--foglio-accent-soft);
  }

  .ct-note {
    font-family: var(--foglio-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--foglio-ink-soft);
    margin: 0;
  }

  @media (max-width: 900px) {
    .ct-body {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .ct-page {
      padding: 3rem 1.4rem 6rem;
    }
    .ct-body {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ct-head {
      margin-bottom: 3rem;
    }
  }
</style>
