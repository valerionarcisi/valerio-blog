---
import BaseHead from "~/components/BaseHead.astro";
import StructuredData from "~/components/StructuredData.astro";
import FoglioHeader from "~/components/FoglioHeader.astro";
import FoglioFooter from "~/components/FoglioFooter.astro";
import RelatedPosts from "~/components/RelatedPosts.astro";
import ShareButtons from "~/components/ShareButtons.astro";
import ReaderMode from "~/components/ReaderMode.astro";
import { SITE_TITLE } from "~/consts";
import "~/styles/foglio.css";
import "./FoglioPostLayout.css";

interface Props {
  title: string;
  extract: string;
  date: string;
  coverImage?: string | null;
  coverAuthorName?: string | null;
  coverAuthorLink?: string | null;
  coverDescription?: string | null;
  tags: string[];
  slug: string;
  lang?: "it" | "en";
  headings?: Array<{ depth: number; slug: string; text: string }>;
}

const {
  title,
  extract,
  date,
  coverImage,
  coverAuthorName,
  coverAuthorLink,
  coverDescription,
  tags,
  slug,
  lang = "it",
  headings = [],
} = Astro.props;

const isEn = lang === "en";
const langSwitchHref = isEn
  ? `/blog/${slug}`
  : `/en/blog/${slug}`;
const langSwitchLabel = isEn ? "IT" : "EN";

const formattedDate = new Date(date).toLocaleDateString(
  isEn ? "en-GB" : "it-IT",
  { day: "numeric", month: "long", year: "numeric" }
);

function tagHref(tag: string): string {
  const slug = tag.toLowerCase().trim().replace(/\s+/g, "-");
  return isEn ? `/en/tag/${slug}/` : `/tag/${slug}/`;
}

const h2Headings = headings.filter((h) => h.depth === 2);
---

<html lang={lang} class="foglio">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={extract}
      cover={coverImage ?? undefined}
      lang={lang}
    />
    <StructuredData
      type="article"
      title={title}
      description={extract}
      url={Astro.url.href}
      image={coverImage ?? undefined}
      datePublished={date}
      tags={tags}
    />
  </head>

  <body>
    <!-- Reading progress bar -->
    <div class="fp-progress" id="fp-progress"></div>
    <script is:inline>
      if (window.matchMedia("(max-width: 1100px)").matches) {
        document.querySelectorAll(".fp-toc[open]").forEach(function (d) {
          d.removeAttribute("open");
        });
      }
    </script>

    <FoglioHeader lang={lang} active="blog" />
    <ReaderMode lang={lang} />
    <main>

    <!-- Cover hero -->
    {coverImage && (
      <section class="fp-cover-hero">
        <img
          class="fp-cover-hero-img"
          src={coverImage}
          alt={title}
          loading="eager"
        />
        {(coverAuthorName || coverDescription) && (
          <div class="fp-cover-hero-caption">
            {coverDescription && <span>{coverDescription}</span>}
            {coverAuthorName && (
              <span>
                {" · "}
                {coverAuthorLink
                  ? <a href={coverAuthorLink} target="_blank" rel="noopener">{coverAuthorName}</a>
                  : coverAuthorName}
              </span>
            )}
          </div>
        )}
      </section>
    )}

    <!-- Post header -->
    <header class="fp-head">
      <div class="fp-eyebrow">
        <span class="fp-eyebrow-tags-date">
          {tags.map((tag, i) => (
            <>
              {i > 0 && <span class="fp-eyebrow-sep"> · </span>}
              <a href={tagHref(tag)} class="fp-eyebrow-tag">{tag}</a>
            </>
          ))}
          {tags.length > 0 && <span class="fp-eyebrow-sep"> · </span>}
          {formattedDate}
        </span>
      </div>
      <h1 class="fp-title">{title}</h1>
      {extract && <p class="fp-extract">{extract}</p>}
    </header>

    <!-- Layout -->
    <div class={`fp-layout${h2Headings.length === 0 ? " fp-layout--no-toc" : ""}`}>
      <!-- Left: Table of Contents -->
      {h2Headings.length > 0 && (
        <details class="fp-toc" open>
          <summary>{isEn ? "On this page" : "In questa pagina"}</summary>
          <ol>
            {h2Headings.map((heading) => (
              <li>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </details>
      )}

      <!-- Center: article content -->
      <article class="fp-article">
        <slot />
        <ShareButtons title={title} url={Astro.url.href} lang={lang} />
      </article>
    </div>

    <!-- Related posts -->
    <div class="fp-related">
      <RelatedPosts currentSlug={slug} currentTags={tags} lang={lang} />
    </div>

    </main>
    <FoglioFooter lang={lang} />

    <!-- marked + DOMPurify for comment rendering -->
    <script>
      import { marked } from "marked";
      import DOMPurify from "dompurify";
      marked.setOptions({ breaks: true, gfm: true });
      // @ts-expect-error attaching renderer to window for the inline comments consumer
      window.__commentsMd = {
        render(text: string): string {
          const raw = marked.parse(text, { async: false }) as string;
          return DOMPurify.sanitize(raw, {
            ALLOWED_TAGS: [
              "p", "br", "strong", "em", "code", "pre", "blockquote",
              "ul", "ol", "li", "a", "h3", "h4", "hr",
            ],
            ALLOWED_ATTR: ["href", "title", "target", "rel"],
          });
        },
      };
      window.dispatchEvent(new CustomEvent("comments-md-ready"));
    </script>

    <!-- Reading progress bar -->
    <script is:inline>
      (function () {
        var bar = document.getElementById("fp-progress");
        if (!bar) return;
        function update() {
          var h = document.documentElement.scrollHeight - window.innerHeight;
          var pct = h > 0 ? (window.scrollY / h) * 100 : 0;
          bar.style.width = pct + "%";
        }
        window.addEventListener("scroll", update, { passive: true });
        update();
      })();
    </script>

    <!-- Copy button for <pre> blocks -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var ICON_COPY = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        var ICON_CHECK = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        document.querySelectorAll(".fp-article pre").forEach(function (pre) {
          pre.style.position = "relative";
          var btn = document.createElement("button");
          btn.className = "fp-copy";
          btn.setAttribute("aria-label", "Copy code");
          btn.innerHTML = ICON_COPY;
          btn.addEventListener("click", function () {
            var code = pre.querySelector("code");
            if (code) {
              navigator.clipboard.writeText(code.textContent || "");
              btn.innerHTML = ICON_CHECK;
              btn.classList.add("is-copied");
              setTimeout(function () {
                btn.innerHTML = ICON_COPY;
                btn.classList.remove("is-copied");
              }, 1800);
            }
          });
          pre.appendChild(btn);
        });
      });
    </script>

    <!-- ToC active section highlight -->
    <script is:inline>
      (function () {
        var toc = document.querySelector(".fp-toc");
        if (!toc) return;
        var links = Array.from(toc.querySelectorAll("a[href^='#']"));
        if (!links.length) return;
        var headings = links.map(function (a) {
          return document.getElementById(a.getAttribute("href").slice(1));
        }).filter(Boolean);

        function activate() {
          var scrollY = window.scrollY + 80;
          var active = headings[0];
          headings.forEach(function (h) {
            if (h.offsetTop <= scrollY) active = h;
          });
          links.forEach(function (a) {
            a.parentElement.classList.toggle(
              "is-current",
              a.getAttribute("href") === "#" + active.id
            );
          });
        }
        window.addEventListener("scroll", activate, { passive: true });
        activate();
      })();
    </script>
  </body>
</html>
