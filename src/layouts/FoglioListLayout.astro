---
import BaseHead from "~/components/BaseHead.astro";
import FoglioHeader from "~/components/FoglioHeader.astro";
import FoglioFooter from "~/components/FoglioFooter.astro";
import { getCollection } from "astro:content";
import { getLangFromId } from "~/i18n/utils";
import "~/styles/foglio.css";
import "~/layouts/FoglioListLayout.css";

interface Props {
  category?: string;
  posts: Array<{
    title: string;
    extract: string;
    date: string;
    coverImage?: string;
    tags: string[];
    slug: string;
  }>;
  lang?: "it" | "en";
  pagination?: {
    currentPage: number;
    lastPage: number;
    url: { prev?: string; next?: string; current: string };
    basePath: string;
  };
  noindex?: boolean;
  activeTag?: string;
}

const { posts, lang = "it", pagination, noindex = false, activeTag } = Astro.props;

const isEn = lang === "en";

const subtitle = isEn
  ? "Writing on cinema and code. Set diaries. Notes when an idea tries to stand up."
  : "Pezzi sul cinema e sul codice. Diari di set quando un corto finisce. Note quando un'idea prova a stare in piedi.";

// Mappa traduzioni tag → label leggibile. Per i tag non listati uso il tag stesso
// capitalizzato. Solo i tag effettivamente usati nei post diventano chip.
const tagLabels: Record<string, { it: string; en: string }> = {
  javascript: { it: "Javascript", en: "Javascript" },
  typescript: { it: "TypeScript", en: "TypeScript" },
  shortmovie: { it: "Cortometraggi", en: "Short films" },
  festival: { it: "Festival", en: "Festival" },
  thoughts: { it: "Pensieri", en: "Thoughts" },
  ai: { it: "AI", en: "AI" },
  caramella: { it: "Caramella", en: "Caramella" },
  "non-fa-ridere": { it: "Non fa ridere", en: "Non fa ridere" },
  letterboxd: { it: "Letterboxd", en: "Letterboxd" },
  lastfm: { it: "Last.fm", en: "Last.fm" },
  strava: { it: "Strava", en: "Strava" },
  meditation: { it: "Meditazione", en: "Meditation" },
  "result-pattern": { it: "Result Pattern", en: "Result Pattern" },
  astro: { it: "Astro", en: "Astro" },
  css: { it: "CSS", en: "CSS" },
};

function tagLabel(tag: string): string {
  const t = tagLabels[tag];
  if (t) return isEn ? t.en : t.it;
  return tag.charAt(0).toUpperCase() + tag.slice(1).replace(/-/g, " ");
}

// Conta occorrenze di ogni tag tra TUTTI i post di questa lingua, normalizzato
// (lowercase + trim) per accorpare duplicati di casing.
const allEntries = await getCollection("blog");
const langPosts = allEntries.filter((e) => getLangFromId(e.id) === lang);
const tagCounts = new Map<string, number>();
for (const p of langPosts) {
  for (const t of p.data.tags ?? []) {
    const key = t.toLowerCase().trim();
    if (!key) continue;
    tagCounts.set(key, (tagCounts.get(key) ?? 0) + 1);
  }
}
// Sort per count desc, poi alpha
const sortedTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag]) => tag);

const VISIBLE_CHIP_COUNT = 5;
const primaryTags = sortedTags.slice(0, VISIBLE_CHIP_COUNT);
const overflowTags = sortedTags.slice(VISIBLE_CHIP_COUNT);

const primaryChips: Array<{ label: string; tag: string | null }> = [
  { label: isEn ? "All" : "Tutti", tag: null },
  ...primaryTags.map((tag) => ({ label: tagLabel(tag), tag })),
];
const overflowChips = overflowTags.map((tag) => ({ label: tagLabel(tag), tag }));

// Se il tag attivo è negli overflow, lo "promuoviamo" e accordion deve essere
// aperta di default così l'utente vede dov'è.
const activeIsInOverflow = activeTag
  ? overflowTags.includes(activeTag.toLowerCase().trim())
  : false;

function chipHref(chip: { label: string; tag: string | null }): string {
  if (!chip.tag) return isEn ? "/en/blog/" : "/blog/";
  return isEn ? `/en/tag/${chip.tag}/` : `/tag/${chip.tag}/`;
}

function isChipActive(chip: { label: string; tag: string | null }): boolean {
  if (!chip.tag) return !activeTag;
  return !!activeTag && activeTag.toLowerCase() === chip.tag.toLowerCase();
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString(isEn ? "en-GB" : "it-IT", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function postHref(slug: string): string {
  return isEn ? `/en/blog/${slug}/` : `/blog/${slug}/`;
}

const pageTitle = isEn ? "Blog | Valerio Narcisi" : "Blog | Valerio Narcisi";
const pageDescription = isEn
  ? "Writing on cinema and code. Set diaries. Notes when an idea tries to stand up."
  : "Pezzi sul cinema e sul codice. Diari di set quando un corto finisce. Note quando un'idea prova a stare in piedi.";
---

<!doctype html>
<html lang={lang} class="foglio">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} lang={lang} />
    {noindex && <meta name="robots" content="noindex, follow" />}
  </head>
  <body>
    <FoglioHeader lang={lang} active="blog" />
    <main>

    <header class="fl-head">
      <h1><em class="acc">Blog</em>.</h1>
      <p>{subtitle}</p>
    </header>

    <div class="fl-filters">
      {primaryChips.map((chip) => (
        <a
          href={chipHref(chip)}
          class={`fl-chip${isChipActive(chip) ? " fl-chip--active" : ""}`}
        >
          {chip.label}
        </a>
      ))}

      {overflowChips.length > 0 && (
        <details class="fl-overflow" open={activeIsInOverflow}>
          <summary class="fl-chip fl-chip--more" aria-label={isEn ? "More tags" : "Altri tag"}>
            +{overflowChips.length} {isEn ? "more" : "altri"}
          </summary>
          <div class="fl-overflow-row">
            {overflowChips.map((chip) => (
              <a
                href={chipHref(chip)}
                class={`fl-chip${isChipActive(chip) ? " fl-chip--active" : ""}`}
              >
                {chip.label}
              </a>
            ))}
          </div>
        </details>
      )}
    </div>

    <section class="fl-posts">
      {posts.map((post) => (
        <a href={postHref(post.slug)} class="fl-row">
          <div class="fl-row-date">{formatDate(post.date)}</div>
          <div class="fl-row-main">
            <h3>{post.title}</h3>
            <p>{post.extract}</p>
          </div>
          <div class="fl-row-tag">
            {post.tags[0] ?? ""}
          </div>
        </a>
      ))}
    </section>

    {pagination && (pagination.url.prev || pagination.url.next) && (
      <nav class="fl-pagination">
        {pagination.url.prev && (
          <a href={pagination.url.prev}>&larr; {isEn ? "Prev" : "Prec"}</a>
        )}
        {pagination.url.next && (
          <a href={pagination.url.next}>{isEn ? "Next" : "Succ"} &rarr;</a>
        )}
      </nav>
    )}

    </main>
    <FoglioFooter lang={lang} />
  </body>
</html>
